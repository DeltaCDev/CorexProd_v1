<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CorexProd.App.Pages.GuiaInternaPage"
             Title="Guia Interna">
    <Grid BackgroundColor="#F4F6F8">
        <Grid x:Name="ListadoPanel" RowDefinitions="Auto,*">
            <VerticalStackLayout Padding="14" Spacing="10" BackgroundColor="White">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <SearchBar x:Name="BuscarSearch"
                               Placeholder="Numero, OCI, cliente u OC"
                               SearchButtonPressed="OnBuscarPressed" />
                    <Button Grid.Column="1"
                            Text="Nueva"
                            Padding="18,8"
                            Clicked="OnNuevaClicked" />
                </Grid>
                <Label x:Name="ResumenLabel"
                       Text="Cargando guias..."
                       FontSize="12"
                       TextColor="#667085" />
            </VerticalStackLayout>

            <RefreshView Grid.Row="1" x:Name="Refresh" Refreshing="OnRefreshing">
                <CollectionView x:Name="GuiasView" Margin="12" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="No hay guias internas registradas."
                               Padding="24"
                               HorizontalTextAlignment="Center"
                               TextColor="#637083" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12" Margin="0,0,0,10" BackgroundColor="White" Stroke="#D9E0E6">
                                <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="5" ColumnSpacing="10">
                                    <Label Text="{Binding NumeroGuia}" FontFamily="OpenSansSemibold" FontSize="16" TextColor="#10324A" />
                                    <Label Grid.Column="1" Text="{Binding Estado}" FontFamily="OpenSansSemibold" TextColor="#067647" />
                                    <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding EmpresaDestino}" TextColor="#344054" LineBreakMode="WordWrap" />
                                    <Label Grid.Row="2" Text="{Binding Origen}" FontSize="12" TextColor="#667085" />
                                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding FechaEmision, StringFormat='{0:dd/MM/yyyy}'}" FontSize="12" TextColor="#667085" />
                                    <Grid Grid.Row="3" Grid.ColumnSpan="2" ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,6,0,0">
                                        <Button Text="Ver detalle" BackgroundColor="#0E9384" Clicked="OnVerDetalleClicked" />
                                        <Button Grid.Column="1" Text="Anular" BackgroundColor="#B42318" Clicked="OnAnularClicked" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>
        </Grid>

        <Grid x:Name="FormularioPanel" RowDefinitions="Auto,*,Auto" IsVisible="False">
            <Grid Padding="14" BackgroundColor="White" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Button Text="Volver" BackgroundColor="#667085" Clicked="OnVolverClicked" />
                <Label Grid.Column="1"
                       Text="Nueva guia interna manual"
                       FontFamily="OpenSansSemibold"
                       FontSize="18"
                       TextColor="#101828"
                       VerticalOptions="Center" />
            </Grid>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="14" Spacing="12">
                    <Border Padding="12" BackgroundColor="White" Stroke="#D9E0E6">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Cabecera" FontFamily="OpenSansSemibold" FontSize="16" TextColor="#10324A" />
                            <Label x:Name="AlmacenLabel" Text="Almacen" TextColor="#344054" />
                            <Picker x:Name="MotivoPicker" Title="Motivo" />
                            <Entry x:Name="DestinoEntry" Placeholder="Destino / cliente" />
                            <Editor x:Name="ObservacionEditor" Placeholder="Observacion" AutoSize="TextChanges" HeightRequest="70" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Padding="12" BackgroundColor="White" Stroke="#D9E0E6">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Producto" FontFamily="OpenSansSemibold" FontSize="16" TextColor="#10324A" />
                            <SearchBar x:Name="ProductoSearch" Placeholder="Codigo, producto o etiqueta" SearchButtonPressed="OnProductoSearchPressed" />
                            <Label x:Name="ProductosLabel" Text="Busque un producto para agregar." FontSize="12" TextColor="#637083" />
                            <CollectionView x:Name="ProductosView" SelectionMode="Single" SelectionChanged="OnProductoSeleccionado" MaximumHeightRequest="320">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10" Margin="0,0,0,8" BackgroundColor="{Binding Fondo}" Stroke="{Binding Borde}">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <Label Text="{Binding Producto.Codigo}" FontFamily="OpenSansSemibold" TextColor="#10324A" />
                                                <Label Grid.Column="1" Text="{Binding Producto.StockActual, StringFormat='Stock {0:N2}'}" FontFamily="OpenSansSemibold" TextColor="#067647" />
                                                <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Producto.NombreProducto}" FontSize="13" TextColor="#344054" LineBreakMode="WordWrap" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                            <Entry x:Name="CantidadEntry" Placeholder="Cantidad a despachar" Keyboard="Numeric" />
                            <Button Text="Agregar" Clicked="OnAgregarClicked" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Padding="12" BackgroundColor="White" Stroke="#D9E0E6">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Detalle" FontFamily="OpenSansSemibold" FontSize="16" TextColor="#10324A" />
                                <Label Grid.Column="1" x:Name="TotalLabel" Text="0 producto(s)" TextColor="#637083" />
                            </Grid>
                            <CollectionView x:Name="DetalleView" SelectionMode="None" MaximumHeightRequest="320">
                                <CollectionView.EmptyView>
                                    <Label Text="Agregue productos para emitir la guia." Padding="12" TextColor="#637083" />
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,8" ColumnDefinitions="*,Auto">
                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="{Binding Producto.Codigo}" FontFamily="OpenSansSemibold" TextColor="#10324A" />
                                                <Label Text="{Binding Producto.NombreProducto}" FontSize="13" TextColor="#344054" LineBreakMode="WordWrap" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1" Text="{Binding Cantidad, StringFormat='{0:N2}'}" FontFamily="OpenSansSemibold" TextColor="#067647" VerticalOptions="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

            <Grid Grid.Row="2" Padding="14" BackgroundColor="White" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Button Text="Limpiar" BackgroundColor="#667085" Clicked="OnLimpiarClicked" />
                <Button Grid.Column="1" x:Name="EmitirButton" Text="Emitir guia" Clicked="OnEmitirClicked" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
