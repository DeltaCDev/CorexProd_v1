<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CorexProd.App.Pages.HomePage"
             Title="Menu principal">
    <Grid ColumnDefinitions="150,*" BackgroundColor="#F4F6F8">
        <ScrollView BackgroundColor="#10324A">
            <VerticalStackLayout Padding="10,16" Spacing="10">
                <Label Text="CorexProd"
                       FontFamily="OpenSansSemibold"
                       FontSize="18"
                       TextColor="White" />
                <Label x:Name="UserLabel"
                       FontSize="12"
                       TextColor="#CFE1EC"
                       LineBreakMode="WordWrap" />
                <BoxView HeightRequest="1" Color="#2E5B73" />

                <Label Text="Almacen" FontFamily="OpenSansSemibold" FontSize="12" TextColor="#A9D3E8" />
                <Button Text="Stock productos" FontSize="12" Padding="8,6" Clicked="OnProductosClicked" />
                <Button Text="Stock insumos" FontSize="12" Padding="8,6" Clicked="OnInsumosClicked" />
                <Button Text="Ingreso stock" FontSize="12" Padding="8,6" Clicked="OnIngresoStockClicked" />

                <Label Text="Ventas" FontFamily="OpenSansSemibold" FontSize="12" TextColor="#A9D3E8" />
                <Button Text="Proformas" FontSize="12" Padding="8,6" Clicked="OnProformasClicked" />
                <Button Text="OCI" FontSize="12" Padding="8,6" Clicked="OnOciClicked" />
                <Button Text="Guia Interna" FontSize="12" Padding="8,6" Clicked="OnGuiaInternaClicked" />

                <Label Text="Produccion" FontFamily="OpenSansSemibold" FontSize="12" TextColor="#A9D3E8" />
                <Button Text="OT Produccion" FontSize="12" Padding="8,6" Clicked="OnOrdenesTrabajoClicked" />

                <Label Text="Reportes" FontFamily="OpenSansSemibold" FontSize="12" TextColor="#A9D3E8" />
                <Button Text="Kardex" FontSize="12" Padding="8,6" Clicked="OnKardexClicked" />

                <BoxView HeightRequest="1" Color="#2E5B73" />
                <Button Text="Cerrar sesion"
                        FontSize="12"
                        Padding="8,6"
                        BackgroundColor="#667085"
                        Clicked="OnLogoutClicked" />
            </VerticalStackLayout>
        </ScrollView>

        <ScrollView Grid.Column="1">
            <VerticalStackLayout Padding="16" Spacing="14">
                <Border Padding="16" BackgroundColor="White" Stroke="#D9E0E6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Image x:Name="CompanyLogo"
                               Source="logo.png"
                               WidthRequest="118"
                               HeightRequest="118"
                               Aspect="AspectFit" />
                        <Label x:Name="WelcomeLabel"
                               Text="Bienvenido"
                               FontFamily="OpenSansSemibold"
                               FontSize="22"
                               TextColor="#101828"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                        <Label x:Name="RoleLabel"
                               FontSize="13"
                               TextColor="#667085"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <Border Padding="14" BackgroundColor="White" Stroke="#D9E0E6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Modulos habilitados"
                               FontFamily="OpenSansSemibold"
                               FontSize="15" />
                        <CollectionView x:Name="MenusView"
                                        SelectionMode="None"
                                        MaximumHeightRequest="260">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,5">
                                        <Label Text="{Binding .}"
                                               TextColor="#344054" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
