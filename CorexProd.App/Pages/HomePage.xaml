<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CorexProd.App.Pages.HomePage"
             Title="Menú principal">
    <Grid RowDefinitions="Auto,*" BackgroundColor="#F4F6F8">
        <VerticalStackLayout Padding="20,18" BackgroundColor="#10324A" Spacing="4">
            <Label x:Name="UserLabel"
                   FontFamily="OpenSansSemibold"
                   FontSize="18"
                   TextColor="White" />
            <Label x:Name="RoleLabel"
                   FontSize="13"
                   TextColor="#CFE1EC" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="12">
                <Grid ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto,Auto"
                      ColumnSpacing="12"
                      RowSpacing="12">
                    <Button Text="Stock productos"
                            Clicked="OnProductosClicked" />
                    <Button Grid.Column="1"
                            Text="Stock insumos"
                            Clicked="OnInsumosClicked" />
                    <Button Grid.Row="1"
                            Text="Proformas"
                            IsEnabled="False" />
                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Text="OCI"
                            IsEnabled="False" />
                    <Button Grid.Row="2"
                            Text="Órdenes de Trabajo"
                            IsEnabled="False" />
                    <Button Grid.Row="2"
                            Grid.Column="1"
                            Text="Kardex"
                            IsEnabled="False" />
                </Grid>

                <Border Padding="14" BackgroundColor="White" Stroke="#D9E0E6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Módulos habilitados"
                               FontFamily="OpenSansSemibold"
                               FontSize="15" />
                        <CollectionView x:Name="MenusView"
                                        SelectionMode="None"
                                        MaximumHeightRequest="260">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,5">
                                        <Label Text="{Binding .}"
                                               TextColor="#344054" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Button Text="Cerrar sesión"
                        BackgroundColor="#667085"
                        Clicked="OnLogoutClicked" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
