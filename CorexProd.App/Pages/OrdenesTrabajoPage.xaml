<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CorexProd.App.Pages.OrdenesTrabajoPage"
             Title="OT Producción">
    <Grid RowDefinitions="Auto,*" BackgroundColor="#F4F6F8">
        <VerticalStackLayout Padding="14" Spacing="10" BackgroundColor="White">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <VerticalStackLayout Spacing="3"><Label Text="Desde" FontSize="11" TextColor="#667085"/><DatePicker x:Name="FechaDesde" DateSelected="OnFilterChanged"/></VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" Spacing="3"><Label Text="Hasta" FontSize="11" TextColor="#667085"/><DatePicker x:Name="FechaHasta" DateSelected="OnFilterChanged"/></VerticalStackLayout>
            </Grid>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Picker x:Name="EstadoPicker" Title="Estado" SelectedIndexChanged="OnFilterChanged"/>
                <Entry Grid.Column="1" x:Name="ClienteFilter" Placeholder="Cliente" TextChanged="OnFilterTextChanged"/>
            </Grid>
            <SearchBar x:Name="Search"
                       Placeholder="OT, OCI, cliente o estado"
                       SearchButtonPressed="OnSearchPressed"
                       TextChanged="OnSearchTextChanged" />
            <Grid ColumnDefinitions="*,Auto">
                <Label x:Name="CountLabel"
                       Text="Sin datos"
                       TextColor="#637083"
                       VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="Buscar"
                        Clicked="OnBuscarClicked" />
            </Grid>
        </VerticalStackLayout>

        <RefreshView Grid.Row="1" x:Name="Refresh" Refreshing="OnRefreshing">
            <CollectionView x:Name="OrdenesView"
                            Margin="12"
                            SelectionMode="Single"
                            SelectionChanged="OnOrdenSelectionChanged">
                <CollectionView.EmptyView>
                    <Label Text="No hay órdenes de trabajo para mostrar."
                           Padding="24"
                           HorizontalTextAlignment="Center"
                           TextColor="#637083" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" Margin="0,0,0,10" BackgroundColor="White" Stroke="#D9E0E6">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <Label Text="{Binding NumeroOT}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="15"
                                       TextColor="#10324A" />
                                <Label Grid.Column="1"
                                       Text="{Binding Estado}"
                                       FontSize="12"
                                       TextColor="#B54708" />
                                <Label Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding NombreCliente}"
                                       LineBreakMode="WordWrap"
                                       TextColor="#344054" />
                                <Label Grid.Row="2"
                                       Text="{Binding NumeroOci, StringFormat='OCI: {0}'}"
                                       FontSize="12"
                                       TextColor="#667085" />
                                <Label Grid.Row="2"
                                       Grid.Column="1"
                                       Text="{Binding Avance, StringFormat='{0:P0}'}"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="#067647" />
                                <Label Grid.Row="3"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding OrdenCompraCliente, StringFormat='OC Cliente: {0}'}"
                                       FontSize="12"
                                       TextColor="#475467" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
