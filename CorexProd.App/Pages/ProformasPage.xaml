<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CorexProd.App.Pages.ProformasPage"
             Title="Proformas">
    <Grid RowDefinitions="Auto,*" BackgroundColor="#F4F6F8">
        <VerticalStackLayout Padding="14" Spacing="10" BackgroundColor="White">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <VerticalStackLayout Spacing="3"><Label Text="Desde" FontSize="11" TextColor="#667085"/><DatePicker x:Name="FechaDesde" DateSelected="OnFilterChanged"/></VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" Spacing="3"><Label Text="Hasta" FontSize="11" TextColor="#667085"/><DatePicker x:Name="FechaHasta" DateSelected="OnFilterChanged"/></VerticalStackLayout>
            </Grid>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Picker x:Name="EstadoPicker" Title="Estado" SelectedIndexChanged="OnFilterChanged"/>
                <Entry Grid.Column="1" x:Name="ClienteFilter" Placeholder="Cliente" TextChanged="OnFilterTextChanged"/>
            </Grid>
            <SearchBar x:Name="Search"
                       Placeholder="Numero, cliente u OC"
                       SearchButtonPressed="OnSearchPressed"
                       TextChanged="OnSearchTextChanged" />
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <Label x:Name="CountLabel" Text="Sin datos" TextColor="#637083" VerticalOptions="Center" />
                <Button Grid.Column="1" Text="Nueva" Clicked="OnNuevaClicked" />
                <Button Grid.Column="2" Text="Buscar" Clicked="OnBuscarClicked" />
            </Grid>
        </VerticalStackLayout>

        <RefreshView Grid.Row="1" x:Name="Refresh" Refreshing="OnRefreshing">
            <CollectionView x:Name="ItemsView" Margin="12" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Text="No hay proformas para mostrar." Padding="24" HorizontalTextAlignment="Center" TextColor="#637083" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" Margin="0,0,0,10" BackgroundColor="White" Stroke="#D9E0E6">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="10">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <Label Text="{Binding Item.SerieNumero}" FontFamily="OpenSansSemibold" FontSize="15" TextColor="#10324A" />
                                    <Label Grid.Column="1" Text="{Binding Item.Total, StringFormat='S/ {0:N2}'}" FontFamily="OpenSansSemibold" TextColor="#067647" />
                                    <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Item.NombreCliente}" LineBreakMode="WordWrap" TextColor="#344054" />
                                    <Label Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding OcClienteTexto}" FontSize="12" TextColor="#475467" />
                                    <Label Grid.Row="3" Text="{Binding Item.Estado}" FontSize="12" TextColor="#667085" />
                                    <Label Grid.Row="3" Grid.Column="1" Text="{Binding Item.FechaEmision, StringFormat='{0:dd/MM/yyyy}'}" FontSize="12" TextColor="#667085" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                    <Button Text="👁 Ver detalle" FontSize="12" Padding="8,6" Clicked="OnVerDetalleClicked" />
                                    <Button Grid.Column="1"
                                            Text="{Binding OciAccionTexto}"
                                            FontSize="12"
                                            Padding="8,6"
                                            BackgroundColor="{Binding OciAccionColor}"
                                            TextColor="White"
                                            IsEnabled="{Binding PuedeGenerarOci}"
                                            Clicked="OnGenerarOciClicked" />
                                    <Button Grid.Column="2"
                                            Text="🗑 Anular"
                                            FontSize="12"
                                            Padding="8,6"
                                            BackgroundColor="#B42318"
                                            Clicked="OnAnularClicked" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
