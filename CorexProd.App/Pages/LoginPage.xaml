<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CorexProd.App.Pages.LoginPage"
             Shell.NavBarIsVisible="False"
             Title="Inicio de sesión">
    <Grid BackgroundColor="#F4F6F8">
        <ScrollView>
            <VerticalStackLayout Padding="20,28" Spacing="14">
                <Image Source="logo.png"
                       WidthRequest="82"
                       HeightRequest="82"
                       HorizontalOptions="Center">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnApiIconTapped" />
                    </Image.GestureRecognizers>
                </Image>

                <Label Text="CorexProd"
                       FontFamily="OpenSansSemibold"
                       FontSize="28"
                       HorizontalTextAlignment="Center"
                       TextColor="#101828" />

                <Border Padding="16" BackgroundColor="White" Stroke="#D9E0E6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Usuario" FontFamily="OpenSansSemibold" FontSize="14" />
                        <Entry x:Name="UserEntry"
                               Placeholder="Usuario"
                               ReturnType="Next" />

                        <Label Text="Contraseña" FontFamily="OpenSansSemibold" FontSize="14" />
                        <Entry x:Name="PasswordEntry"
                               Placeholder="Contraseña"
                               IsPassword="True"
                               ReturnType="Go"
                               Completed="OnPasswordCompleted" />

                        <Button x:Name="LoginButton"
                                Text="Iniciar sesión"
                                Clicked="OnLoginClicked" />

                        <ActivityIndicator x:Name="BusyIndicator"
                                           IsVisible="False"
                                           IsRunning="False" />

                        <Label x:Name="MessageLabel"
                               TextColor="#B42318"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="ApiPanel"
                        Padding="16"
                        BackgroundColor="White"
                        Stroke="#D9E0E6"
                        IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Conexión API" FontFamily="OpenSansSemibold" FontSize="14" />
                        <Entry x:Name="ServerEntry"
                               Keyboard="Url"
                               Placeholder="http://192.168.1.50:5000"
                               ReturnType="Next" />

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Label x:Name="ServerStatusLabel"
                                   Text="Use la IP de la PC servidor cuando esté en planta."
                                   TextColor="#637083"
                                   LineBreakMode="WordWrap"
                                   VerticalOptions="Center" />
                            <Button Grid.Column="1"
                                    Text="Probar"
                                    Clicked="OnTestConnectionClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
