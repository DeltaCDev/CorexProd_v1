<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CorexProd.App.Pages.LoginPage"
             Shell.NavBarIsVisible="False"
             Title="Inicio de sesión">
    <Grid RowDefinitions="Auto,*" BackgroundColor="#F4F6F8">
        <VerticalStackLayout Padding="24,36,24,22" BackgroundColor="#10324A" Spacing="6">
            <Label Text="CorexProd"
                   FontFamily="OpenSansSemibold"
                   FontSize="30"
                   TextColor="White" />
            <Label Text="App de planta y almacén"
                   FontSize="14"
                   TextColor="#CFE1EC" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="14">
                <Border Padding="16" BackgroundColor="White" Stroke="#D9E0E6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Servidor API" FontFamily="OpenSansSemibold" FontSize="14" />
                        <Entry x:Name="ServerEntry"
                               Keyboard="Url"
                               Placeholder="http://192.168.1.50:5000"
                               ReturnType="Next" />

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Label x:Name="ServerStatusLabel"
                                   Text="Use la IP de la PC servidor cuando esté en planta."
                                   TextColor="#637083"
                                   VerticalOptions="Center" />
                            <Button Grid.Column="1"
                                    Text="Probar"
                                    Clicked="OnTestConnectionClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Padding="16" BackgroundColor="White" Stroke="#D9E0E6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Usuario" FontFamily="OpenSansSemibold" FontSize="14" />
                        <Entry x:Name="UserEntry"
                               Placeholder="Usuario"
                               ReturnType="Next" />

                        <Label Text="Contraseña" FontFamily="OpenSansSemibold" FontSize="14" />
                        <Entry x:Name="PasswordEntry"
                               Placeholder="Contraseña"
                               IsPassword="True"
                               ReturnType="Go"
                               Completed="OnPasswordCompleted" />

                        <Button x:Name="LoginButton"
                                Text="Ingresar"
                                Clicked="OnLoginClicked" />

                        <ActivityIndicator x:Name="BusyIndicator"
                                           IsVisible="False"
                                           IsRunning="False" />

                        <Label x:Name="MessageLabel"
                               TextColor="#B42318"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
