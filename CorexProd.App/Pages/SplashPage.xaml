<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CorexProd.App.Pages.SplashPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">
    <Grid Padding="28" RowDefinitions="*,Auto,*">
        <Grid Grid.Row="1"
              HorizontalOptions="Center"
              VerticalOptions="Center"
              WidthRequest="230"
              HeightRequest="260"
              RowDefinitions="*,Auto">
            <Grid x:Name="LogoStage"
                  WidthRequest="210"
                  HeightRequest="210"
                  HorizontalOptions="Center"
                  VerticalOptions="Center">
                <Ellipse x:Name="PulseOne"
                         Fill="#0BA5EC"
                         Opacity="0.10"
                         Scale="0.35" />
                <Ellipse x:Name="PulseTwo"
                         Fill="#F79009"
                         Opacity="0.08"
                         Scale="0.20" />
                <Image x:Name="LogoMark"
                       Source="logo.png"
                       WidthRequest="178"
                       HeightRequest="178"
                       Aspect="AspectFit"
                       Opacity="0"
                       Scale="0.55"
                       Rotation="-18"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Grid>

            <Grid Grid.Row="1"
                  Margin="0,10,0,0"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="8"
                  HorizontalOptions="Center"
                  WidthRequest="150">
                <BoxView x:Name="BlueBar"
                         HeightRequest="5"
                         CornerRadius="3"
                         ScaleX="0"
                         Color="#0BA5EC" />
                <BoxView x:Name="GreenBar"
                         Grid.Column="1"
                         HeightRequest="5"
                         CornerRadius="3"
                         ScaleX="0"
                         Color="#85D028" />
                <BoxView x:Name="OrangeBar"
                         Grid.Column="2"
                         HeightRequest="5"
                         CornerRadius="3"
                         ScaleX="0"
                         Color="#F79009" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
