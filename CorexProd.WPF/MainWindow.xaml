<Window x:Class="CorexProd.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CorexProd"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#000000">
            <DockPanel>

                <!-- LOGO -->
                <StackPanel DockPanel.Dock="Top" Margin="0,15,0,0">
                    <Image Source="/Images/LOGO.png"
                           Height="110"
                           Margin="10,0,10,20"
                           Stretch="Uniform"/>

                    <Button Content="Inicio"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding IrInicioCommand}"/>
                </StackPanel>

                <!-- USUARIO -->
                <StackPanel DockPanel.Dock="Bottom" Margin="15">
                    <TextBlock Text="Usuario:"
                               Foreground="#9CA3AF"
                               FontSize="12"/>

                    <TextBlock Text="{Binding NombreUsuario}"
                               Foreground="White"
                               FontWeight="Bold"
                               Margin="0,5,0,15"/>

                    <Button Content="Cerrar sesión"
                            Height="35"
                            Background="#DC2626"
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>

                <!-- MENÚ DINÁMICO -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SidebarMenus}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Header="{Binding Titulo}"
                                          Foreground="White"
                                          Background="#000000"
                                          Margin="10,3"
                                          IsExpanded="False">

                                    <ItemsControl ItemsSource="{Binding Hijos}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Titulo}"
                                                        Command="{Binding DataContext.IrVistaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Vista}"
                                                        Height="34"
                                                        Margin="10,2,0,2"
                                                        Padding="18,0"
                                                        Background="#111827"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        HorizontalContentAlignment="Left"
                                                        Cursor="Hand"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="White">
                <TextBlock Text="{Binding Titulo}"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="25,0,0,0"/>
            </Border>

            <!-- ÁREA CENTRAL -->
            <Border Grid.Row="1"
                    Margin="20"
                    Background="White"
                    CornerRadius="10">

                <ContentControl Content="{Binding VistaActual}"/>

            </Border>
        </Grid>
    </Grid>
</Window>