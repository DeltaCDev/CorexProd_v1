<Window x:Class="CorexProd.WPF.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CorexProd"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        Background="#F3F4F6">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding DataContext.SidebarWidth, ElementName=RootWindow}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#020617">
            <DockPanel LastChildFill="True">

                <!-- TOP SIDEBAR -->
                <StackPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                    <Button Content="{Binding SidebarToggleText}"
                            Command="{Binding ToggleSidebarCommand}"
                            ToolTip="{Binding SidebarToggleToolTip}"
                            Width="36"
                            Height="30"
                            Margin="0,0,12,8"
                            HorizontalAlignment="Right"
                            Background="#111827"
                            Foreground="White"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            FontWeight="Bold"
                            Cursor="Hand"/>

                    <StackPanel Visibility="{Binding SidebarExpandedVisibility}">
                        <Image Source="/Images/LOGO.png"
                               Height="110"
                               Margin="10,0,10,20"
                               Stretch="Uniform"/>

                        <Button Content="Inicio"
                                Style="{StaticResource MenuButtonStyle}"
                                Command="{Binding IrInicioCommand}"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding SidebarCollapsedVisibility}">
                        <Image Source="/Images/LOGO.png"
                               Width="42"
                               Height="42"
                               Margin="10,0,10,10"
                               Stretch="Uniform"/>

                        <Button Content="I"
                                Command="{Binding IrInicioCommand}"
                                ToolTip="Inicio"
                                Width="40"
                                Height="40"
                                Margin="12,0"
                                Background="#111827"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>

                <!-- USUARIO -->
                <Border DockPanel.Dock="Bottom"
                        Margin="12"
                        Padding="11"
                        Background="#18243A"
                        CornerRadius="8"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        Visibility="{Binding SidebarExpandedVisibility}">

                    <StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="{Binding NombreUsuario}"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="White"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Text="{Binding NombreRol}"
                                       FontSize="12"
                                       Foreground="#CBD5E1"
                                       Margin="0,3,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Cambiar clave"
                                    Command="{Binding CambiarClaveCommand}"
                                    Width="132"
                                    Height="32"
                                    Margin="0,0,8,0"
                                    Background="#3B82F6"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"/>

                            <Button Command="{Binding CerrarSesionCommand}"
                                    Width="38"
                                    Height="32"
                                    Background="#EF4444"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Cerrar sesión">
                                <TextBlock Text="&#xE8AC;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- MENÚ DINÁMICO -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding SidebarExpandedVisibility}">
                    <ItemsControl ItemsSource="{Binding SidebarMenus}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Header="{Binding Titulo}"
                                          Foreground="White"
                                          Background="#020617"
                                          Margin="10,3"
                                          IsExpanded="False">

                                    <ItemsControl ItemsSource="{Binding Hijos}"
                                                  Margin="10,4,0,4">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Titulo}"
                                                        Command="{Binding DataContext.IrVistaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Vista}"
                                                        Height="34"
                                                        Margin="12,2,8,2"
                                                        Padding="14,0,0,0"
                                                        Background="#111827"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Cursor="Hand"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="White">
                <Grid Margin="25,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Titulo}"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <StackPanel x:Name="ListadoHerramientas"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <TextBlock x:Name="CantidadItemsText"
                                   Foreground="#475569"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,14,0"/>
                        <Button Click="ExportarListado_Click"
                                Height="36"
                                MinWidth="100"
                                Padding="14,0"
                                Background="#16A34A"
                                BorderBrush="#16A34A"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                <TextBlock Text="Exportar"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ÁREA CENTRAL -->
            <Border Grid.Row="1"
                    Margin="20"
                    Background="White"
                    CornerRadius="10">

                <ContentControl x:Name="ContenidoPrincipal" Content="{Binding VistaActual}"/>

            </Border>
        </Grid>
    </Grid>
</Window>
