<Window x:Class="CorexProd.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CorexProd"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENÚ LATERAL -->
        <Border Grid.Column="0" Background="#111827">
            <DockPanel>

                <StackPanel DockPanel.Dock="Top" Margin="0,25,0,0">
                    <TextBlock Text="CorexProd"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>

                    <Button Content="Ventas" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Almacén" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Productos" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Producción" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Reportes" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Seguridad" Style="{StaticResource MenuButtonStyle}"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="15">
                    <TextBlock Text="Usuario:"
                               Foreground="#9CA3AF"
                               FontSize="12"/>

                    <TextBlock x:Name="TxtUsuario"
                               Text="Administrador"
                               Foreground="White"
                               FontWeight="Bold"
                               Margin="0,5,0,15"/>

                    <Button Content="Cerrar sesión"
                            Height="35"
                            Background="#DC2626"
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="White">
                <TextBlock Text="Panel principal"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="25,0,0,0"/>
            </Border>

            <!-- ÁREA CENTRAL -->
            <Border Grid.Row="1"
                    Margin="20"
                    Background="White"
                    CornerRadius="10">

                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <TextBlock Text="Bienvenido a CorexProd"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Sistema de producción, ventas, almacén e inventario"
                               FontSize="16"
                               Foreground="Gray"
                               Margin="0,10,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>

            </Border>
        </Grid>
    </Grid>
</Window>