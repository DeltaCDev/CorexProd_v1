<Window x:Class="CorexProd.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CorexProd"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENÚ LATERAL -->
        <Border Grid.Column="0" Background="#000000">
            <DockPanel>

                <StackPanel DockPanel.Dock="Top" Margin="0,25,0,0">
                    <Image  Source="/Images/LOGO.png"
                            Height="120"
                            Margin="10,10,10,25"
                            Stretch="Uniform"/>

                    <Button Content="Inicio"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding IrInicioCommand}"/>

                    <Button Content="Ventas"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding IrVentasCommand}"
                            Visibility="{Binding VerVentas, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Content="Almacén"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding IrAlmacenCommand}"
                            Visibility="{Binding VerAlmacen, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Content="Productos"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding IrProductosCommand}"
                            Visibility="{Binding VerProductos, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Content="Producción"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding IrProduccionCommand}"
                            Visibility="{Binding VerProduccion, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Content="Reportes"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding IrReportesCommand}"
                            Visibility="{Binding VerReportes, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Content="Seguridad"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding IrSeguridadCommand}"
                            Visibility="{Binding VerSeguridad, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="15">
                    <TextBlock Text="Usuario:"
                               Foreground="#9CA3AF"
                               FontSize="12"/>

                    <TextBlock x:Name="TxtUsuario"
                               Text="{Binding NombreUsuario}"
                               Foreground="White"
                               FontWeight="Bold"
                               Margin="0,5,0,15"/>

                    <Button Content="Cerrar sesión"
                            Height="35"
                            Background="#DC2626"
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="White">
                <TextBlock Text="{Binding Titulo}"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="25,0,0,0"/>
            </Border>

            <!-- ÁREA CENTRAL -->
            <Border Grid.Row="1"
        Margin="20"
        Background="White"
        CornerRadius="10">

                <ContentControl Content="{Binding VistaActual}"/>

            </Border>
        </Grid>
    </Grid>
</Window>