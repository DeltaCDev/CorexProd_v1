<Window x:Class="CorexProd.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CorexProd"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#000000">
            <DockPanel>

                <!-- LOGO -->
                <StackPanel DockPanel.Dock="Top" Margin="0,15,0,0">
                    <Image Source="/Images/LOGO.png"
                           Height="110"
                           Margin="10,0,10,20"
                           Stretch="Uniform"/>

                    <Button Content="Inicio"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding IrInicioCommand}"/>
                </StackPanel>

                <!-- USUARIO -->
                <!-- USUARIO -->
                <Border DockPanel.Dock="Bottom"
        Margin="12"
        Padding="14"
        Background="#0F172A"
        CornerRadius="10"
        BorderBrush="#1E293B"
        BorderThickness="1">

                    <StackPanel>

                        <!-- Usuario -->
                        <StackPanel Margin="0,0,0,14">

                            <TextBlock Text="{Binding NombreUsuario}"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Foreground="White"/>

                            <TextBlock Text="{Binding NombreRol}"
                       FontSize="12"
                       Foreground="#94A3B8"
                       Margin="0,3,0,0"/>

                        </StackPanel>

                        <!-- Botón cambiar clave -->
                        <Button Content="Cambiar clave"
                Command="{Binding CambiarClaveCommand}"
                Height="36"
                Margin="0,0,0,8"
                Background="#2563EB"
                Foreground="White"
                BorderThickness="0"
                FontWeight="SemiBold"
                Cursor="Hand"/>

                        <!-- Botón cerrar sesión -->
                        <Button Content="Cerrar sesión"
                Command="{Binding CerrarSesionCommand}"
                Height="36"
                Background="#DC2626"
                Foreground="White"
                BorderThickness="0"
                FontWeight="SemiBold"
                Cursor="Hand"/>

                    </StackPanel>
                </Border>

                <!-- MENÚ DINÁMICO -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SidebarMenus}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Header="{Binding Titulo}"
                                          Foreground="White"
                                          Background="#000000"
                                          Margin="10,3"
                                          IsExpanded="False">

                                    <ItemsControl ItemsSource="{Binding Hijos}"
                                                  Margin="10,4,0,4">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Titulo}"
                                                        Command="{Binding DataContext.IrVistaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Vista}"
                                                        Height="34"
                                                        Margin="12,2,8,2"
                                                        Padding="14,0,0,0"
                                                        Background="#111827"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Cursor="Hand"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="White">
                <TextBlock Text="{Binding Titulo}"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="25,0,0,0"/>
            </Border>

            <!-- ÁREA CENTRAL -->
            <Border Grid.Row="1"
                    Margin="20"
                    Background="White"
                    CornerRadius="10">

                <ContentControl Content="{Binding VistaActual}"/>

            </Border>
        </Grid>
    </Grid>
</Window>