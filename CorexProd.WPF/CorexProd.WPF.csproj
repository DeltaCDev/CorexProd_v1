<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\CorexProd.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Assets\CorexProd.ico" />
    <None Remove="Images\LOGO.png" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CorexProd.Entidad\CorexProd.Entidad.csproj" />
    <ProjectReference Include="..\CorexProd.Negocio\CorexProd.Negocio.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\CorexProd.ico">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Resource>
    <Resource Include="Images\LOGO.png" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Modules\Reportes\ViewModels\" />
    <Folder Include="Modules\Ventas\ViewModels\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="HandyControl" Version="3.5.1" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.4022.49" />
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="10.0.7" />
  </ItemGroup>

</Project>
