<Window x:Class="CorexProd.WPF.Modules.Produccion.Views.ValidacionInsumosWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Validación de insumos" Height="430" Width="760" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
 <Grid Margin="20"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <TextBlock Text="Validación de insumos para producción" FontSize="20" FontWeight="Bold" Margin="0,0,0,14"/>
  <DataGrid x:Name="ProductosGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"><DataGrid.Columns><DataGridTextColumn Header="Alerta" Binding="{Binding Alerta}" Width="65"/><DataGridTextColumn Header="Producto" Binding="{Binding Producto}" Width="*"/><DataGridTextColumn Header="Estado de insumos" Binding="{Binding EstadoInsumos}" Width="150"/></DataGrid.Columns></DataGrid>
  <TextBlock x:Name="MensajeText" Grid.Row="2" TextWrapping="Wrap" Margin="0,12,0,0" Foreground="#B45309"/>
  <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0"><Button Content="Cancelar" Width="95" Height="35" Margin="0,0,8,0" IsCancel="True"/><Button Content="Continuar" Width="110" Height="35" IsDefault="True" Click="Continuar_Click"/></StackPanel>
 </Grid>
</Window>
