<Window x:Class="CorexProd.WPF.Modules.Produccion.Views.ValidacionInsumosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Validación de insumos"
        Height="540" Width="980" MinHeight="480" MinWidth="860"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style x:Key="AlertaTexto" TargetType="TextBlock">
            <Setter Property="Text" Value="●"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#16A34A"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding EstadoInsumos}" Value="Faltantes">
                    <Setter Property="Text" Value="⊖"/>
                    <Setter Property="Foreground" Value="#DC2626"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EstadoInsumos}" Value="Sin ficha tecnica">
                    <Setter Property="Text" Value="●"/>
                    <Setter Property="Foreground" Value="#D97706"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="EstadoTexto" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#15803D"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding EstadoInsumos}" Value="Faltantes">
                    <Setter Property="Foreground" Value="#DC2626"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EstadoInsumos}" Value="Sin ficha tecnica">
                    <Setter Property="Foreground" Value="#D97706"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,14">
            <TextBlock Text="Validación de insumos para producción"
                       FontSize="22" FontWeight="Bold"/>
            <TextBlock x:Name="OciText" Margin="0,5,0,0" Foreground="#64748B"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8">
            <DataGrid x:Name="ProductosGrid" AutoGenerateColumns="False"
                      CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column"
                      RowHeight="44" GridLinesVisibility="None" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Alerta" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource AlertaTexto}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Producto" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Producto}"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="36"
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding Producto}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Cantidad a elaborar"
                                        Binding="{Binding CantidadRequerida, StringFormat=N3}"
                                        Width="140"/>
                    <DataGridTemplateColumn Header="Estado" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding EstadoInsumos}"
                                           Style="{StaticResource EstadoTexto}"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock x:Name="MensajeText" Grid.Row="2" TextWrapping="Wrap"
                   Margin="0,10,0,0" Foreground="#475569"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancelar" Width="100" Height="36" Margin="0,0,8,0"
                    IsCancel="True"/>
            <Button Content="Continuar" Width="120" Height="36" IsDefault="True"
                    Click="Continuar_Click"/>
        </StackPanel>
    </Grid>
</Window>
