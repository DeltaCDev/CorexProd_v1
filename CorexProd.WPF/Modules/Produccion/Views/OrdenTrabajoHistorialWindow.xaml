<Window x:Class="CorexProd.WPF.Modules.Produccion.Views.OrdenTrabajoHistorialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historial de movimientos"
        Height="620"
        Width="1080"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,14">
            <TextBlock Text="HISTORIAL DE MOVIMIENTOS DE PRODUCCION"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#7E22CE"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="ResumenText"
                       Margin="0,6,0,0"
                       HorizontalAlignment="Center"
                       Foreground="#475569"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="OtText" FontWeight="SemiBold"/>
                <TextBlock x:Name="OciText" Grid.Column="1"/>
                <TextBlock x:Name="ClienteText" Grid.Column="2"/>
            </Grid>
        </Border>

        <DataGrid x:Name="MovimientosGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  MinRowHeight="38">
            <DataGrid.Resources>
                <Style x:Key="TextoWrap" TargetType="TextBlock">
                    <Setter Property="TextWrapping" Value="Wrap"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="4,5"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha/Hora" Binding="{Binding FechaHora, StringFormat=dd/MM/yyyy HH:mm}" Width="135"/>
                <DataGridTextColumn Header="Producto" Binding="{Binding Producto}" Width="260" ElementStyle="{StaticResource TextoWrap}"/>
                <DataGridTextColumn Header="Origen" Binding="{Binding Origen}" Width="130"/>
                <DataGridTextColumn Header="Destino" Binding="{Binding Destino}" Width="130"/>
                <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad, StringFormat=N2}" Width="90"/>
                <DataGridTextColumn Header="Accion" Binding="{Binding Accion}" Width="115"/>
                <DataGridTextColumn Header="Usuario" Binding="{Binding Usuario}" Width="125"/>
                <DataGridTextColumn Header="Observacion" Binding="{Binding Observacion}" Width="*" ElementStyle="{StaticResource TextoWrap}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="3"
                Content="Cerrar"
                Width="100"
                Height="36"
                HorizontalAlignment="Center"
                Margin="0,14,0,0"
                IsCancel="True"/>
    </Grid>
</Window>
