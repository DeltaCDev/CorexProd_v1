<Window x:Class="CorexProd.WPF.Modules.Produccion.Views.OrdenTrabajoHistorialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historial de movimientos"
        Height="660" Width="1120"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,12">
            <TextBlock Text="↺ HISTORIAL DE MOVIMIENTOS DE PRODUCCION"
                       FontSize="20" FontWeight="Bold" Foreground="#7E22CE"/>
            <TextBlock x:Name="ResumenText" Margin="0,6,0,0" HorizontalAlignment="Center" Foreground="#475569"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10" Margin="0,0,0,10">
            <WrapPanel>
                <TextBlock x:Name="OtText" FontWeight="SemiBold" Margin="0,0,18,0"/>
                <TextBlock x:Name="OciText" Margin="0,0,18,0"/>
                <TextBlock x:Name="ClienteText" Margin="0,0,18,0"/>
                <TextBlock x:Name="FechaOtText"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10" Margin="0,0,0,12">
            <WrapPanel VerticalAlignment="Center">
                <StackPanel Width="210" Margin="0,0,12,0">
                    <TextBlock Text="Producto" FontWeight="SemiBold"/>
                    <ComboBox x:Name="ProductoCombo" SelectionChanged="Filtro_Changed"/>
                </StackPanel>
                <StackPanel Width="180" Margin="0,0,12,0">
                    <TextBlock Text="Usuario" FontWeight="SemiBold"/>
                    <ComboBox x:Name="UsuarioCombo" SelectionChanged="Filtro_Changed"/>
                </StackPanel>
                <StackPanel Width="180" Margin="0,0,12,0">
                    <TextBlock Text="Tipo de movimiento" FontWeight="SemiBold"/>
                    <ComboBox x:Name="TipoCombo" SelectionChanged="Filtro_Changed"/>
                </StackPanel>
                <StackPanel Width="150" Margin="0,0,12,0">
                    <TextBlock Text="Fecha desde" FontWeight="SemiBold"/>
                    <DatePicker x:Name="FechaDesdePicker" SelectedDateChanged="Fecha_Changed"/>
                </StackPanel>
                <StackPanel Width="150" Margin="0,0,12,0">
                    <TextBlock Text="Fecha hasta" FontWeight="SemiBold"/>
                    <DatePicker x:Name="FechaHastaPicker" SelectedDateChanged="Fecha_Changed"/>
                </StackPanel>
                <Button Content="Limpiar" Width="95" Height="34" Margin="0,16,8,0" Click="Limpiar_Click"/>
                <Button Content="Excel" Width="95" Height="34" Margin="0,16,0,0" Background="#166534" Foreground="White" Click="Exportar_Click"/>
            </WrapPanel>
        </Border>

        <DataGrid x:Name="MovimientosGrid" Grid.Row="3"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  RowHeight="56" MinRowHeight="48">
            <DataGrid.Resources>
                <Style x:Key="TextoWrap" TargetType="TextBlock">
                    <Setter Property="TextWrapping" Value="Wrap"/>
                    <Setter Property="TextTrimming" Value="None"/>
                    <Setter Property="MaxHeight" Value="44"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="4,5"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha/Hora" Binding="{Binding FechaHora, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="145"/>
                <DataGridTextColumn Header="Codigo" Binding="{Binding CodigoProducto}" Width="80"/>
                <DataGridTextColumn Header="Producto" Binding="{Binding NombreProducto}" Width="360" ElementStyle="{StaticResource TextoWrap}"/>
                <DataGridTextColumn Header="Origen" Binding="{Binding Origen}" Width="120"/>
                <DataGridTextColumn Header="Destino" Binding="{Binding Destino}" Width="140"/>
                <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad, StringFormat=N3}" Width="90"/>
                <DataGridTextColumn Header="Accion" Binding="{Binding Accion}" Width="130"/>
                <DataGridTextColumn Header="Usuario" Binding="{Binding Usuario}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="4" Content="Cerrar" Width="100" Height="36"
                HorizontalAlignment="Center" Margin="0,14,0,0" IsCancel="True"/>
    </Grid>
</Window>
