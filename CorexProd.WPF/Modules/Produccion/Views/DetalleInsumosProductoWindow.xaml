<Window x:Class="CorexProd.WPF.Modules.Produccion.Views.DetalleInsumosProductoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle de suministros del producto"
        Height="590" Width="1080" WindowStartupLocation="CenterOwner">
    <Grid x:Name="Contenido" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel>
            <StackPanel>
                <TextBlock x:Name="ProductoText" FontSize="17" FontWeight="Bold"/>
                <TextBlock x:Name="OrdenText" Margin="0,6,0,0"/>
                <TextBlock x:Name="ProduccionText" Margin="0,4,0,0"/>
            </StackPanel>
            <Button DockPanel.Dock="Right" Content="Imprimir" Width="100" Height="34"
                    Click="Imprimir_Click"/>
        </DockPanel>

        <StackPanel Grid.Row="1" Margin="0,14,0,10">
            <TextBlock x:Name="ResultadoText" FontWeight="Bold" FontSize="15"/>
            <TextBlock x:Name="FaltantesText" Margin="0,5,0,0"/>
        </StackPanel>

        <DataGrid x:Name="InsumosGrid" Grid.Row="2" AutoGenerateColumns="False"
                  CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Estado}" Value="Faltante">
                            <Setter Property="Background" Value="#FFF1F2"/>
                            <Setter Property="Foreground" Value="#C81E1E"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Estado}" Value="Completo">
                            <Setter Property="Background" Value="#F0FDF4"/>
                            <Setter Property="Foreground" Value="#15803D"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Código" Binding="{Binding CodigoInsumo}" Width="95"/>
                <DataGridTextColumn Header="Suministro requerido" Binding="{Binding NombreInsumo}" Width="*"/>
                <DataGridTextColumn Header="UM" Binding="{Binding UnidadMedida}" Width="65"/>
                <DataGridTextColumn Header="Cantidad necesaria"
                                    Binding="{Binding CantidadNecesaria, StringFormat=N3}" Width="120"/>
                <DataGridTextColumn Header="Stock actual"
                                    Binding="{Binding StockActual, StringFormat=N3}" Width="100"/>
                <DataGridTextColumn Header="Cantidad faltante"
                                    Binding="{Binding CantidadFaltante, StringFormat=N3}" Width="115"/>
                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="95"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="3" Content="Cerrar" HorizontalAlignment="Right" Width="90"
                Height="34" Margin="0,12,0,0" IsCancel="True"/>
    </Grid>
</Window>
