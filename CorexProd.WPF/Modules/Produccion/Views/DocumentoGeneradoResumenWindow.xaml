<Window x:Class="CorexProd.WPF.Modules.Produccion.Views.DocumentoGeneradoResumenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Documento generado correctamente"
        Width="760"
        Height="460"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC"
        SizeToContent="Manual">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
            <Border Background="#DBEAFE"
                    CornerRadius="22"
                    Width="44"
                    Height="44"
                    Margin="0,0,12,0">
                <TextBlock Text="i"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#2563EB"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TituloText"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#0F172A"/>
                <TextBlock x:Name="SubtituloText"
                           Margin="0,4,0,0"
                           Foreground="#334155"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   x:Name="DetalleText"
                   Text="Productos:"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="8">
            <DataGrid x:Name="ProductosGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="36">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código"
                                        Binding="{Binding Codigo}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Producto"
                                        Binding="{Binding Producto}"
                                        Width="*"/>
                    <DataGridTextColumn Header="Cantidad"
                                        Binding="{Binding Cantidad, StringFormat=N3}"
                                        Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Button Grid.Row="3"
                Content="Aceptar"
                Width="110"
                Height="34"
                HorizontalAlignment="Right"
                Margin="0,14,0,0"
                IsDefault="True"
                Click="Aceptar_Click"/>
    </Grid>
</Window>
