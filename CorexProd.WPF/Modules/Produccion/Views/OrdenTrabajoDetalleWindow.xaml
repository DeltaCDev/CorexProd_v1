<Window x:Class="CorexProd.WPF.Modules.Produccion.Views.OrdenTrabajoDetalleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle de Orden de Trabajo"
        Height="720"
        Width="1200"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#CBD5E1" BorderThickness="1" Padding="14" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="NumeroText" FontWeight="SemiBold"/>
                    <TextBlock x:Name="ClienteText" Margin="0,9,0,0"/>
                </StackPanel>
                <TextBlock x:Name="OciText" Grid.Column="1" FontWeight="SemiBold"/>
                <StackPanel Grid.Column="2">
                    <TextBlock x:Name="OrdenCompraText" FontWeight="SemiBold"/>
                    <TextBlock x:Name="EstadoText" Margin="0,9,0,0" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Productos y Detalles de Produccion">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Productos y Detalles de Produccion" FontSize="17" FontWeight="Bold"/>
                        <TextBlock Text="P: Pendiente | E: Enviado | M: Merma" Foreground="#64748B" Margin="0,4,0,10"/>
                    </StackPanel>
                    <DataGrid x:Name="ResumenGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              FrozenColumnCount="3"
                              MinRowHeight="78"
                              HeadersVisibility="Column"
                              HorizontalScrollBarVisibility="Auto"/>
                </Grid>
            </TabItem>

            <TabItem Header="Operaciones por area" Visibility="Collapsed">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Area:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="AreaCombo" Width="210" DisplayMemberPath="NombreArea" SelectionChanged="AreaCombo_SelectionChanged"/>
                        <Button Content="Iniciar seleccionados" Margin="8,0,0,0" Padding="12,5" Click="Iniciar_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="ItemsGrid" Grid.Row="1" Margin="0,10,0,0" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Sel." Binding="{Binding Seleccionado}" Width="48"/>
                            <DataGridTextColumn Header="Codigo" Binding="{Binding CodigoProducto}" IsReadOnly="True" Width="40"/>
                            <DataGridTextColumn Header="Producto" Binding="{Binding NombreProducto}" IsReadOnly="True" Width="100"/>
                            <DataGridTextColumn Header="Recibido" Binding="{Binding CantidadRecibida,StringFormat=N2}" IsReadOnly="True" Width="85"/>
                            <DataGridTextColumn Header="Enviado" Binding="{Binding CantidadEnviada,StringFormat=N2}" IsReadOnly="True" Width="85"/>
                            <DataGridTextColumn Header="Merma" Binding="{Binding CantidadMerma,StringFormat=N2}" IsReadOnly="True" Width="75"/>
                            <DataGridTextColumn Header="Pendiente" Binding="{Binding CantidadPendiente,StringFormat=N2}" IsReadOnly="True" Width="85"/>
                            <DataGridTextColumn Header="Cantidad" Binding="{Binding CantidadOperacion,UpdateSourceTrigger=PropertyChanged}" Width="85"/>
                            <DataGridTextColumn Header="Modo" Binding="{Binding ModoEnvio}" IsReadOnly="True" Width="75"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" IsReadOnly="True" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Enviar todos" Padding="12,6" Click="EnviarTodos_Click"/>
                        <Button Content="Transferir" Margin="7,0,0,0" Padding="12,6" Click="Transferir_Click"/>
                        <Button Content="Registrar merma" Margin="7,0,0,0" Padding="12,6" Click="Merma_Click"/>
                        <Button Content="Confirmar consumo" Margin="7,0,0,0" Padding="12,6" Click="Consumo_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <Button Grid.Row="2" Content="Cerrar" Width="90" Height="34" HorizontalAlignment="Right" Margin="0,10,0,0" IsCancel="True"/>
    </Grid>
</Window>
