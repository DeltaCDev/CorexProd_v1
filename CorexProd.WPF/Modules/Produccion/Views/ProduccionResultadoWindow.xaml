<Window x:Class="CorexProd.WPF.Modules.Produccion.Views.ProduccionResultadoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resultado de Produccion"
        Height="430" Width="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Background="White" Padding="28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TituloText" FontSize="21" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock x:Name="MensajeText" Grid.Row="1" Margin="0,18,0,14"
                       FontSize="14" TextWrapping="Wrap"/>
            <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                    CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock x:Name="OrigenText" Margin="0,0,0,8"/>
                    <TextBlock x:Name="DestinoText" Margin="0,0,0,8"/>
                    <TextBlock x:Name="CantidadText" Margin="0,0,0,8"/>
                    <TextBlock x:Name="SaldoText" Margin="0,0,0,8"/>
                    <TextBlock x:Name="EstadoText" FontWeight="SemiBold" Foreground="#16A34A"/>
                </StackPanel>
            </Border>
            <Button Grid.Row="3" Content="Aceptar" Width="120" Height="36"
                    HorizontalAlignment="Right" Margin="0,16,0,0"
                    IsDefault="True" Click="Aceptar_Click"/>
        </Grid>
    </Border>
</Window>
