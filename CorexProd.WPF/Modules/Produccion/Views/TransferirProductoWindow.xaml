<Window x:Class="CorexProd.WPF.Modules.Produccion.Views.TransferirProductoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transferir producto"
        Height="650"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TituloText" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,12"/>
        <StackPanel Grid.Row="1">
            <TextBlock Text="Producto:" FontWeight="SemiBold"/>
            <TextBlock x:Name="ProductoText" TextWrapping="Wrap" Margin="0,3,0,10"/>
        </StackPanel>
        <TextBlock x:Name="StockText" Grid.Row="2" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <StackPanel x:Name="CantidadOperacionPanel" Grid.Row="3">
            <TextBlock x:Name="CantidadLabel" Text="Cantidad a transferir:" FontWeight="SemiBold"/>
            <Border x:Name="AjusteInicioInfo"
                    Visibility="Collapsed"
                    Background="#FEF3C7"
                    BorderBrush="#F59E0B"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10"
                    Margin="0,4,0,8">
                <StackPanel>
                    <TextBlock Text="Es área de inicio"
                               Foreground="#92400E"
                               FontWeight="Bold"/>
                    <TextBlock Text="Se puede enviar más de la cantidad requerida si producción necesita aprovechar material disponible."
                               Foreground="#92400E"
                               TextWrapping="Wrap"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
            <TextBox x:Name="CantidadTextBox" Height="34" Margin="0,4,0,10" Padding="7" VerticalContentAlignment="Center"/>
        </StackPanel>

        <CheckBox x:Name="RegistrarMermaCheckBox"
                  Grid.Row="4"
                  Content="Registrar merma"
                  FontWeight="SemiBold"
                  Margin="0,2,0,9"
                  Visibility="Collapsed"
                  Checked="RegistrarMerma_Changed"
                  Unchecked="RegistrarMerma_Changed"/>

        <StackPanel x:Name="MermaPanel" Grid.Row="5" Visibility="Collapsed">
            <TextBlock Text="Cantidad de merma:" FontWeight="SemiBold"/>
            <TextBox x:Name="CantidadMermaTextBox" Height="34" Margin="0,4,0,9" Padding="7" VerticalContentAlignment="Center"/>
            <TextBlock Text="Observacion de merma:" FontWeight="SemiBold"/>
            <TextBox x:Name="ObservacionMermaTextBox" Height="52" Margin="0,4,0,10" Padding="7" TextWrapping="Wrap" AcceptsReturn="True" MaxLength="500"/>
        </StackPanel>

        <StackPanel Grid.Row="6">
            <TextBlock Text="Clave de usuario:" FontWeight="SemiBold"/>
            <PasswordBox x:Name="ClavePasswordBox" Height="34" Margin="0,4,0,0" Padding="7"/>
        </StackPanel>
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,4">
            <Button x:Name="ConfirmarButton" Content="Confirmar" Width="140" Height="40" Margin="0,0,12,0" IsDefault="True" Click="Confirmar_Click"/>
            <Button Content="Cancelar" Width="120" Height="40" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
