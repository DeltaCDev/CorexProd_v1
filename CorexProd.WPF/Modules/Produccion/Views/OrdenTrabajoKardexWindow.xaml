<Window x:Class="CorexProd.WPF.Modules.Produccion.Views.OrdenTrabajoKardexWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KARDEX - INGRESO AL INVENTARIO"
        Height="540" Width="1220" MinWidth="1120"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🧾  KARDEX - INGRESO AL INVENTARIO"
                   FontSize="22" FontWeight="Bold" Foreground="#43A047"
                   HorizontalAlignment="Center" Margin="0,0,0,16"/>

        <Border Grid.Row="1" Background="#E8F5E9" CornerRadius="8" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="OtText" FontWeight="SemiBold"/>
                    <TextBlock x:Name="FechaOtText" Margin="0,8,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="FechaGeneracionText" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TotalText" Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="IngresosGrid" Grid.Row="2"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  MinRowHeight="42" GridLinesVisibility="Horizontal">
            <DataGrid.Resources>
                <Style x:Key="TextoWrap" TargetType="TextBlock">
                    <Setter Property="TextWrapping" Value="Wrap"/>
                    <Setter Property="TextTrimming" Value="None"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="4,5"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Codigo" Binding="{Binding CodigoProducto}" Width="95"/>
                <DataGridTextColumn Header="Producto" Binding="{Binding NombreProducto}" Width="*" ElementStyle="{StaticResource TextoWrap}"/>
                <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad, StringFormat=N3}" Width="95"/>
                <DataGridTextColumn Header="Almacen" Binding="{Binding Almacen}" Width="170"/>
                <DataGridTextColumn Header="Fecha y Hora Movimiento" Binding="{Binding FechaMovimiento, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="175"/>
                <DataGridTextColumn Header="Usuario" Binding="{Binding Usuario}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="3" Content="✓ CERRAR" Width="150" Height="40"
                HorizontalAlignment="Center" Margin="0,16,0,0"
                Background="#4CAF50" Foreground="White" FontWeight="Bold"
                IsCancel="True"/>
    </Grid>
</Window>
