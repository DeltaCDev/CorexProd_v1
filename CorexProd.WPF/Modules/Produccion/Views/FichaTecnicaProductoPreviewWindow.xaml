<Window x:Class="CorexProd.WPF.Modules.Produccion.Views.FichaTecnicaProductoPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Ficha técnica del producto"
        Height="760"
        Width="1150"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Código" Foreground="#64748B"/>
                    <TextBlock x:Name="CodigoText"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="18,0,18,0">
                    <TextBlock Text="Producto" Foreground="#64748B"/>
                    <TextBlock x:Name="ProductoText"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="2"
                        x:Name="EstadoBorder"
                        Background="#DCFCE7"
                        CornerRadius="16"
                        Padding="14,6"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="EstadoText"
                               Text="Ficha técnica disponible"
                               Foreground="#15803D"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#EFF6FF"
                BorderBrush="#BFDBFE"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Observaciones del producto"
                           Foreground="#1E3A8A"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <TextBlock x:Name="ObservacionText"
                           TextWrapping="Wrap"
                           Foreground="#0F172A"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <wv2:WebView2 x:Name="PdfWebView"
                              Margin="8"/>

                <TextBlock x:Name="SinFichaText"
                           Text="Ficha técnica no existe."
                           Visibility="Collapsed"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#B91C1C"/>
            </Grid>
        </Border>

        <Button Grid.Row="3"
                Content="Cerrar"
                Width="110"
                Height="36"
                HorizontalAlignment="Right"
                Margin="0,12,0,0"
                IsCancel="True"/>
    </Grid>
</Window>
