<Window x:Class="CorexProd.WPF.Modules.Produccion.Views.OrdenTrabajoCrearWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generar Orden de Trabajo"
        Height="660" Width="1340" MinHeight="540" MinWidth="1120"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="BotonAccion" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Foreground" Value="#0284C7"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#38BDF8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="EstadoTexto" TargetType="TextBlock">
            <Setter Property="Text" Value="{Binding EstadoInsumos}"/>
            <Setter Property="Foreground" Value="#15803D"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding EstadoInsumos}" Value="Faltantes">
                    <Setter Property="Foreground" Value="#DC2626"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EstadoInsumos}" Value="Sin ficha tecnica">
                    <Setter Property="Foreground" Value="#D97706"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DeficitTexto" TargetType="TextBlock">
            <Setter Property="Text" Value="{Binding Deficit, StringFormat=N3}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Deficit}" Value="0">
                    <Setter Property="Foreground" Value="#15803D"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EstadoInsumos}" Value="Faltantes">
                    <Setter Property="Foreground" Value="#DC2626"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Generar orden de trabajo" FontSize="22" FontWeight="Bold"/>
                <TextBlock x:Name="CabeceraText" Margin="0,5,0,0" Foreground="#475569"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Orden de compra del cliente:" FontSize="15"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Border BorderBrush="#CBD5E1" BorderThickness="1" Padding="12,8">
                    <TextBlock x:Name="OrdenCompraText"/>
                </Border>
            </StackPanel>
        </Grid>

        <DataGrid x:Name="DetallesGrid" Grid.Row="1" AutoGenerateColumns="False"
                  CanUserAddRows="False" IsReadOnly="True" RowHeight="54"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Código" Binding="{Binding CodigoProducto}" Width="80"/>
                <DataGridTemplateColumn Header="Producto" Width="*" MinWidth="520">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NombreProducto}"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       MaxHeight="38"
                                       VerticalAlignment="Center"
                                       ToolTip="{Binding NombreProducto}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Acciones" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="👁" ToolTip="Ver observaciones"
                                        Style="{StaticResource BotonAccion}"
                                        Click="Observacion_Click"/>
                                <Button Content="🖨" ToolTip="Imprimir ficha técnica"
                                        Style="{StaticResource BotonAccion}"
                                        Click="ImprimirFicha_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Binding="{Binding CantidadRequerida, StringFormat=N3}" Width="85">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="Cantidad&#x0a;Requerida" TextAlignment="Center"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding StockTotal, StringFormat=N3}" Width="75">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="Stock&#x0a;Actual" TextAlignment="Center"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Déficit" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource DeficitTexto}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="120">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="Estado de&#x0a;insumos" TextAlignment="Center"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource EstadoTexto}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="100">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="Detalle de&#x0a;Insumos" TextAlignment="Center"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="👁  Ver" ToolTip="Ver insumos requeridos"
                                    Padding="8,4" Foreground="#0284C7"
                                    Click="VerDetalle_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="Observación general de la OT (opcional)"
                       Foreground="#475569" Margin="0,0,0,5"/>
            <TextBox x:Name="ObservacionText" Height="52" Padding="8"
                     AcceptsReturn="True" TextWrapping="Wrap" MaxLength="500"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,14,0,0">
            <Button x:Name="GuardarButton" Content="Guardar" Width="105" Height="36"
                    Margin="0,0,10,0" IsDefault="True" Background="#16A34A"
                    Foreground="White" BorderBrush="#16A34A" Click="Crear_Click"/>
            <Button Content="Cancelar" Width="105" Height="36" IsCancel="True"
                    Background="#EF4444" Foreground="White" BorderBrush="#EF4444"/>
        </StackPanel>
    </Grid>
</Window>
