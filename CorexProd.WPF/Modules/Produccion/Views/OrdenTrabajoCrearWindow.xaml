<Window x:Class="CorexProd.WPF.Modules.Produccion.Views.OrdenTrabajoCrearWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Generar Orden de Trabajo" Height="620" Width="1220" WindowStartupLocation="CenterOwner">
 <Grid Margin="18"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Generar Orden de Trabajo" FontSize="21" FontWeight="Bold"/><TextBlock x:Name="CabeceraText" Margin="0,6,0,12" Foreground="#475569"/></StackPanel><TextBlock x:Name="OrdenCompraText" Grid.Column="1" FontSize="15" FontWeight="SemiBold"/></Grid>
  <DataGrid x:Name="DetallesGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"><DataGrid.Columns><DataGridTextColumn Header="Código - Descripción del producto" Binding="{Binding Producto}" Width="*"/><DataGridTextColumn Header="Observaciones" Binding="{Binding Observacion}" Width="110"/><DataGridTextColumn Header="Ficha" Binding="{Binding IdFichaTecnica}" Width="60"/><DataGridTextColumn Header="Cantidad requerida" Binding="{Binding CantidadRequerida,StringFormat=N3}" Width="100"/><DataGridTextColumn Header="Stock Almacén" Binding="{Binding StockAlmacen,StringFormat=N3}" Width="85"/><DataGridTextColumn Header="Stock Corte" Binding="{Binding StockCorte,StringFormat=N3}" Width="80"/><DataGridTextColumn Header="Stock Confección" Binding="{Binding StockConfeccion,StringFormat=N3}" Width="95"/><DataGridTextColumn Header="Stock Acabado" Binding="{Binding StockAcabado,StringFormat=N3}" Width="90"/><DataGridTextColumn Header="Stock Total" Binding="{Binding StockTotal,StringFormat=N3}" Width="80"/><DataGridTextColumn Header="Déficit" Binding="{Binding Deficit,StringFormat=N3}" Width="80"/><DataGridTextColumn Header="Estado insumos" Binding="{Binding EstadoInsumos}" Width="100"/><DataGridTemplateColumn Header="Ver detalle" Width="90"><DataGridTemplateColumn.CellTemplate><DataTemplate><Button Content="Ver" Padding="10,4" Click="VerDetalle_Click"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn></DataGrid.Columns></DataGrid>
  <TextBox x:Name="ObservacionText" Grid.Row="2" Height="52" Margin="0,12,0,0" Padding="8" AcceptsReturn="True" ToolTip="Observación general de la OT"/>
  <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0"><Button Content="Guardar" Width="105" Height="36" Margin="0,0,10,0" IsDefault="True" Click="Crear_Click"/><Button Content="Cancelar" Width="105" Height="36" IsCancel="True"/></StackPanel>
 </Grid>
</Window>
