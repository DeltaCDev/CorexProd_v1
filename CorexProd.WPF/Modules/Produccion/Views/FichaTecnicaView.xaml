<UserControl x:Class="CorexProd.WPF.Modules.Produccion.Views.FichaTecnicaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CorexProd.WPF.Modules.Produccion.ViewModels">

    <UserControl.DataContext>
        <vm:FichaTecnicaViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITULO -->
        <TextBlock Text="Ficha Técnica de Producción"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- LISTA DE FICHAS -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding FichasTecnicas}"
                  SelectedItem="{Binding FichaSeleccionada}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="0,0,0,15">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding IdFichaTecnica}"
                                    Width="60"/>

                <DataGridTextColumn Header="Código"
                                    Binding="{Binding CodigoProducto}"
                                    Width="120"/>

                <DataGridTextColumn Header="Producto"
                                    Binding="{Binding NombreProducto}"
                                    Width="*"/>

                <DataGridTextColumn Header="Versión"
                                    Binding="{Binding Version}"
                                    Width="80"/>

                <DataGridCheckBoxColumn Header="Activo"
                                        Binding="{Binding Estado}"
                                        Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- CABECERA -->
        <Border Grid.Row="2"
                Padding="15"
                Margin="0,0,0,15"
                BorderBrush="#DDD"
                BorderThickness="1"
                CornerRadius="8">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Producto"/>
                    <ComboBox ItemsSource="{Binding Productos}"
                              SelectedItem="{Binding ProductoSeleccionado}"
                              DisplayMemberPath="NombreProducto"
                              Height="32"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Versión"/>
                    <TextBox Text="{Binding Version}"
                             Height="32"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Observación"/>
                    <TextBox Text="{Binding Observacion}"
                             Height="32"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Text="Estado"/>
                    <CheckBox Content="Activo"
                              IsChecked="{Binding Estado}"
                              Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom">
                    <Button Content="Nuevo"
                            Width="90"
                            Height="32"
                            Margin="0,0,8,0"
                            Command="{Binding NuevoCommand}"/>

                    <Button Content="Guardar"
                            Width="100"
                            Height="32"
                            Command="{Binding GuardarCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DETALLE -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- FORMULARIO DETALLE -->
            <Border Padding="15"
                    Margin="0,0,0,15"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="8">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Insumo"/>
                        <ComboBox ItemsSource="{Binding Insumos}"
                                  SelectedItem="{Binding InsumoSeleccionado}"
                                  DisplayMemberPath="NombreInsumo"
                                  Height="32"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Cantidad"/>
                        <TextBox Text="{Binding Cantidad}"
                                 Height="32"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="Unidad"/>
                        <ComboBox ItemsSource="{Binding UnidadesMedida}"
                                  SelectedItem="{Binding UnidadSeleccionada}"
                                  DisplayMemberPath="Abreviatura"
                                  Height="32"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Bottom">

                        <Button Content="Agregar"
                                Width="90"
                                Height="32"
                                Margin="0,0,8,0"
                                Command="{Binding AgregarDetalleCommand}"/>

                        <Button Content="Editar"
                                Width="90"
                                Height="32"
                                Margin="0,0,8,0"
                                Command="{Binding EditarDetalleCommand}"/>

                        <Button Content="Quitar"
                                Width="90"
                                Height="32"
                                Command="{Binding QuitarDetalleCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- GRID DETALLE -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Detalles}"
                      SelectedItem="{Binding DetalleSeleccionado}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding IdFichaTecnicaDetalle}"
                                        Width="60"/>

                    <DataGridTextColumn Header="Insumo"
                                        Binding="{Binding NombreInsumo}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Cantidad"
                                        Binding="{Binding Cantidad}"
                                        Width="120"/>

                    <DataGridTextColumn Header="U.M"
                                        Binding="{Binding Abreviatura}"
                                        Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>