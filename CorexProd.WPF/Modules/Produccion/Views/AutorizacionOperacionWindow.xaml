<Window x:Class="CorexProd.WPF.Modules.Produccion.Views.AutorizacionOperacionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Autorizar operacion"
        Height="380"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Ingrese las credenciales del usuario autorizador"
                   FontWeight="SemiBold"
                   FontSize="16"
                   Margin="0,0,0,18"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Usuario autorizador" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
            <TextBox x:Name="UsuarioTextBox" Height="40" Padding="9" VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Contrasena" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
            <PasswordBox x:Name="ClavePasswordBox" Height="40" Padding="9" VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="3">
            <TextBlock Text="Observacion general (opcional)" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
            <TextBox x:Name="ObservacionTextBox" Height="70" Padding="9" AcceptsReturn="True" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button Content="Cancelar" Width="96" Height="36" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Autorizar" Width="108" Height="36" IsDefault="True" Click="Autorizar_Click"/>
        </StackPanel>
    </Grid>
</Window>
