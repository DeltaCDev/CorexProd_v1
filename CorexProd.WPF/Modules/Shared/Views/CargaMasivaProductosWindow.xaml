<Window x:Class="CorexProd.WPF.Modules.Shared.Views.CargaMasivaProductosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Carga masiva"
        Width="820"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{Binding Titulo}" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
            <TextBlock Text="Pegue dos columnas: codigo del producto y cantidad. Puede usar tabulacion de Excel o espacios."
                       Foreground="#6B7280"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <TextBox Grid.Row="1"
                 Text="{Binding TextoCarga, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="13"
                 Padding="10"/>

        <DockPanel Grid.Row="2" Margin="0,12,0,10">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Procesar"
                        Width="105"
                        Height="32"
                        Margin="0,0,8,0"
                        Command="{Binding ProcesarCommand}"/>
                <Button Content="Limpiar"
                        Width="90"
                        Height="32"
                        Command="{Binding LimpiarCommand}"/>
            </StackPanel>

            <TextBlock Text="{Binding Resumen}"
                       VerticalAlignment="Center"
                       Foreground="#374151"
                       FontWeight="SemiBold"/>
        </DockPanel>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Filas}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  RowHeight="34"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Agregar"
                                        Binding="{Binding Seleccionado, UpdateSourceTrigger=PropertyChanged}"
                                        Width="70"/>
                <DataGridTextColumn Header="Linea"
                                    Binding="{Binding NumeroLinea}"
                                    IsReadOnly="True"
                                    Width="60"/>
                <DataGridTextColumn Header="Codigo"
                                    Binding="{Binding Codigo}"
                                    IsReadOnly="True"
                                    Width="120"/>
                <DataGridTextColumn Header="Producto"
                                    Binding="{Binding NombreProducto}"
                                    IsReadOnly="True"
                                    Width="*"/>
                <DataGridTextColumn Header="Cantidad"
                                    Binding="{Binding Cantidad, StringFormat=N2}"
                                    IsReadOnly="True"
                                    Width="95"/>
                <DataGridTextColumn Header="Estado"
                                    Binding="{Binding Estado}"
                                    IsReadOnly="True"
                                    Width="85"/>
                <DataGridTextColumn Header="Validacion"
                                    Binding="{Binding Mensaje}"
                                    IsReadOnly="True"
                                    Width="230"/>
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="4" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Content="Agregar productos"
                        Width="140"
                        Height="34"
                        Margin="0,0,8,0"
                        Command="{Binding AgregarCommand}"/>
                <Button Content="Cancelar"
                        Width="100"
                        Height="34"
                        Command="{Binding CancelarCommand}"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
