<UserControl x:Class="CorexProd.WPF.Views.CategoriasInsumoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F6FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Categorías de Insumos"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,20">

            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Nombre"/>
                        <TextBox Text="{Binding NombreCategoria, UpdateSourceTrigger=PropertyChanged}"
                                 Height="35"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="Descripción"/>
                        <TextBox Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"
                                 Height="35"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Bottom"
                                Orientation="Horizontal">
                        <Button Content="Nuevo" Width="90" Height="35" Margin="0,0,8,0"
                                Command="{Binding NuevoCommand}"/>
                        <Button Content="Guardar" Width="90" Height="35" Margin="0,0,8,0"
                                Command="{Binding GuardarCommand}"/>
                        <Button Content="Editar" Width="90" Height="35" Margin="0,0,8,0"
                                Command="{Binding EditarCommand}"/>
                        <Button Content="Eliminar" Width="90" Height="35"
                                Command="{Binding EliminarCommand}"/>
                    </StackPanel>
                </Grid>

                <CheckBox Content="Activo"
                          IsChecked="{Binding Estado}"
                          Margin="0,15,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="10"
                Padding="15">

            <DataGrid ItemsSource="{Binding Categorias}"
                      SelectedItem="{Binding CategoriaSeleccionada}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding IdCategoriaInsumo}"
                                        Width="80"/>

                    <DataGridTextColumn Header="Categoría"
                                        Binding="{Binding NombreCategoria}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Descripción"
                                        Binding="{Binding Descripcion}"
                                        Width="2*"/>

                    <DataGridCheckBoxColumn Header="Activo"
                                            Binding="{Binding Estado}"
                                            Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>