<Window x:Class="CorexProd.WPF.Modules.Almacen.Views.IngresoManualStockInsumoDetalleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle del Ingreso Manual de Stock de Insumos"
        Width="980"
        Height="680"
        WindowStartupLocation="CenterOwner"
        Background="#F3F4F6">

    <Window.Resources>
        <Style x:Key="EtiquetaDato" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="ValorDato" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="{Binding NumeroDocumento, StringFormat=Ingreso {0}}" FontSize="24" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
            <Border DockPanel.Dock="Right" Background="#FEF3C7" CornerRadius="12" Padding="12,5">
                <TextBlock Text="{Binding Estado}" FontWeight="SemiBold" Foreground="#92400E"/>
            </Border>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="1.1*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,14,14">
                            <TextBlock Text="ID" Style="{StaticResource EtiquetaDato}"/>
                            <TextBlock Text="{Binding IdIngresoManualStockInsumo}" Style="{StaticResource ValorDato}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,14,14">
                            <TextBlock Text="FECHA EMISION" Style="{StaticResource EtiquetaDato}"/>
                            <TextBlock Text="{Binding FechaEmision, StringFormat=dd/MM/yyyy}" Style="{StaticResource ValorDato}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,14,14">
                            <TextBlock Text="TIPO DOCUMENTO" Style="{StaticResource EtiquetaDato}"/>
                            <TextBlock Text="{Binding NombreTipoDocumento}" Style="{StaticResource ValorDato}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,14">
                            <TextBlock Text="TOTAL" Style="{StaticResource EtiquetaDato}"/>
                            <TextBlock Text="{Binding Total, StringFormat=S/ {0:N2}}" Style="{StaticResource ValorDato}" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,14,14">
                            <TextBlock Text="PROVEEDOR" Style="{StaticResource EtiquetaDato}"/>
                            <TextBlock Text="{Binding NombreProveedor}" Style="{StaticResource ValorDato}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,14,14">
                            <TextBlock Text="SERIE" Style="{StaticResource EtiquetaDato}"/>
                            <TextBlock Text="{Binding Serie}" Style="{StaticResource ValorDato}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,0,14">
                            <TextBlock Text="NUMERO" Style="{StaticResource EtiquetaDato}"/>
                            <TextBlock Text="{Binding Numero}" Style="{StaticResource ValorDato}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,14,0">
                            <TextBlock Text="ALMACEN" Style="{StaticResource EtiquetaDato}"/>
                            <TextBlock Text="{Binding NombreAlmacen}" Style="{StaticResource ValorDato}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2">
                            <TextBlock Text="OBSERVACION" Style="{StaticResource EtiquetaDato}"/>
                            <TextBlock Text="{Binding Observacion}" Style="{StaticResource ValorDato}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Insumos" FontSize="16" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding Detalles}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" MinHeight="260">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Codigo" Binding="{Binding CodigoInsumo}" Width="90"/>
                                <DataGridTextColumn Header="Insumo" Binding="{Binding NombreInsumo}" Width="360"/>
                                <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad, StringFormat=N2}" Width="90"/>
                                <DataGridTextColumn Header="Unidad" Binding="{Binding NombreUnidad}" Width="100"/>
                                <DataGridTextColumn Header="P. Unitario" Binding="{Binding PrecioUnitario, StringFormat=N2}" Width="90"/>
                                <DataGridTextColumn Header="Descuento" Binding="{Binding Descuento, StringFormat=N2}" Width="90"/>
                                <DataGridTextColumn Header="Importe" Binding="{Binding Importe, StringFormat=S/ {0:N2}}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <TextBlock Text="{Binding Subtotal, StringFormat=Subtotal: S/ {0:N2}}" VerticalAlignment="Center" Margin="0,0,18,0"/>
            <TextBlock Text="{Binding DescuentoTotal, StringFormat=Descuento: S/ {0:N2}}" VerticalAlignment="Center" Margin="0,0,18,0"/>
            <TextBlock Text="{Binding Total, StringFormat=Total: S/ {0:N2}}" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,18,0"/>
            <Button Content="Aceptar" Width="100" Height="32" Click="Cerrar_Click"/>
        </StackPanel>
    </Grid>
</Window>



