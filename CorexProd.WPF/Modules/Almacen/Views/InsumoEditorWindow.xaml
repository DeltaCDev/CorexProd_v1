<Window x:Class="CorexProd.WPF.Views.InsumoEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding TituloEditor}"
        Width="680"
        Height="500"
        MinHeight="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F3F4F6">

    <Window.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BotonBase" TargetType="Button">
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ButtonBorder" Property="Background" Value="#E2E8F0"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="ButtonBorder" Property="Background" Value="#CBD5E1"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BotonPrimario" TargetType="Button" BasedOn="{StaticResource BotonBase}">
            <Setter Property="Background" Value="#F97316"/>
            <Setter Property="BorderBrush" Value="#F97316"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EA580C"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#EA580C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#C2410C"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#C2410C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding TituloEditor}" FontSize="22" FontWeight="Bold" Foreground="#F97316" Margin="0,0,0,14"/>

        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16">
            <StackPanel>
                <TextBlock Margin="0,0,0,16" FontSize="13" Foreground="#64748B">
                    <Run Text="Complete la informacion del insumo. Los campos marcados con "/>
                    <Run Text="*" Foreground="#DC2626" FontWeight="Bold"/>
                    <Run Text=" son obligatorios."/>
                </TextBlock>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                        <TextBlock Style="{StaticResource LabelCampo}"><Run Text="Codigo "/><Run Text="*" Foreground="#DC2626"/></TextBlock>
                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Codigo, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource LabelCampo}"><Run Text="Nombre "/><Run Text="*" Foreground="#DC2626"/></TextBlock>
                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding NombreInsumo, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                        <TextBlock Style="{StaticResource LabelCampo}"><Run Text="Categoria "/><Run Text="*" Foreground="#DC2626"/></TextBlock>
                        <ComboBox Style="{StaticResource CampoCombo}" ItemsSource="{Binding Categorias}" SelectedValue="{Binding IdCategoriaInsumo}" SelectedValuePath="IdCategoriaInsumo" DisplayMemberPath="NombreCategoria"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource LabelCampo}"><Run Text="Unidad de Medida "/><Run Text="*" Foreground="#DC2626"/></TextBlock>
                        <ComboBox Style="{StaticResource CampoCombo}" ItemsSource="{Binding UnidadesMedida}" SelectedValue="{Binding IdUnidadMedida}" SelectedValuePath="IdUnidadMedida" DisplayMemberPath="NombreUnidad"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                        <TextBlock Text="Stock minimo" Style="{StaticResource LabelCampo}"/>
                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding StockMinimo, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" Content="Activo" IsChecked="{Binding Estado}" FontSize="13" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                </Grid>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Guardar" Style="{StaticResource BotonPrimario}" Command="{Binding GuardarCommand}" Margin="0,0,8,0"/>
            <Button Content="Limpiar" Style="{StaticResource BotonBase}" Command="{Binding LimpiarCommand}" Margin="0,0,8,0"/>
            <Button Content="Cerrar" Style="{StaticResource BotonBase}" Command="{Binding CerrarCommand}"/>
        </StackPanel>
    </Grid>
</Window>
