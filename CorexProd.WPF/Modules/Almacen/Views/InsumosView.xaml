<UserControl x:Class="CorexProd.WPF.Views.InsumosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F6FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Insumos"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,20">

            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.3*"/>
                        <ColumnDefinition Width="1.3*"/>
                        <ColumnDefinition Width="0.9*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Código"/>
                        <TextBox Text="{Binding Codigo, UpdateSourceTrigger=PropertyChanged}"
                                 Height="35"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="Nombre"/>
                        <TextBox Text="{Binding NombreInsumo, UpdateSourceTrigger=PropertyChanged}"
                                 Height="35"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,15,0">
                        <TextBlock Text="Categoría"/>
                        <ComboBox ItemsSource="{Binding Categorias}"
                                  SelectedValue="{Binding IdCategoriaInsumo}"
                                  SelectedValuePath="IdCategoriaInsumo"
                                  DisplayMemberPath="NombreCategoria"
                                  Height="35"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,15,0">
                        <TextBlock Text="Unidad de Medida"/>
                        <ComboBox ItemsSource="{Binding UnidadesMedida}"
                                  SelectedValue="{Binding IdUnidadMedida}"
                                  SelectedValuePath="IdUnidadMedida"
                                  DisplayMemberPath="NombreUnidad"
                                  Height="35"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Margin="0,0,15,0">
                        <TextBlock Text="Stock mínimo"/>
                        <TextBox Text="{Binding StockMinimo, UpdateSourceTrigger=PropertyChanged}"
                                 Height="35"/>
                    </StackPanel>

                    <StackPanel Grid.Column="5"
                                VerticalAlignment="Bottom"
                                Orientation="Horizontal">

                        <Button Content="Nuevo"
                                Width="90"
                                Height="35"
                                Margin="0,0,8,0"
                                Command="{Binding NuevoCommand}"/>

                        <Button Content="Guardar"
                                Width="90"
                                Height="35"
                                Margin="0,0,8,0"
                                Command="{Binding GuardarCommand}"/>

                        <Button Content="Editar"
                                Width="90"
                                Height="35"
                                Margin="0,0,8,0"
                                Command="{Binding EditarCommand}"/>

                        <Button Content="Eliminar"
                                Width="90"
                                Height="35"
                                Command="{Binding EliminarCommand}"/>
                    </StackPanel>
                </Grid>

                <CheckBox Content="Activo"
                          IsChecked="{Binding Estado}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="10"
                Padding="15">

            <DataGrid ItemsSource="{Binding Insumos}"
                      SelectedItem="{Binding InsumoSeleccionado}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding IdInsumo}"
                                        Width="60"/>

                    <DataGridTextColumn Header="Código"
                                        Binding="{Binding Codigo}"
                                        Width="90"/>

                    <DataGridTextColumn Header="Insumo"
                                        Binding="{Binding NombreInsumo}"
                                        Width="400"/>

                    <DataGridTextColumn Header="Categoría"
                                        Binding="{Binding NombreCategoria}"
                                        Width="100"/>

                    <DataGridTextColumn Header="Unidad"
                                        Binding="{Binding NombreUnidad}"
                                        Width="80"/>

                    <DataGridTextColumn Header="Abrev."
                                        Binding="{Binding Abreviatura}"
                                        Width="80"/>

                    <DataGridTextColumn Header="Stock mínimo"
                                        Binding="{Binding StockMinimo}"
                                        Width="100"/>

                    <DataGridCheckBoxColumn Header="Activo"
                                            Binding="{Binding Estado}"
                                            Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
