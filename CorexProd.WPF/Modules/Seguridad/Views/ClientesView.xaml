<UserControl x:Class="CorexProd.WPF.Modules.Seguridad.Views.ClientesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="18"
                Margin="0,0,0,14">

            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Gestión de Clientes"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Listado de clientes registrados"
                               FontSize="14"
                               Foreground="#6B7280"/>
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Content="Nuevo"
                        Width="110"
                        Height="32"
                        HorizontalAlignment="Right"
                        Command="{Binding NuevoCommand}"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="18"
                Margin="0,0,0,14"
                Visibility="{Binding FormularioVisibility}">

            <StackPanel>
                <TextBlock Text="{Binding TituloFormulario}"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,14"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.3*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Documento "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>
                        <ComboBox Style="{StaticResource CampoCombo}"
                                  SelectedValuePath="Content"
                                  SelectedValue="{Binding TipoDocumento}">
                            <ComboBoxItem Content="DNI"/>
                            <ComboBoxItem Content="RUC"/>
                            <ComboBoxItem Content="CARNET EXTRANJERIA"/>
                            <ComboBoxItem Content="PASAPORTE"/>
                            <ComboBoxItem Content="S/N"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Nro Documento "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Content="Consultar"
                                    Width="82"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Command="{Binding ConsultarDocumentoCommand}"/>
                            <TextBox Style="{StaticResource CampoTexto}"
                                     Text="{Binding NumeroDocumento, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Nombre o Razón Social "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>
                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding NombreRazonSocial, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,14">
                        <TextBlock Text="Teléfono" Style="{StaticResource LabelCampo}"/>
                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding Telefono, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,20,14">
                        <TextBlock Text="Dirección" Style="{StaticResource LabelCampo}"/>
                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding Direccion, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,20,14">
                        <TextBlock Text="Correo" Style="{StaticResource LabelCampo}"/>
                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding Correo, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,0,14">
                        <TextBlock Text="Estado" Style="{StaticResource LabelCampo}"/>
                        <CheckBox Content="Activo"
                                  IsChecked="{Binding Estado}"
                                  FontSize="14"
                                  VerticalAlignment="Center"
                                  Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Grid.Column="2"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <Button Content="Guardar"
                                Width="110"
                                Height="32"
                                Margin="0,0,10,0"
                                Command="{Binding GuardarCommand}"/>

                        <Button Content="Cancelar"
                                Width="110"
                                Height="32"
                                Command="{Binding CancelarCommand}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="0">

            <DataGrid ItemsSource="{Binding Clientes}"
                      SelectedItem="{Binding ClienteSeleccionado}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      RowHeight="44"
                      GridLinesVisibility="Horizontal">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdCliente}" Width="70"/>
                    <DataGridTextColumn Header="Documento" Binding="{Binding TipoDocumento}" Width="150"/>
                    <DataGridTextColumn Header="Nro Documento" Binding="{Binding NumeroDocumento}" Width="150"/>
                    <DataGridTextColumn Header="Nombre / Razón Social" Binding="{Binding NombreRazonSocial}" Width="*"/>
                    <DataGridTextColumn Header="Dirección" Binding="{Binding Direccion}" Width="220"/>
                    <DataGridTextColumn Header="Teléfono" Binding="{Binding Telefono}" Width="130"/>
                    <DataGridTextColumn Header="Correo" Binding="{Binding Correo}" Width="190"/>
                    <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Estado}" Width="80"/>

                    <DataGridTemplateColumn Header="Acciones" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Editar"
                                            Margin="0,0,8,0"
                                            Command="{Binding DataContext.EditarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Eliminar"
                                            Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding IdCliente}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
