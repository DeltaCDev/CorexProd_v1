<UserControl x:Class="CorexProd.WPF.Modules.Seguridad.Views.SeriesCorrelativosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="Boton" TargetType="Button"><Setter Property="Height" Value="36"/><Setter Property="MinWidth" Value="100"/><Setter Property="Padding" Value="14,0"/><Setter Property="Margin" Value="6,0,0,0"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/></Style>
        <Style x:Key="Etiqueta" TargetType="TextBlock"><Setter Property="Foreground" Value="#475569"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="12"/><Setter Property="Margin" Value="0,0,0,5"/></Style>
        <Style x:Key="Campo" TargetType="Control"><Setter Property="Height" Value="34"/><Setter Property="Margin" Value="0,0,0,12"/></Style>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="Series y Correlativos" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/><TextBlock Text="Administra la numeración automática de los documentos del sistema" Foreground="#64748B" Margin="0,4,0,0"/></StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox Width="250" Height="36" ItemsSource="{Binding Tipos}" DisplayMemberPath="NombreTipoDocumento" SelectedItem="{Binding TipoFiltro}"/>
                    <Button Content="Quitar filtro" Style="{StaticResource Boton}" Command="{Binding QuitarFiltroCommand}"/>
                    <Button Content="Actualizar" Style="{StaticResource Boton}" Command="{Binding ActualizarCommand}"/>
                    <Button Content="Nueva serie" Style="{StaticResource Boton}" Command="{Binding NuevoCommand}" Background="#0F766E" BorderBrush="#0F766E" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="360"/></Grid.ColumnDefinitions>
            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                <DataGrid ItemsSource="{Binding Series}" SelectedItem="{Binding SerieSeleccionada}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" RowHeight="44" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Documento" Binding="{Binding NombreTipoDocumento}" Width="*"/>
                        <DataGridTextColumn Header="Serie" Binding="{Binding Serie}" Width="85"/>
                        <DataGridTextColumn Header="Último correlativo" Binding="{Binding UltimoCorrelativo}" Width="110"/>
                        <DataGridTextColumn Header="Dígitos" Binding="{Binding CantidadDigitos}" Width="65"/>
                        <DataGridCheckBoxColumn Header="Activa" Binding="{Binding Activa}" Width="60"/>
                        <DataGridCheckBoxColumn Header="Predet." Binding="{Binding Predeterminada}" Width="65"/>
                        <DataGridTextColumn Header="Último número generado" Binding="{Binding UltimoNumeroGenerado}" Width="150"/>
                        <DataGridTextColumn Header="Modificado por" Binding="{Binding UsuarioModificacion}" Width="105"/>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding FechaModificacion, StringFormat=dd/MM/yyyy HH:mm}" Width="125"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            <Border Grid.Column="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Text="Configuración" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                    <StackPanel Grid.Row="1" Margin="0,14,0,14">
                        <TextBlock Text="Tipo de documento" Style="{StaticResource Etiqueta}"/><ComboBox Style="{StaticResource Campo}" ItemsSource="{Binding Tipos}" DisplayMemberPath="NombreTipoDocumento" SelectedItem="{Binding TipoEdicion}"/>
                        <TextBlock Text="Serie" Style="{StaticResource Etiqueta}"/><TextBox Style="{StaticResource Campo}" Text="{Binding Serie, UpdateSourceTrigger=PropertyChanged}" MaxLength="20"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Último correlativo" Style="{StaticResource Etiqueta}"/><TextBox Style="{StaticResource Campo}" Text="{Binding UltimoCorrelativo, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="Cantidad de dígitos" Style="{StaticResource Etiqueta}"/><TextBox Style="{StaticResource Campo}" Text="{Binding CantidadDigitos, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                        </Grid>
                        <Border Background="#F0FDFA" CornerRadius="6" Padding="10" Margin="0,0,0,12"><StackPanel><TextBlock Text="Vista del último número" Foreground="#64748B" FontSize="11"/><TextBlock Text="{Binding VistaPrevia}" Foreground="#0F766E" FontSize="18" FontWeight="Bold" Margin="0,3,0,0"/></StackPanel></Border>
                        <StackPanel Orientation="Horizontal"><CheckBox Content="Activa" IsChecked="{Binding Activa}" Margin="0,0,22,0"/><CheckBox Content="Predeterminada" IsChecked="{Binding Predeterminada}"/></StackPanel>
                        <Button Content="Guardar configuración" Style="{StaticResource Boton}" Command="{Binding GuardarCommand}" HorizontalAlignment="Right" Margin="0,14,0,0" Background="#2563EB" BorderBrush="#2563EB" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2"><TextBlock Text="Historial de cambios" FontSize="15" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding Historial}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MaxHeight="190" RowHeight="34" FontSize="11">
                            <DataGrid.Columns><DataGridTextColumn Header="Acción" Binding="{Binding Accion}" Width="75"/><DataGridTextColumn Header="Serie" Binding="{Binding SerieNueva}" Width="60"/><DataGridTextColumn Header="Correlativo" Binding="{Binding CorrelativoNuevo}" Width="75"/><DataGridTextColumn Header="Usuario" Binding="{Binding Usuario}" Width="70"/><DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=dd/MM HH:mm}" Width="90"/></DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
