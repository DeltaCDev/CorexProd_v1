<UserControl x:Class="CorexProd.WPF.Modules.Seguridad.Views.CargosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="BotonBase" TargetType="Button">
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="BotonPrimario" TargetType="Button" BasedOn="{StaticResource BotonBase}">
            <Setter Property="Background" Value="#F97316"/>
            <Setter Property="BorderBrush" Value="#F97316"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BotonIcono" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="IconoAccion" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="CeldaTexto" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="EncabezadoCentro" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="CeldaGridCentro" TargetType="DataGridCell">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20" MaxWidth="1360" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="18" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Administra los cargos disponibles para empleados" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Style="{StaticResource BotonPrimario}" Command="{Binding NuevoCommand}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/><TextBlock Text="Nuevo"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource BotonBase}" Command="{Binding RefrescarCommand}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/><TextBlock Text="Actualizar"/></StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Bottom" Text="{Binding ResumenRegistros}" FontWeight="SemiBold" Foreground="#475569" Margin="14,10"/>
                    <DataGrid ItemsSource="{Binding Cargos}" SelectedItem="{Binding CargoSeleccionado}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" RowHeight="48" MaxHeight="560" GridLinesVisibility="Horizontal" ColumnHeaderStyle="{StaticResource EncabezadoCentro}" CellStyle="{StaticResource CeldaGridCentro}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Acciones" Width="96">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Style="{StaticResource BotonIcono}" ToolTip="Editar" Command="{Binding DataContext.EditarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                                <TextBlock Text="&#xE70F;" Style="{StaticResource IconoAccion}" Foreground="#0369A1"/>
                                            </Button>
                                            <Button Style="{StaticResource BotonIcono}" ToolTip="Eliminar" Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding IdCargo}">
                                                <TextBlock Text="&#xE711;" Style="{StaticResource IconoAccion}" Foreground="#BE123C"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ID" Binding="{Binding IdCargo}" Width="70" ElementStyle="{StaticResource CeldaTexto}"/>
                            <DataGridTextColumn Header="Cargo" Binding="{Binding NombreCargo}" Width="260" ElementStyle="{StaticResource CeldaTexto}"/>
                            <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Estado}" Width="100"/>
                            <DataGridTextColumn Header="Fecha Registro" Binding="{Binding FechaRegistro, StringFormat=dd/MM/yyyy HH:mm}" Width="170" ElementStyle="{StaticResource CeldaTexto}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
