 <UserControl x:Class="CorexProd.WPF.Modules.Seguridad.Views.ProveedoresView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CorexProd.WPF.Modules.Seguridad.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ProveedoresViewModel,
                                             IsDesignTimeCreatable=False}">

    <UserControl.Resources>

        <Style x:Key="LabelCampo"
               TargetType="TextBlock">
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Margin"
                    Value="0,0,0,5"/>
        </Style>

        <Style x:Key="CampoTexto"
               TargetType="TextBox">
            <Setter Property="Height"
                    Value="30"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="Padding"
                    Value="8,0"/>
        </Style>

        <Style x:Key="CampoCombo"
               TargetType="ComboBox">
            <Setter Property="Height"
                    Value="30"/>
            <Setter Property="Padding"
                    Value="6,0"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="18"
                Margin="0,0,0,14">

            <DockPanel LastChildFill="False">

                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Listado de proveedores registrados"
                               FontSize="14"
                               Foreground="#6B7280"/>
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Content="Nuevo"
                        Width="110"
                        Height="32"
                        HorizontalAlignment="Right"
                        Command="{Binding NuevoCommand}"/>

            </DockPanel>
        </Border>

        <!-- FORMULARIO -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="18"
                Margin="0,0,0,14"
                Visibility="{Binding FormularioVisibility}">

            <StackPanel>

                <TextBlock Text="{Binding TituloFormulario}"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,14"/>

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- TIPO DE DOCUMENTO -->
                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,20,14">

                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Documento "/>
                            <Run Text="*"
                                 Foreground="Red"/>
                        </TextBlock>

                        <ComboBox Style="{StaticResource CampoCombo}"
                                  SelectedValuePath="Content"
                                  SelectedValue="{Binding TipoDocumento,
                                                          Mode=TwoWay,
                                                          UpdateSourceTrigger=PropertyChanged}">

                            <ComboBoxItem Content="RUC"/>
                            <ComboBoxItem Content="DNI"/>
                            <ComboBoxItem Content="CARNET EXTRANJERIA"/>
                            <ComboBoxItem Content="PASAPORTE"/>
                            <ComboBoxItem Content="S/N"/>

                        </ComboBox>
                    </StackPanel>

                    <!-- NÚMERO DE DOCUMENTO -->
                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Margin="0,0,20,14">

                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Nro Documento "/>
                            <Run Text="*"
                                 Foreground="Red"/>
                        </TextBlock>

                        <DockPanel LastChildFill="True">

                            <Button DockPanel.Dock="Right"
                                    Width="38"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    ToolTip="Consultar documento"
                                    Command="{Binding ConsultarDocumentoCommand}">

                                <TextBlock Text="&#xE721;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"/>

                            </Button>

                            <TextBox Style="{StaticResource CampoTexto}"
                                     Text="{Binding NumeroDocumento,
                                                    Mode=TwoWay,
                                                    UpdateSourceTrigger=PropertyChanged}"/>

                        </DockPanel>
                    </StackPanel>

                    <!-- NOMBRE O RAZÓN SOCIAL -->
                    <StackPanel Grid.Row="0"
                                Grid.Column="2"
                                Margin="0,0,20,14">

                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Nombre o Razón Social "/>
                            <Run Text="*"
                                 Foreground="Red"/>
                        </TextBlock>

                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding NombreRazonSocial,
                                                Mode=TwoWay,
                                                UpdateSourceTrigger=PropertyChanged}"/>

                    </StackPanel>

                    <!-- TELÉFONO -->
                    <StackPanel Grid.Row="0"
                                Grid.Column="3"
                                Margin="0,0,0,14">

                        <TextBlock Text="Teléfono"
                                   Style="{StaticResource LabelCampo}"/>

                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding Telefono,
                                                Mode=TwoWay,
                                                UpdateSourceTrigger=PropertyChanged}"/>

                    </StackPanel>

                    <!-- DIRECCIÓN -->
                    <StackPanel Grid.Row="1"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Margin="0,0,20,14">

                        <TextBlock Text="Dirección"
                                   Style="{StaticResource LabelCampo}"/>

                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding Direccion,
                                                Mode=TwoWay,
                                                UpdateSourceTrigger=PropertyChanged}"/>

                    </StackPanel>

                    <!-- CORREO -->
                    <StackPanel Grid.Row="1"
                                Grid.Column="2"
                                Margin="0,0,20,14">

                        <TextBlock Text="Correo"
                                   Style="{StaticResource LabelCampo}"/>

                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding Correo,
                                                Mode=TwoWay,
                                                UpdateSourceTrigger=PropertyChanged}"/>

                    </StackPanel>

                    <!-- ESTADO -->
                    <StackPanel Grid.Row="1"
                                Grid.Column="3"
                                Margin="0,0,0,14">

                        <TextBlock Text="Estado"
                                   Style="{StaticResource LabelCampo}"/>

                        <CheckBox Content="Activo"
                                  IsChecked="{Binding Estado,
                                                      Mode=TwoWay,
                                                      UpdateSourceTrigger=PropertyChanged}"
                                  FontSize="14"
                                  VerticalAlignment="Center"
                                  Margin="0,6,0,0"/>

                    </StackPanel>

                    <!-- BOTONES -->
                    <StackPanel Grid.Row="2"
                                Grid.Column="2"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <Button Content="Guardar"
                                Width="110"
                                Height="32"
                                Margin="0,0,10,0"
                                Command="{Binding GuardarCommand}"/>

                        <Button Content="Cancelar"
                                Width="110"
                                Height="32"
                                Command="{Binding CancelarCommand}"/>

                    </StackPanel>

                </Grid>
            </StackPanel>
        </Border>

        <!-- LISTADO -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="0">

            <DataGrid ItemsSource="{Binding Proveedores}"
                      SelectedItem="{Binding ProveedorSeleccionado,
                                             Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      RowHeight="44"
                      GridLinesVisibility="Horizontal">

                <DataGrid.Columns>

                    <!-- ACCIONES -->
                    <DataGridTemplateColumn Header="Acciones"
                                            Width="90">

                        <DataGridTemplateColumn.CellTemplate>

                            <DataTemplate>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">

                                    <Button Style="{StaticResource BotonAccionTabla}"
                                            ToolTip="Editar"
                                            Command="{Binding DataContext.EditarCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">

                                        <TextBlock Text="&#xE70F;"
                                                   Style="{StaticResource IconoAccionTabla}"
                                                   Foreground="#0369A1"/>

                                    </Button>

                                    <Button Style="{StaticResource BotonAnularTabla}"
                                            ToolTip="Eliminar"
                                            Command="{Binding DataContext.EliminarCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding IdProveedor}">

                                        <TextBlock Text="&#xE711;"
                                                   Style="{StaticResource IconoAccionTabla}"/>

                                    </Button>

                                </StackPanel>

                            </DataTemplate>

                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding IdProveedor}"
                                        Width="40"/>

                    <DataGridTextColumn Header="Documento"
                                        Binding="{Binding TipoDocumento}"
                                        Width="87"/>

                    <DataGridTextColumn Header="Nro Documento"
                                        Binding="{Binding NumeroDocumento}"
                                        Width="110"/>

                    <DataGridTextColumn Header="Nombre / Razón Social"
                                        Binding="{Binding NombreRazonSocial}"
                                        Width="250"/>

                    <DataGridTextColumn Header="Dirección"
                                        Binding="{Binding Direccion}"
                                        Width="200"/>

                    <DataGridTextColumn Header="Teléfono"
                                        Binding="{Binding Telefono}"
                                        Width="90"/>

                    <DataGridTextColumn Header="Correo"
                                        Binding="{Binding Correo}"
                                        Width="120"/>

                    <DataGridCheckBoxColumn Header="Activo"
                                            Binding="{Binding Estado}"
                                            Width="70"/>

                </DataGrid.Columns>

            </DataGrid>
        </Border>

    </Grid>
</UserControl>
