<Window x:Class="CorexProd.WPF.Modules.Seguridad.Views.EmpleadoEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding TituloEditor}"
        Width="820"
        Height="560"
        MinHeight="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F3F4F6">
    <Window.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>
        <Style x:Key="BotonBase" TargetType="Button">
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="BotonPrimario" TargetType="Button" BasedOn="{StaticResource BotonBase}">
            <Setter Property="Background" Value="#F97316"/>
            <Setter Property="BorderBrush" Value="#F97316"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding TituloEditor}" FontSize="22" FontWeight="Bold" Foreground="#F97316" Margin="0,0,0,14"/>
        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16">
            <StackPanel>
                <TextBlock Margin="0,0,0,16" FontSize="13" Foreground="#64748B">
                    <Run Text="Complete la informacion del empleado. Los campos marcados con "/>
                    <Run Text="*" Foreground="#DC2626" FontWeight="Bold"/>
                    <Run Text=" son obligatorios."/>
                </TextBlock>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                        <TextBlock Style="{StaticResource LabelCampo}"><Run Text="Tipo Documento "/><Run Text="*" Foreground="#DC2626"/></TextBlock>
                        <ComboBox Style="{StaticResource CampoCombo}" SelectedValuePath="Content" SelectedValue="{Binding TipoDocumento}">
                            <ComboBoxItem Content="DNI"/>
                            <ComboBoxItem Content="CE"/>
                            <ComboBoxItem Content="PASAPORTE"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                        <TextBlock Style="{StaticResource LabelCampo}"><Run Text="Numero "/><Run Text="*" Foreground="#DC2626"/></TextBlock>
                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding NumeroDocumento, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,14,0">
                        <TextBlock Style="{StaticResource LabelCampo}"><Run Text="Nombres "/><Run Text="*" Foreground="#DC2626"/></TextBlock>
                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Style="{StaticResource LabelCampo}"><Run Text="Apellidos "/><Run Text="*" Foreground="#DC2626"/></TextBlock>
                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Apellido, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                        <TextBlock Style="{StaticResource LabelCampo}"><Run Text="Sexo "/><Run Text="*" Foreground="#DC2626"/></TextBlock>
                        <ComboBox Style="{StaticResource CampoCombo}" SelectedValuePath="Content" SelectedValue="{Binding Sexo}">
                            <ComboBoxItem Content="Masculino"/>
                            <ComboBoxItem Content="Femenino"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                        <TextBlock Text="Telefono" Style="{StaticResource LabelCampo}"/>
                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Telefono, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,14,0">
                        <TextBlock Text="Correo" Style="{StaticResource LabelCampo}"/>
                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Fecha Nacimiento" Style="{StaticResource LabelCampo}"/>
                        <DatePicker Height="32" SelectedDate="{Binding FechaNacimiento}"/>
                    </StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                        <TextBlock Text="Direccion" Style="{StaticResource LabelCampo}"/>
                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Direccion, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                        <TextBlock Style="{StaticResource LabelCampo}"><Run Text="Cargo "/><Run Text="*" Foreground="#DC2626"/></TextBlock>
                        <ComboBox Style="{StaticResource CampoCombo}" ItemsSource="{Binding Cargos}" DisplayMemberPath="NombreCargo" SelectedValuePath="IdCargo" SelectedValue="{Binding IdCargo}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="2" Content="Activo" IsChecked="{Binding Estado}" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                </Grid>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Guardar" Style="{StaticResource BotonPrimario}" Command="{Binding GuardarCommand}" Margin="0,0,8,0"/>
            <Button Content="Limpiar" Style="{StaticResource BotonBase}" Command="{Binding LimpiarCommand}" Margin="0,0,8,0"/>
            <Button Content="Cerrar" Style="{StaticResource BotonBase}" Command="{Binding CerrarCommand}"/>
        </StackPanel>
    </Grid>
</Window>
