<UserControl x:Class="CorexProd.WPF.Modules.Seguridad.Views.ParametrosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="18"
                Margin="0,0,0,14">

            <StackPanel>
                <TextBlock Margin="0,0,0,18"
                           FontSize="14">
                    <Run Text="Configure valores generales del sistema. Los campos marcados con "/>
                    <Run Text="*" Foreground="Red" FontWeight="Bold"/>
                    <Run Text=" son obligatorios." Foreground="Red"/>
                </TextBlock>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Código "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>

                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding CodigoParametro, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Nombre "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>

                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding NombreParametro, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Valor "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>

                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding ValorParametro, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <CheckBox Grid.Row="0"
                              Grid.Column="3"
                              Content="Activo"
                              IsChecked="{Binding Estado}"
                              FontSize="14"
                              VerticalAlignment="Bottom"
                              Margin="0,0,0,19"/>

                    <StackPanel Grid.Row="1"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Margin="0,0,20,0">

                        <TextBlock Text="Descripción"
                                   Style="{StaticResource LabelCampo}"/>

                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Bottom">

                        <Button Content="Guardar"
                                Width="110"
                                Height="32"
                                Margin="0,0,10,0"
                                Command="{Binding GuardarCommand}"/>

                        <Button Content="Limpiar"
                                Width="110"
                                Height="32"
                                Command="{Binding LimpiarCommand}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="0">

            <DataGrid ItemsSource="{Binding Parametros}"
                      SelectedItem="{Binding ParametroSeleccionado}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      RowHeight="44"
                      GridLinesVisibility="Horizontal">

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Acciones" Width="75">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource BotonAnularTabla}" ToolTip="Eliminar"
                                        HorizontalAlignment="Center"
                                        Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding IdParametro}">
                                    <TextBlock Text="&#xE711;" Style="{StaticResource IconoAccionTabla}"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding IdParametro}"
                                        Width="45"/>

                    <DataGridTextColumn Header="Código"
                                        Binding="{Binding CodigoParametro}"
                                        Width="180"/>

                    <DataGridTextColumn Header="Nombre"
                                        Binding="{Binding NombreParametro}"
                                        Width="190"/>

                    <DataGridTextColumn Header="Valor"
                                        Binding="{Binding ValorParametro}"
                                        Width="190"/>

                    <DataGridTextColumn Header="Descripción"
                                        Binding="{Binding Descripcion}"
                                        Width="*"/>

                    <DataGridCheckBoxColumn Header="Activo"
                                            Binding="{Binding Estado}"
                                            Width="80"/>

                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
