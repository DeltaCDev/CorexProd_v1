<UserControl x:Class="CorexProd.WPF.Modules.Seguridad.Views.EmpleadosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="18"
                Margin="0,0,0,14">

            <StackPanel>
                <TextBlock Text="Gestión de Empleados"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <TextBlock Margin="0,0,0,18"
                           FontSize="14">
                    <Run Text="Complete la información del empleado. Los campos marcados con "/>
                    <Run Text="*" Foreground="Red" FontWeight="Bold"/>
                    <Run Text=" son obligatorios." Foreground="Red"/>
                </TextBlock>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.3*"/>
                        <ColumnDefinition Width="1.3*"/>
                        <ColumnDefinition Width="1.1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tipo Documento -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Tipo de Documento "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>
                        <ComboBox Style="{StaticResource CampoCombo}"
                                  SelectedValuePath="Content"
                                  SelectedValue="{Binding TipoDocumento}">
                            <ComboBoxItem Content="DNI"/>
                            <ComboBoxItem Content="CE"/>
                            <ComboBoxItem Content="PASAPORTE"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Número Documento -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Número de Documento "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>
                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding NumeroDocumento, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Nombres -->
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Nombres "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>
                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Apellidos -->
                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Apellidos "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>
                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding Apellido, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Sexo -->
                    <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Sexo "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>
                        <ComboBox Style="{StaticResource CampoCombo}"
                                  SelectedValuePath="Content"
                                  SelectedValue="{Binding Sexo}">
                            <ComboBoxItem Content="Masculino"/>
                            <ComboBoxItem Content="Femenino"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Teléfono -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,20,14">
                        <TextBlock Text="Teléfono" Style="{StaticResource LabelCampo}"/>
                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding Telefono, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Correo -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,20,14">
                        <TextBlock Text="Correo Electrónico" Style="{StaticResource LabelCampo}"/>
                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Dirección -->
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,20,14">
                        <TextBlock Text="Dirección" Style="{StaticResource LabelCampo}"/>
                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding Direccion, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Cargo -->
                    <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Cargo "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>
                        <ComboBox Style="{StaticResource CampoCombo}"
                                  ItemsSource="{Binding Cargos}"
                                  DisplayMemberPath="NombreCargo"
                                  SelectedValuePath="IdCargo"
                                  SelectedValue="{Binding IdCargo}"/>
                    </StackPanel>

                    <!-- Fecha Nacimiento -->
                    <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,0,0,14">
                        <TextBlock Text="Fecha de Nacimiento" Style="{StaticResource LabelCampo}"/>
                        <DatePicker Height="30"
                                    SelectedDate="{Binding FechaNacimiento}"/>
                    </StackPanel>

                    <!-- Botones -->
                    <StackPanel Grid.Row="2"
                                Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,4,0,0">

                        <CheckBox Content="Activo"
                                  IsChecked="{Binding Estado}"
                                  FontSize="14"
                                  VerticalAlignment="Center"
                                  Margin="0,0,25,0"/>

                        <Button Content="Guardar"
                                Width="110"
                                Height="32"
                                Margin="0,0,10,0"
                                Command="{Binding GuardarCommand}"/>

                        <Button Content="Limpiar"
                                Width="110"
                                Height="32"
                                Command="{Binding LimpiarCommand}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Tabla -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="0">

            <DataGrid ItemsSource="{Binding Empleados}"
                      SelectedItem="{Binding EmpleadoSeleccionado}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      RowHeight="44"
                      GridLinesVisibility="Horizontal">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdEmpleado}" Width="70"/>
                    <DataGridTextColumn Header="Documento" Binding="{Binding NumeroDocumento}" Width="150"/>
                    <DataGridTextColumn Header="Nombres" Binding="{Binding Nombre}" Width="170"/>
                    <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellido}" Width="170"/>
                    <DataGridTextColumn Header="Cargo" Binding="{Binding NombreCargo}" Width="170"/>
                    <DataGridTextColumn Header="Teléfono" Binding="{Binding Telefono}" Width="130"/>
                    <DataGridTextColumn Header="Correo" Binding="{Binding Email}" Width="*"/>
                    <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Estado}" Width="90"/>

                    <DataGridTemplateColumn Header="Acciones" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Eliminar"
                                        Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding IdEmpleado}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>