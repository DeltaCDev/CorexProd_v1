<Window x:Class="CorexProd.WPF.Modules.Seguridad.Views.EmpresaEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Titulo}"
        Width="980"
        Height="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F4F6">

    <Window.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Foreground" Value="#374151"/>
        </Style>

        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Titulo}"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#111827"
                   Margin="0,0,0,16"/>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,18,14">
                    <TextBlock Style="{StaticResource LabelCampo}">
                        <Run Text="RUC "/>
                        <Run Text="*" Foreground="Red"/>
                    </TextBlock>
                    <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Ruc, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,18,14">
                    <TextBlock Style="{StaticResource LabelCampo}">
                        <Run Text="Nombre "/>
                        <Run Text="*" Foreground="Red"/>
                    </TextBlock>
                    <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,18,14">
                    <TextBlock Text="Nombre comercial" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}" Text="{Binding NombreComercial, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,14">
                    <TextBlock Text="Teléfono" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Telefono, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,18,14">
                    <TextBlock Text="Correo" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Correo, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,18,14">
                    <TextBlock Text="Departamento" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Departamento, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,18,14">
                    <TextBlock Text="Provincia" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Provincia, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,0,14">
                    <TextBlock Text="Distrito" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Distrito, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,18,14">
                    <TextBlock Text="Dirección" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Direccion, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,18,14">
                    <TextBlock Text="Logo" Style="{StaticResource LabelCampo}"/>
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Content="Buscar"
                                Width="78"
                                Height="30"
                                Margin="8,0,0,0"
                                Command="{Binding SeleccionarLogoCommand}"/>
                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Logo, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="3" Margin="0,0,0,14">
                    <TextBlock Text="Código cliente" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}" Text="{Binding CodigoCliente, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,18,0">
                    <TextBlock Text="Licencia de activación" Style="{StaticResource LabelCampo}"/>
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Content="En mantenimiento"
                                Width="130"
                                Height="30"
                                Margin="8,0,0,0"
                                IsEnabled="False"
                                Command="{Binding ValidarLicenciaCommand}"/>
                        <TextBox Style="{StaticResource CampoTexto}"
                                 IsReadOnly="True"
                                 Text="{Binding LicenciaActivacion, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,18,0">
                    <CheckBox Content="Predeterminada"
                              IsChecked="{Binding EsPredeterminada}"
                              Margin="0,0,18,6"/>
                    <CheckBox Content="Activa"
                              IsChecked="{Binding Estado}"
                              Margin="0,0,0,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Cancelar"
                    Width="110"
                    Height="34"
                    Margin="0,0,10,0"
                    Command="{Binding CancelarCommand}"/>
            <Button Content="Guardar"
                    Width="110"
                    Height="34"
                    Command="{Binding GuardarCommand}"/>
        </StackPanel>
    </Grid>
</Window>
