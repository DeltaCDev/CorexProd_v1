<Window x:Class="CorexProd.WPF.Modules.Seguridad.Views.UsuarioEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding TituloEditor}"
        Width="680"
        Height="520"
        MinHeight="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F3F4F6">
    <Window.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>
        <Style x:Key="BotonBase" TargetType="Button">
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="BotonPrimario" TargetType="Button" BasedOn="{StaticResource BotonBase}">
            <Setter Property="Background" Value="#F97316"/>
            <Setter Property="BorderBrush" Value="#F97316"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding TituloEditor}" FontSize="22" FontWeight="Bold" Foreground="#F97316" Margin="0,0,0,14"/>

        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16">
            <StackPanel>
                <TextBlock Margin="0,0,0,16" FontSize="13" Foreground="#64748B">
                    <Run Text="Complete la informacion del usuario. Los campos marcados con "/>
                    <Run Text="*" Foreground="#DC2626" FontWeight="Bold"/>
                    <Run Text=" son obligatorios."/>
                </TextBlock>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                        <TextBlock Style="{StaticResource LabelCampo}"><Run Text="Empleado "/><Run Text="*" Foreground="#DC2626"/></TextBlock>
                        <ComboBox Style="{StaticResource CampoCombo}" ItemsSource="{Binding Empleados}" DisplayMemberPath="NombreCompleto" SelectedValuePath="IdEmpleado" SelectedValue="{Binding IdEmpleado}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource LabelCampo}"><Run Text="Rol "/><Run Text="*" Foreground="#DC2626"/></TextBlock>
                        <ComboBox Style="{StaticResource CampoCombo}" ItemsSource="{Binding Roles}" DisplayMemberPath="NombreRol" SelectedValuePath="IdRol" SelectedValue="{Binding IdRol}"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                        <TextBlock Style="{StaticResource LabelCampo}"><Run Text="Usuario "/><Run Text="*" Foreground="#DC2626"/></TextBlock>
                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                        <TextBlock Style="{StaticResource LabelCampo}"><Run Text="Clave "/><Run Text="*" Foreground="#DC2626"/></TextBlock>
                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding Clave, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="2" Content="Activo" IsChecked="{Binding Estado}" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                </Grid>

                <Border Background="#F8FAFC"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="Permisos operativos del rol seleccionado"
                                   FontWeight="Bold"
                                   Foreground="#374151"
                                   Margin="0,0,0,8"/>
                        <UniformGrid Columns="3">
                            <CheckBox Content="Generar OT"
                                      IsChecked="{Binding PuedeGenerarOtRol, Mode=OneWay}"
                                      IsEnabled="False"
                                      FontWeight="SemiBold"/>
                            <CheckBox Content="Generar Guía Interna"
                                      IsChecked="{Binding PuedeGenerarGuiaRol, Mode=OneWay}"
                                      IsEnabled="False"
                                      FontWeight="SemiBold"/>
                            <CheckBox Content="Transferir en OT"
                                      IsChecked="{Binding PuedeTransferirOtRol, Mode=OneWay}"
                                      IsEnabled="False"
                                      FontWeight="SemiBold"/>
                        </UniformGrid>
                        <TextBlock Text="Para activar o desactivar estos permisos, edite el rol en Seguridad > Roles."
                                   Foreground="#64748B"
                                   FontSize="12"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Guardar" Style="{StaticResource BotonPrimario}" Command="{Binding GuardarCommand}" Margin="0,0,8,0"/>
            <Button Content="Limpiar" Style="{StaticResource BotonBase}" Command="{Binding LimpiarCommand}" Margin="0,0,8,0"/>
            <Button Content="Cerrar" Style="{StaticResource BotonBase}" Command="{Binding CerrarCommand}"/>
        </StackPanel>
    </Grid>
</Window>
