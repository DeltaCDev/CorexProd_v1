<UserControl x:Class="CorexProd.WPF.Modules.Seguridad.Views.RolesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FORMULARIO ROL -->
        <Border Background="#F9FAFB"
                Padding="20"
                CornerRadius="10">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="0,0,15,0">
                    <TextBlock Text="Nombre del Rol"
                               FontWeight="SemiBold"/>

                    <TextBox Text="{Binding NombreRol}"
                             Height="35"
                             Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="0,0,15,0">
                    <TextBlock Text="Estado"
                               FontWeight="SemiBold"/>

                    <CheckBox IsChecked="{Binding Estado}"
                              Content="Activo"
                              Margin="0,10,0,0"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Guardar"
                        Height="35"
                        Margin="0,23,0,0"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        Command="{Binding GuardarCommand}"/>
            </Grid>
        </Border>

        <!-- TABLA + PERMISOS -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- ROLES -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="10">

                <DataGrid ItemsSource="{Binding Roles}"
                          SelectedItem="{Binding RolSeleccionado}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Margin="10">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding IdRol}"
                                            Width="70"/>

                        <DataGridTextColumn Header="Rol"
                                            Binding="{Binding NombreRol}"
                                            Width="*"/>

                        <DataGridCheckBoxColumn Header="Activo"
                                                Binding="{Binding Estado}"
                                                Width="90"/>

                        <DataGridTextColumn Header="Fecha Registro"
                                            Binding="{Binding FechaRegistro}"
                                            Width="170"/>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- PERMISOS -->
            <Border Grid.Column="2"
                    Background="#F9FAFB"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="15">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Permisos del Rol"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="1"
                               Text="Seleccione un rol y marque los módulos que podrá visualizar."
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <Border Grid.Row="2"
                            Background="White"
                            BorderBrush="#FCD34D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Permisos operativos clave"
                                       FontWeight="Bold"
                                       Foreground="#92400E"
                                       Margin="0,0,0,6"/>
                            <CheckBox Content="Generar OT / Operar y transferir en Orden de Trabajo"
                                      IsChecked="{Binding PermisoOrdenTrabajo, Mode=TwoWay}"
                                      Margin="0,3"/>
                            <CheckBox Content="Generar Guía Interna de Salida"
                                      IsChecked="{Binding PermisoGuiaInterna, Mode=TwoWay}"
                                      Margin="0,3"/>
                        </StackPanel>
                    </Border>

                    <!-- COPIAR ROL -->
                    <Grid Grid.Row="3"
                          Margin="0,0,0,10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding RolesParaCopiar}"
                                  SelectedItem="{Binding RolOrigenSeleccionado}"
                                  DisplayMemberPath="NombreRol"
                                  Height="32"/>

                        <Button Grid.Column="2"
                                Content="Copiar Rol"
                                Height="32"
                                Command="{Binding CopiarPermisosCommand}"/>
                    </Grid>

                    <ScrollViewer Grid.Row="4"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,0,0,10"
                                  PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">

                        <TreeView ItemsSource="{Binding Menus}"
                                  BorderThickness="0"
                                  Background="Transparent">

                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Hijos}">

                                    <CheckBox Content="{Binding NombreMenu}"
                                              IsChecked="{Binding TienePermiso, Mode=TwoWay}"
                                              FontWeight="SemiBold"
                                              Margin="0,5"/>

                                    <HierarchicalDataTemplate.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding NombreMenu}"
                                                      IsChecked="{Binding TienePermiso, Mode=TwoWay}"
                                                      Margin="20,4,0,4"/>
                                        </DataTemplate>
                                    </HierarchicalDataTemplate.ItemTemplate>

                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>

                    </ScrollViewer>

                    <Grid Grid.Row="5"
                          Margin="0,0,0,10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Seleccionar todo"
                                Height="32"
                                Command="{Binding SeleccionarTodoCommand}"/>

                        <Button Grid.Column="2"
                                Content="Quitar selección"
                                Height="32"
                                Command="{Binding QuitarSeleccionCommand}"/>
                    </Grid>

                    <Button Grid.Row="6"
                            Content="Guardar Permisos"
                            Height="38"
                            Background="#16A34A"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Command="{Binding GuardarPermisosCommand}"/>

                </Grid>
            </Border>

        </Grid>

    </Grid>
</UserControl>
