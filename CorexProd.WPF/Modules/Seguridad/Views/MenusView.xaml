<UserControl x:Class="CorexProd.WPF.Modules.Seguridad.Views.MenusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CorexProd.WPF.Modules.Seguridad.ViewModels">

    <UserControl.DataContext>
        <vm:MenusViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="18"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Administración del menú lateral"
                               FontSize="22"
                               FontWeight="Bold"/>
                    <TextBlock Text="Cambie el orden de los módulos y submenús. Puede editar la columna Orden o usar Subir/Bajar y luego Guardar."
                               Foreground="#475569"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Subir"
                            Width="95"
                            Height="34"
                            Margin="0,0,8,0"
                            Command="{Binding SubirCommand}"/>
                    <Button Content="Bajar"
                            Width="95"
                            Height="34"
                            Margin="0,0,8,0"
                            Command="{Binding BajarCommand}"/>
                    <Button Content="Actualizar"
                            Width="105"
                            Height="34"
                            Margin="0,0,8,0"
                            Command="{Binding ActualizarCommand}"/>
                    <Button Content="Guardar"
                            Width="110"
                            Height="34"
                            Command="{Binding GuardarCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="0">
            <DataGrid ItemsSource="{Binding Menus}"
                      SelectedItem="{Binding MenuSeleccionado}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      RowHeight="42"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding IdMenu}"
                                        Width="60"
                                        IsReadOnly="True"/>
                    <DataGridTextColumn Header="Tipo"
                                        Binding="{Binding Tipo}"
                                        Width="110"
                                        IsReadOnly="True"/>
                    <DataGridTextColumn Header="Menú"
                                        Binding="{Binding NombreMenu}"
                                        Width="2*"
                                        IsReadOnly="True"/>
                    <DataGridTextColumn Header="Padre"
                                        Binding="{Binding NombrePadre}"
                                        Width="1.4*"
                                        IsReadOnly="True"/>
                    <DataGridTextColumn Header="Orden"
                                        Binding="{Binding Orden, UpdateSourceTrigger=PropertyChanged}"
                                        Width="95"/>
                    <DataGridCheckBoxColumn Header="Activo"
                                            Binding="{Binding Estado, UpdateSourceTrigger=PropertyChanged}"
                                            Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
