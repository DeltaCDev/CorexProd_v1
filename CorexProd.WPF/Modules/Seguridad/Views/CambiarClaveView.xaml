<UserControl x:Class="CorexProd.WPF.Modules.Seguridad.Views.CambiarClaveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Border Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="24"
                Width="520"
                HorizontalAlignment="Left"
                VerticalAlignment="Top">

            <StackPanel>
                <TextBlock Text="Actualice su contraseña de acceso al sistema."
                           FontSize="14"
                           Foreground="#64748B"
                           Margin="0,0,0,24"/>

                <TextBlock Text="Clave Actual *"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <PasswordBox x:Name="TxtClaveActual"
                             Height="32"
                             Margin="0,0,0,14"/>

                <TextBlock Text="Nueva Clave *"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <PasswordBox x:Name="TxtClaveNueva"
                             Height="32"
                             Margin="0,0,0,14"/>

                <TextBlock Text="Confirmar Nueva Clave *"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <PasswordBox x:Name="TxtConfirmarClave"
                             Height="32"
                             Margin="0,0,0,24"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="Guardar"
                            Width="110"
                            Height="32"
                            Margin="0,0,10,0"
                            Command="{Binding CambiarClaveCommand}"
                            CommandParameter="{Binding ElementName=TxtClaveActual}"/>

                    <Button Content="Limpiar"
                            Width="110"
                            Height="32"
                            Command="{Binding LimpiarCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
