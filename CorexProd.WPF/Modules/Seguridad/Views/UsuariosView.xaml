<UserControl x:Class="CorexProd.WPF.Modules.Seguridad.Views.UsuariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="18"
                Margin="0,0,0,14">

            <StackPanel>
                <TextBlock Text="Gestión de Usuarios"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <TextBlock Margin="0,0,0,18"
                           FontSize="14">
                    <Run Text="Complete la información del usuario. Los campos marcados con "/>
                    <Run Text="*" Foreground="Red" FontWeight="Bold"/>
                    <Run Text=" son obligatorios." Foreground="Red"/>
                </TextBlock>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.7*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Empleado -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Empleado "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>

                        <ComboBox Style="{StaticResource CampoCombo}"
                                  ItemsSource="{Binding Empleados}"
                                  DisplayMemberPath="NombreCompleto"
                                  SelectedValuePath="IdEmpleado"
                                  SelectedValue="{Binding IdEmpleado}"/>
                    </StackPanel>

                    <!-- Usuario -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Usuario "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>

                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Clave -->
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Clave "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>

                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding Clave, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Rol -->
                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Rol "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>

                        <ComboBox Style="{StaticResource CampoCombo}"
                                  ItemsSource="{Binding Roles}"
                                  DisplayMemberPath="NombreRol"
                                  SelectedValuePath="IdRol"
                                  SelectedValue="{Binding IdRol}"/>
                    </StackPanel>

                    <!-- Activo -->
                    <CheckBox Grid.Row="0"
                              Grid.Column="4"
                              Content="Activo"
                              IsChecked="{Binding Estado}"
                              FontSize="14"
                              VerticalAlignment="Bottom"
                              Margin="0,0,0,17"/>

                    <!-- Botones -->
                    <StackPanel Grid.Row="1"
                                Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,4,0,0">

                        <Button Content="Guardar"
                                Width="110"
                                Height="32"
                                Margin="0,0,10,0"
                                Command="{Binding GuardarCommand}"/>

                        <Button Content="Limpiar"
                                Width="110"
                                Height="32"
                                Command="{Binding LimpiarCommand}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Tabla -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="0">

            <DataGrid ItemsSource="{Binding Usuarios}"
                      SelectedItem="{Binding UsuarioSeleccionado}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      RowHeight="44"
                      GridLinesVisibility="Horizontal">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdUsuario}" Width="70"/>
                    <DataGridTextColumn Header="Empleado" Binding="{Binding NombreEmpleado}" Width="220"/>
                    <DataGridTextColumn Header="Usuario" Binding="{Binding NombreUsuario}" Width="160"/>
                    <DataGridTextColumn Header="Rol" Binding="{Binding NombreRol}" Width="160"/>
                    <DataGridTextColumn Header="Fecha Registro"
                                        Binding="{Binding FechaRegistro, StringFormat=dd/MM/yyyy HH:mm}"
                                        Width="160"/>
                    <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Estado}" Width="90"/>

                    <DataGridTemplateColumn Header="Acciones" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Eliminar"
                                        Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding IdUsuario}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>