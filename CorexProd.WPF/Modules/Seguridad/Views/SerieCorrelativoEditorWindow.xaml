<Window x:Class="CorexProd.WPF.Modules.Seguridad.Views.SerieCorrelativoEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding TituloModal}" Width="700" Height="650" MinHeight="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Background="#F3F4F6">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="Etiqueta" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="Campo" TargetType="Control">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="Boton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,14">
            <TextBlock Text="{Binding TituloModal}" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="{Binding SubtituloModal}" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="18" IsEnabled="{Binding PuedeEditar}">
                    <StackPanel>
                        <TextBlock Text="Tipo de documento" Style="{StaticResource Etiqueta}"/>
                        <ComboBox Style="{StaticResource Campo}" ItemsSource="{Binding Tipos}" DisplayMemberPath="NombreTipoDocumento" SelectedItem="{Binding TipoEdicion}"/>
                        <TextBlock Text="Serie" Style="{StaticResource Etiqueta}"/>
                        <TextBox Style="{StaticResource Campo}" Text="{Binding Serie, UpdateSourceTrigger=PropertyChanged}" MaxLength="20"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Último correlativo" Style="{StaticResource Etiqueta}"/>
                                <TextBox Style="{StaticResource Campo}" Text="{Binding UltimoCorrelativo, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Cantidad de dígitos" Style="{StaticResource Etiqueta}"/>
                                <TextBox Style="{StaticResource Campo}" Text="{Binding CantidadDigitos, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <Border Background="#F0FDFA" CornerRadius="6" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Vista del último número" Foreground="#64748B" FontSize="11"/>
                                <TextBlock Text="{Binding VistaPrevia}" Foreground="#0F766E" FontSize="18" FontWeight="Bold" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="Activa" IsChecked="{Binding Activa}" Margin="0,0,22,0"/>
                            <CheckBox Content="Predeterminada" IsChecked="{Binding Predeterminada}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,14,0,0"
                        Visibility="{Binding SoloLectura, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Historial de cambios" FontSize="16" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,10"/>
                        <DataGrid ItemsSource="{Binding Historial}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MinHeight="150" RowHeight="34" FontSize="11">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Acción" Binding="{Binding Accion}" Width="90"/>
                                <DataGridTextColumn Header="Serie" Binding="{Binding SerieNueva}" Width="80"/>
                                <DataGridTextColumn Header="Correlativo" Binding="{Binding CorrelativoNuevo}" Width="95"/>
                                <DataGridTextColumn Header="Usuario" Binding="{Binding Usuario}" Width="*"/>
                                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=dd/MM/yyyy HH:mm}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Guardar" Style="{StaticResource Boton}" Command="{Binding GuardarCommand}"
                    Background="#2563EB" BorderBrush="#2563EB" Foreground="White"
                    Visibility="{Binding PuedeEditar, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <Button Content="Cerrar" Style="{StaticResource Boton}" Command="{Binding CerrarCommand}"/>
        </StackPanel>
    </Grid>
</Window>
