<UserControl x:Class="CorexProd.WPF.Modules.DestajoPagos.Views.PrestamosCuotasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="White">

    <UserControl.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>

        <Style x:Key="BotonAccion" TargetType="Button">
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="CajaSeccion" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E5E7EB"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E5E7EB"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="MinColumnWidth" Value="96"/>
            <Setter Property="ColumnWidth" Value="Auto"/>
            <Setter Property="ColumnHeaderHeight" Value="34"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="False"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderBrush" Value="#CBD5E1"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridCell}">
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                                <Setter Property="Foreground" Value="#111827"/>
                                <Setter Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridRow}">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                                <Setter Property="Foreground" Value="#111827"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,12,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CajaSeccion}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1.6*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Trabajador" Style="{StaticResource LabelCampo}"/>
                    <ComboBox Style="{StaticResource CampoCombo}"
                              ItemsSource="{Binding Trabajadores}"
                              DisplayMemberPath="NombreTrabajador"
                              SelectedValuePath="IdTrabajadorOperativo"
                              SelectedValue="{Binding IdTrabajadorPrestamo}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Fecha" Style="{StaticResource LabelCampo}"/>
                    <DatePicker Height="30"
                                SelectedDate="{Binding FechaPrestamo}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Monto" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}"
                             Text="{Binding MontoPrestamo, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Text="Cuotas" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}"
                             Text="{Binding NumeroCuotasPrestamo, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="0,0,10,0">
                    <TextBlock Text="Monto cuota" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}"
                             Text="{Binding MontoCuotaPrestamo, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="5" Margin="0,0,10,0">
                    <TextBlock Text="Concepto cuota" Style="{StaticResource LabelCampo}"/>
                    <ComboBox Style="{StaticResource CampoCombo}"
                              ItemsSource="{Binding ConceptosDescuento}"
                              DisplayMemberPath="NombreConcepto"
                              SelectedValuePath="IdConceptoMovimiento"
                              SelectedValue="{Binding IdConceptoCuota}"/>
                </StackPanel>

                <StackPanel Grid.Column="6" Margin="0,0,10,0">
                    <TextBlock Text="Observación" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}"
                             Text="{Binding ObservacionPrestamo, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="7"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom">
                    <Button Content="Registrar"
                            Style="{StaticResource BotonAccion}"
                            Command="{Binding RegistrarPrestamoCommand}"/>
                    <Button Content="Limpiar"
                            Style="{StaticResource BotonAccion}"
                            Command="{Binding LimpiarPrestamoCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CajaSeccion}">
            <StackPanel Orientation="Horizontal">
                <StackPanel Width="300" Margin="0,0,10,0">
                    <TextBlock Text="Filtro trabajador" Style="{StaticResource LabelCampo}"/>
                    <ComboBox Style="{StaticResource CampoCombo}"
                              ItemsSource="{Binding Trabajadores}"
                              DisplayMemberPath="NombreTrabajador"
                              SelectedValuePath="IdTrabajadorOperativo"
                              SelectedValue="{Binding IdTrabajadorFiltroPrestamos}"/>
                </StackPanel>
                <Button Content="Filtrar"
                        Style="{StaticResource BotonAccion}"
                        Command="{Binding FiltrarPrestamosCommand}"
                        VerticalAlignment="Bottom"/>
                <Button Content="Todos"
                        Style="{StaticResource BotonAccion}"
                        Command="{Binding LimpiarFiltroPrestamosCommand}"
                        VerticalAlignment="Bottom"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Prestamos}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  MinHeight="200"
                  Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Trabajador" Binding="{Binding NombreTrabajador}" Width="210"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding FechaPrestamo, StringFormat=d}" Width="100"/>
                <DataGridTextColumn Header="Monto" Binding="{Binding MontoTotal, StringFormat={}{0:N2}}" Width="100"/>
                <DataGridTextColumn Header="Cuotas" Binding="{Binding NumeroCuotas}" Width="80"/>
                <DataGridTextColumn Header="Monto cuota" Binding="{Binding MontoCuota, StringFormat={}{0:N2}}" Width="100"/>
                <DataGridTextColumn Header="Saldo" Binding="{Binding SaldoPendiente, StringFormat={}{0:N2}}" Width="100"/>
                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="110"/>
                <DataGridTextColumn Header="Observación" Binding="{Binding Observacion}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,8">
                <ComboBox Width="260"
                          Style="{StaticResource CampoCombo}"
                          ItemsSource="{Binding Trabajadores}"
                          DisplayMemberPath="NombreTrabajador"
                          SelectedValuePath="IdTrabajadorOperativo"
                          SelectedValue="{Binding IdTrabajadorFiltroCuotas}"/>
                <Button Content="Filtrar"
                        Style="{StaticResource BotonAccion}"
                        Command="{Binding FiltrarCuotasCommand}"
                        Margin="10,0,8,0"/>
                <Button Content="Aplicar al periodo"
                        Style="{StaticResource BotonAccion}"
                        Command="{Binding AplicarCuotaCommand}"/>
            </StackPanel>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Cuotas}"
                      SelectedItem="{Binding CuotaSeleccionada}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      MinHeight="200">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Trabajador" Binding="{Binding NombreTrabajador}" Width="190"/>
                    <DataGridTextColumn Header="Origen" Binding="{Binding TipoOrigen}" Width="100"/>
                    <DataGridTextColumn Header="Concepto" Binding="{Binding NombreConcepto}" Width="160"/>
                    <DataGridTextColumn Header="Cuota" Binding="{Binding NumeroCuota}" Width="70"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding TotalCuotas}" Width="70"/>
                    <DataGridTextColumn Header="Monto" Binding="{Binding MontoCuota, StringFormat={}{0:N2}}" Width="90"/>
                    <DataGridTextColumn Header="Fecha" Binding="{Binding FechaProgramada, StringFormat=d}" Width="100"/>
                    <DataGridTextColumn Header="Periodo" Binding="{Binding CodigoPeriodoAplicado}" Width="110"/>
                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="110"/>
                    <DataGridTextColumn Header="Observación" Binding="{Binding Observacion}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
