<UserControl x:Class="CorexProd.WPF.Modules.DestajoPagos.Views.PanelDestajoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="White">

    <UserControl.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>

        <Style x:Key="BotonAccion" TargetType="Button">
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="CajaSeccion" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E5E7EB"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E5E7EB"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="MinColumnWidth" Value="96"/>
            <Setter Property="ColumnWidth" Value="Auto"/>
            <Setter Property="ColumnHeaderHeight" Value="34"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="False"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderBrush" Value="#CBD5E1"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridCell}">
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                                <Setter Property="Foreground" Value="#111827"/>
                                <Setter Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridRow}">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                                <Setter Property="Foreground" Value="#111827"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,12,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CajaSeccion}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                    <TextBlock Text="Fecha" Style="{StaticResource LabelCampo}"/>
                    <DatePicker Height="30"
                                SelectedDate="{Binding FechaMovimiento}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,10">
                    <TextBlock Text="Trabajador" Style="{StaticResource LabelCampo}"/>
                    <ComboBox Style="{StaticResource CampoCombo}"
                              ItemsSource="{Binding Trabajadores}"
                              DisplayMemberPath="NombreTrabajador"
                              SelectedValuePath="IdTrabajadorOperativo"
                              SelectedValue="{Binding IdTrabajadorMovimiento}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,10,10">
                    <TextBlock Text="Concepto" Style="{StaticResource LabelCampo}"/>
                    <ComboBox Style="{StaticResource CampoCombo}"
                              ItemsSource="{Binding Conceptos}"
                              DisplayMemberPath="NombreConcepto"
                              SelectedValuePath="IdConceptoMovimiento"
                              SelectedValue="{Binding IdConceptoMovimientoForm}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,10,10">
                    <TextBlock Text="Tipo" Style="{StaticResource LabelCampo}"/>
                    <ComboBox Style="{StaticResource CampoCombo}"
                              ItemsSource="{Binding TiposMovimiento}"
                              SelectedItem="{Binding TipoMovimientoForm}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,10,10">
                    <TextBlock Text="Categoría" Style="{StaticResource LabelCampo}"/>
                    <ComboBox Style="{StaticResource CampoCombo}"
                              ItemsSource="{Binding CategoriasMovimiento}"
                              SelectedItem="{Binding CategoriaMovimientoForm}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="5" Margin="0,0,0,10">
                    <TextBlock Text="Estado" Style="{StaticResource LabelCampo}"/>
                    <ComboBox Style="{StaticResource CampoCombo}"
                              ItemsSource="{Binding EstadosMovimiento}"
                              SelectedItem="{Binding EstadoMovimiento}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Cantidad" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}"
                             Text="{Binding CantidadMovimiento, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Unidad" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}"
                             Text="{Binding UnidadMovimiento, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Tarifa" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}"
                             Text="{Binding TarifaMovimiento, UpdateSourceTrigger=LostFocus}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Text="Importe" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}"
                             Text="{Binding ImporteMovimiento, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,0,10,0">
                    <TextBlock Text="Total" Style="{StaticResource LabelCampo}"/>
                    <TextBlock Text="{Binding TotalMovimientoCalculado, StringFormat={}{0:N2}}"
                               FontSize="18"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <CheckBox Grid.Row="1"
                          Grid.Column="5"
                          Content="Descuento"
                          IsChecked="{Binding EsDescuentoMovimiento}"
                          VerticalAlignment="Center"
                          Margin="0,18,0,0"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CajaSeccion}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.9*"/>
                    <ColumnDefinition Width="0.9*"/>
                    <ColumnDefinition Width="3.2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Área" Style="{StaticResource LabelCampo}"/>
                    <ComboBox Style="{StaticResource CampoCombo}"
                              ItemsSource="{Binding Areas}"
                              DisplayMemberPath="NombreArea"
                              SelectedValuePath="IdAreaOperativa"
                              SelectedValue="{Binding IdAreaMovimiento}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Operación" Style="{StaticResource LabelCampo}"/>
                    <ComboBox Style="{StaticResource CampoCombo}"
                              ItemsSource="{Binding Operaciones}"
                              DisplayMemberPath="NombreOperacion"
                              SelectedValuePath="IdOperacionTextil"
                              SelectedValue="{Binding IdOperacionMovimiento}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Descripción" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}"
                             Text="{Binding DescripcionMovimiento, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Text="Observación" Style="{StaticResource LabelCampo}"/>
                    <TextBox Style="{StaticResource CampoTexto}"
                             Text="{Binding ObservacionMovimiento, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom">
                    <Button Content="Guardar"
                            Style="{StaticResource BotonAccion}"
                            Command="{Binding GuardarMovimientoCommand}"/>
                    <Button Content="Eliminar"
                            Style="{StaticResource BotonAccion}"
                            Command="{Binding EliminarMovimientoCommand}"/>
                    <Button Content="Limpiar"
                            Style="{StaticResource BotonAccion}"
                            Command="{Binding LimpiarMovimientoCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CajaSeccion}">
            <StackPanel Orientation="Horizontal">
                <StackPanel Width="300" Margin="0,0,10,0">
                    <TextBlock Text="Filtro trabajador" Style="{StaticResource LabelCampo}"/>
                    <ComboBox Style="{StaticResource CampoCombo}"
                              ItemsSource="{Binding Trabajadores}"
                              DisplayMemberPath="NombreTrabajador"
                              SelectedValuePath="IdTrabajadorOperativo"
                              SelectedValue="{Binding IdTrabajadorFiltroMovimientos}"/>
                </StackPanel>
                <Button Content="Filtrar"
                        Style="{StaticResource BotonAccion}"
                        Command="{Binding FiltrarMovimientosCommand}"
                        VerticalAlignment="Bottom"/>
                <Button Content="Todos"
                        Style="{StaticResource BotonAccion}"
                        Command="{Binding LimpiarFiltroMovimientosCommand}"
                        VerticalAlignment="Bottom"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="3"
                  MinHeight="300"
                  MaxHeight="520"
                  ItemsSource="{Binding Movimientos}"
                  SelectedItem="{Binding MovimientoSeleccionado}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=d}" Width="95"/>
                <DataGridTextColumn Header="Trabajador" Binding="{Binding NombreTrabajador}" Width="180"/>
                <DataGridTextColumn Header="Concepto" Binding="{Binding NombreConcepto}" Width="150"/>
                <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="2.4*"/>
                <DataGridTextColumn Header="Cant." Binding="{Binding Cantidad, StringFormat={}{0:N2}}" Width="80"/>
                <DataGridTextColumn Header="Tarifa" Binding="{Binding Tarifa, StringFormat={}{0:N2}}" Width="80"/>
                <DataGridTextColumn Header="Importe" Binding="{Binding Importe, StringFormat={}{0:N2}}" Width="90"/>
                <DataGridCheckBoxColumn Header="Desc." Binding="{Binding EsDescuento}" Width="70"/>
                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                <DataGridTextColumn Header="Área" Binding="{Binding NombreArea}" Width="120"/>
                <DataGridTextColumn Header="Operación" Binding="{Binding NombreOperacion}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
