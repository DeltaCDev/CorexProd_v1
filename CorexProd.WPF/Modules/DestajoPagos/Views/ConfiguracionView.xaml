<UserControl x:Class="CorexProd.WPF.Modules.DestajoPagos.Views.ConfiguracionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="White">

    <UserControl.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>

        <Style x:Key="BotonAccion" TargetType="Button">
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="CajaSeccion" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E5E7EB"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E5E7EB"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="MinColumnWidth" Value="96"/>
            <Setter Property="ColumnWidth" Value="Auto"/>
            <Setter Property="ColumnHeaderHeight" Value="34"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="False"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderBrush" Value="#CBD5E1"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridCell}">
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                                <Setter Property="Foreground" Value="#111827"/>
                                <Setter Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridRow}">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                                <Setter Property="Foreground" Value="#111827"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <TabControl Margin="0,12,0,0">
            <TabItem Header="Trabajadores">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CajaSeccion}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.6*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Empleado" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding Empleados}"
                                          DisplayMemberPath="NombreCompleto"
                                          SelectedValuePath="IdEmpleado"
                                          SelectedValue="{Binding IdEmpleadoTrabajador}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Tipo" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding TiposTrabajador}"
                                          SelectedItem="{Binding TipoTrabajador}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Text="Medio" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding MediosPago}"
                                          SelectedItem="{Binding MedioPagoTrabajador}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                <TextBlock Text="Cuenta" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding NumeroCuentaTrabajador, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" Margin="0,0,10,0">
                                <TextBlock Text="Teléfono" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding TelefonoPagoTrabajador, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="5" Margin="0,0,10,0">
                                <TextBlock Text="Observación" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding ObservacionTrabajador, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="6"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <CheckBox Content="Activo"
                                          IsChecked="{Binding EstadoTrabajador}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"/>
                                <Button Content="Guardar"
                                        Style="{StaticResource BotonAccion}"
                                        Command="{Binding GuardarTrabajadorCommand}"/>
                                <Button Content="Eliminar"
                                        Style="{StaticResource BotonAccion}"
                                        Command="{Binding EliminarTrabajadorCommand}"/>
                                <Button Content="Limpiar"
                                        Style="{StaticResource BotonAccion}"
                                        Command="{Binding LimpiarTrabajadorCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Trabajadores}"
                              SelectedItem="{Binding TrabajadorSeleccionado}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              MinHeight="250">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Trabajador" Binding="{Binding NombreTrabajador}" Width="230"/>
                            <DataGridTextColumn Header="Documento" Binding="{Binding Documento}" Width="110"/>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding TipoTrabajador}" Width="145"/>
                            <DataGridTextColumn Header="Medio" Binding="{Binding MedioPagoPreferido}" Width="110"/>
                            <DataGridTextColumn Header="Cuenta" Binding="{Binding NumeroCuenta}" Width="160"/>
                            <DataGridTextColumn Header="Teléfono" Binding="{Binding TelefonoPago}" Width="120"/>
                            <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Estado}" Width="80"/>
                            <DataGridTextColumn Header="Observación" Binding="{Binding Observacion}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Conceptos">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CajaSeccion}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Código" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding CodigoConcepto, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Nombre" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding NombreConcepto, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Text="Tipo" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding TiposMovimiento}"
                                          SelectedItem="{Binding TipoMovimientoConcepto}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                <TextBlock Text="Categoría" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding CategoriasMovimiento}"
                                          SelectedItem="{Binding CategoriaMovimientoConcepto}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" Margin="0,0,10,0">
                                <TextBlock Text="Cálculo" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding TiposCalculo}"
                                          SelectedItem="{Binding TipoCalculoConcepto}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="5"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <CheckBox Content="Descuento"
                                          IsChecked="{Binding EsDescuentoConcepto}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"/>
                                <CheckBox Content="Activo"
                                          IsChecked="{Binding EstadoConcepto}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"/>
                                <Button Content="Guardar"
                                        Style="{StaticResource BotonAccion}"
                                        Command="{Binding GuardarConceptoCommand}"/>
                                <Button Content="Eliminar"
                                        Style="{StaticResource BotonAccion}"
                                        Command="{Binding EliminarConceptoCommand}"/>
                                <Button Content="Limpiar"
                                        Style="{StaticResource BotonAccion}"
                                        Command="{Binding LimpiarConceptoCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Conceptos}"
                              SelectedItem="{Binding ConceptoSeleccionado}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              MinHeight="250">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Código" Binding="{Binding CodigoConcepto}" Width="110"/>
                            <DataGridTextColumn Header="Concepto" Binding="{Binding NombreConcepto}" Width="220"/>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding TipoMovimiento}" Width="110"/>
                            <DataGridTextColumn Header="Categoría" Binding="{Binding CategoriaMovimiento}" Width="130"/>
                            <DataGridTextColumn Header="Cálculo" Binding="{Binding TipoCalculo}" Width="150"/>
                            <DataGridCheckBoxColumn Header="Descuento" Binding="{Binding EsDescuento}" Width="90"/>
                            <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Estado}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Áreas y operaciones">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.4*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CajaSeccion}">
                            <StackPanel>
                                <TextBlock Text="Área" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding NombreArea, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="Descripción" Style="{StaticResource LabelCampo}" Margin="0,10,0,4"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding DescripcionArea, UpdateSourceTrigger=PropertyChanged}"/>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <CheckBox Content="Activo"
                                              IsChecked="{Binding EstadoArea}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0"/>
                                    <Button Content="Guardar"
                                            Style="{StaticResource BotonAccion}"
                                            Command="{Binding GuardarAreaCommand}"/>
                                    <Button Content="Eliminar"
                                            Style="{StaticResource BotonAccion}"
                                            Command="{Binding EliminarAreaCommand}"/>
                                    <Button Content="Limpiar"
                                            Style="{StaticResource BotonAccion}"
                                            Command="{Binding LimpiarAreaCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Areas}"
                                  SelectedItem="{Binding AreaSeleccionada}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  MinHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Área" Binding="{Binding NombreArea}" Width="160"/>
                                <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                                <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Estado}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CajaSeccion}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.4*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Código" Style="{StaticResource LabelCampo}"/>
                                    <TextBox Style="{StaticResource CampoTexto}"
                                             Text="{Binding CodigoOperacion, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                    <TextBlock Text="Operación" Style="{StaticResource LabelCampo}"/>
                                    <TextBox Style="{StaticResource CampoTexto}"
                                             Text="{Binding NombreOperacion, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                    <TextBlock Text="Área" Style="{StaticResource LabelCampo}"/>
                                    <ComboBox Style="{StaticResource CampoCombo}"
                                              ItemsSource="{Binding Areas}"
                                              DisplayMemberPath="NombreArea"
                                              SelectedValuePath="IdAreaOperativa"
                                              SelectedValue="{Binding IdAreaOperacion}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                    <TextBlock Text="Tipo" Style="{StaticResource LabelCampo}"/>
                                    <ComboBox Style="{StaticResource CampoCombo}"
                                              ItemsSource="{Binding TiposOperacion}"
                                              SelectedItem="{Binding TipoOperacion}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4" Margin="0,0,10,0">
                                    <TextBlock Text="Tarifa" Style="{StaticResource LabelCampo}"/>
                                    <TextBox Style="{StaticResource CampoTexto}"
                                             Text="{Binding TarifaOperacion, UpdateSourceTrigger=LostFocus}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="5"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Bottom">
                                    <CheckBox Content="Activo"
                                              IsChecked="{Binding EstadoOperacion}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0"/>
                                    <Button Content="Guardar"
                                            Style="{StaticResource BotonAccion}"
                                            Command="{Binding GuardarOperacionCommand}"/>
                                    <Button Content="Eliminar"
                                            Style="{StaticResource BotonAccion}"
                                            Command="{Binding EliminarOperacionCommand}"/>
                                    <Button Content="Limpiar"
                                            Style="{StaticResource BotonAccion}"
                                            Command="{Binding LimpiarOperacionCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Operaciones}"
                                  SelectedItem="{Binding OperacionSeleccionada}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  MinHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Código" Binding="{Binding CodigoOperacion}" Width="95"/>
                                <DataGridTextColumn Header="Operación" Binding="{Binding NombreOperacion}" Width="190"/>
                                <DataGridTextColumn Header="Área" Binding="{Binding NombreArea}" Width="120"/>
                                <DataGridTextColumn Header="Tipo" Binding="{Binding TipoOperacion}" Width="120"/>
                                <DataGridTextColumn Header="Unidad" Binding="{Binding UnidadMedida}" Width="80"/>
                                <DataGridTextColumn Header="Tarifa" Binding="{Binding TarifaBase, StringFormat={}{0:N2}}" Width="90"/>
                                <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Estado}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>