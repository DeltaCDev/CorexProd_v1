<UserControl x:Class="CorexProd.WPF.Modules.DestajoPagos.Views.DestajoPagosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>

        <Style x:Key="BotonAccion" TargetType="Button">
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="CajaSeccion" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E5E7EB"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E5E7EB"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="MinColumnWidth" Value="96"/>
            <Setter Property="ColumnWidth" Value="Auto"/>
            <Setter Property="ColumnHeaderHeight" Value="34"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="False"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderBrush" Value="#CBD5E1"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridCell}">
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                                <Setter Property="Foreground" Value="#111827"/>
                                <Setter Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridRow}">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                                <Setter Property="Foreground" Value="#111827"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">
        <Grid Margin="18"
              MinWidth="1120">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CajaSeccion}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Control de Destajo y Pagos Operativos"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding EstadoPeriodo}"
                               Foreground="#2563EB"
                               FontWeight="SemiBold"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="20,0,20,0">
                    <TextBlock Text="Periodo" Style="{StaticResource LabelCampo}"/>
                    <ComboBox Style="{StaticResource CampoCombo}"
                              ItemsSource="{Binding Periodos}"
                              SelectedItem="{Binding PeriodoSeleccionado}"
                              DisplayMemberPath="CodigoPeriodo"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Actualizar"
                        Style="{StaticResource BotonAccion}"
                        Command="{Binding RefrescarCommand}"
                        VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs"
                    Grid.Row="1">
            <TabItem Header="Periodos">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CajaSeccion}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="1.6*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Código" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding CodigoPeriodo, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Inicio" Style="{StaticResource LabelCampo}"/>
                                <DatePicker Height="30"
                                            SelectedDate="{Binding FechaInicioPeriodo}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                <TextBlock Text="Fin" Style="{StaticResource LabelCampo}"/>
                                <DatePicker Height="30"
                                            SelectedDate="{Binding FechaFinPeriodo}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,12,0">
                                <TextBlock Text="Estado" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding EstadosPeriodo}"
                                          SelectedItem="{Binding EstadoPeriodo}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" Margin="0,0,12,0">
                                <TextBlock Text="Observación" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding ObservacionPeriodo, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="5"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <Button Content="Guardar"
                                        Style="{StaticResource BotonAccion}"
                                        Command="{Binding GuardarPeriodoCommand}"/>
                                <Button Content="Limpiar"
                                        Style="{StaticResource BotonAccion}"
                                        Command="{Binding LimpiarPeriodoCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <Button Content="Enviar"
                                    Style="{StaticResource BotonAccion}"
                                    Command="{Binding CambiarEstadoPeriodoCommand}"
                                    CommandParameter="Enviado a contabilidad"/>
                            <Button Content="Observado"
                                    Style="{StaticResource BotonAccion}"
                                    Command="{Binding CambiarEstadoPeriodoCommand}"
                                    CommandParameter="Observado"/>
                            <Button Content="Corregido"
                                    Style="{StaticResource BotonAccion}"
                                    Command="{Binding CambiarEstadoPeriodoCommand}"
                                    CommandParameter="Corregido"/>
                            <Button Content="Aprobar"
                                    Style="{StaticResource BotonAccion}"
                                    Command="{Binding CambiarEstadoPeriodoCommand}"
                                    CommandParameter="Aprobado"/>
                            <Button Content="Pagado"
                                    Style="{StaticResource BotonAccion}"
                                    Command="{Binding CambiarEstadoPeriodoCommand}"
                                    CommandParameter="Pagado"/>
                            <Button Content="Cerrar"
                                    Style="{StaticResource BotonAccion}"
                                    Command="{Binding CambiarEstadoPeriodoCommand}"
                                    CommandParameter="Cerrado"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Periodos}"
                                  SelectedItem="{Binding PeriodoSeleccionado}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Periodo" Binding="{Binding CodigoPeriodo}" Width="130"/>
                                <DataGridTextColumn Header="Inicio" Binding="{Binding FechaInicio, StringFormat=d}" Width="110"/>
                                <DataGridTextColumn Header="Fin" Binding="{Binding FechaFin, StringFormat=d}" Width="110"/>
                                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="170"/>
                                <DataGridTextColumn Header="Ingresos" Binding="{Binding TotalIngresos, StringFormat={}{0:N2}}" Width="110"/>
                                <DataGridTextColumn Header="Descuentos" Binding="{Binding TotalDescuentos, StringFormat={}{0:N2}}" Width="110"/>
                                <DataGridTextColumn Header="Neto" Binding="{Binding NetoCalculado, StringFormat={}{0:N2}}" Width="110"/>
                                <DataGridTextColumn Header="Pagado" Binding="{Binding TotalPagado, StringFormat={}{0:N2}}" Width="110"/>
                                <DataGridTextColumn Header="Saldo" Binding="{Binding SaldoPendiente, StringFormat={}{0:N2}}" Width="110"/>
                                <DataGridTextColumn Header="Observación" Binding="{Binding Observacion}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Movimientos">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CajaSeccion}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                                <TextBlock Text="Fecha" Style="{StaticResource LabelCampo}"/>
                                <DatePicker Height="30"
                                            SelectedDate="{Binding FechaMovimiento}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,10">
                                <TextBlock Text="Trabajador" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding Trabajadores}"
                                          DisplayMemberPath="NombreTrabajador"
                                          SelectedValuePath="IdTrabajadorOperativo"
                                          SelectedValue="{Binding IdTrabajadorMovimiento}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,10,10">
                                <TextBlock Text="Concepto" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding Conceptos}"
                                          DisplayMemberPath="NombreConcepto"
                                          SelectedValuePath="IdConceptoMovimiento"
                                          SelectedValue="{Binding IdConceptoMovimientoForm}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,10,10">
                                <TextBlock Text="Tipo" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding TiposMovimiento}"
                                          SelectedItem="{Binding TipoMovimientoForm}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,10,10">
                                <TextBlock Text="Categoría" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding CategoriasMovimiento}"
                                          SelectedItem="{Binding CategoriaMovimientoForm}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="5" Margin="0,0,0,10">
                                <TextBlock Text="Estado" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding EstadosMovimiento}"
                                          SelectedItem="{Binding EstadoMovimiento}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Cantidad" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding CantidadMovimiento, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Unidad" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding UnidadMovimiento, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Text="Tarifa" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding TarifaMovimiento, UpdateSourceTrigger=LostFocus}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,10,0">
                                <TextBlock Text="Importe" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding ImporteMovimiento, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,0,10,0">
                                <TextBlock Text="Total" Style="{StaticResource LabelCampo}"/>
                                <TextBlock Text="{Binding TotalMovimientoCalculado, StringFormat={}{0:N2}}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <CheckBox Grid.Row="1"
                                      Grid.Column="5"
                                      Content="Descuento"
                                      IsChecked="{Binding EsDescuentoMovimiento}"
                                      VerticalAlignment="Center"
                                      Margin="0,18,0,0"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CajaSeccion}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.9*"/>
                                <ColumnDefinition Width="0.9*"/>
                                <ColumnDefinition Width="3.2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Área" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding Areas}"
                                          DisplayMemberPath="NombreArea"
                                          SelectedValuePath="IdAreaOperativa"
                                          SelectedValue="{Binding IdAreaMovimiento}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Operación" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding Operaciones}"
                                          DisplayMemberPath="NombreOperacion"
                                          SelectedValuePath="IdOperacionTextil"
                                          SelectedValue="{Binding IdOperacionMovimiento}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Text="Descripción" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding DescripcionMovimiento, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                <TextBlock Text="Observación" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding ObservacionMovimiento, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <Button Content="Guardar"
                                        Style="{StaticResource BotonAccion}"
                                        Command="{Binding GuardarMovimientoCommand}"/>
                                <Button Content="Eliminar"
                                        Style="{StaticResource BotonAccion}"
                                        Command="{Binding EliminarMovimientoCommand}"/>
                                <Button Content="Limpiar"
                                        Style="{StaticResource BotonAccion}"
                                        Command="{Binding LimpiarMovimientoCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="2"
                              MinHeight="300"
                              MaxHeight="520"
                              ItemsSource="{Binding Movimientos}"
                              SelectedItem="{Binding MovimientoSeleccionado}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=d}" Width="95"/>
                            <DataGridTextColumn Header="Trabajador" Binding="{Binding NombreTrabajador}" Width="180"/>
                            <DataGridTextColumn Header="Concepto" Binding="{Binding NombreConcepto}" Width="150"/>
                            <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="2.4*"/>
                            <DataGridTextColumn Header="Cant." Binding="{Binding Cantidad, StringFormat={}{0:N2}}" Width="80"/>
                            <DataGridTextColumn Header="Tarifa" Binding="{Binding Tarifa, StringFormat={}{0:N2}}" Width="80"/>
                            <DataGridTextColumn Header="Importe" Binding="{Binding Importe, StringFormat={}{0:N2}}" Width="90"/>
                            <DataGridCheckBoxColumn Header="Desc." Binding="{Binding EsDescuento}" Width="70"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                            <DataGridTextColumn Header="Área" Binding="{Binding NombreArea}" Width="120"/>
                            <DataGridTextColumn Header="Operación" Binding="{Binding NombreOperacion}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Préstamos y cuotas">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CajaSeccion}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="1.6*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Trabajador" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding Trabajadores}"
                                          DisplayMemberPath="NombreTrabajador"
                                          SelectedValuePath="IdTrabajadorOperativo"
                                          SelectedValue="{Binding IdTrabajadorPrestamo}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Fecha" Style="{StaticResource LabelCampo}"/>
                                <DatePicker Height="30"
                                            SelectedDate="{Binding FechaPrestamo}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Text="Monto" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding MontoPrestamo, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                <TextBlock Text="Cuotas" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding NumeroCuotasPrestamo, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" Margin="0,0,10,0">
                                <TextBlock Text="Monto cuota" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding MontoCuotaPrestamo, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="5" Margin="0,0,10,0">
                                <TextBlock Text="Concepto cuota" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding ConceptosDescuento}"
                                          DisplayMemberPath="NombreConcepto"
                                          SelectedValuePath="IdConceptoMovimiento"
                                          SelectedValue="{Binding IdConceptoCuota}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="6" Margin="0,0,10,0">
                                <TextBlock Text="Observación" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding ObservacionPrestamo, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="7"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <Button Content="Registrar"
                                        Style="{StaticResource BotonAccion}"
                                        Command="{Binding RegistrarPrestamoCommand}"/>
                                <Button Content="Limpiar"
                                        Style="{StaticResource BotonAccion}"
                                        Command="{Binding LimpiarPrestamoCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Prestamos}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Trabajador" Binding="{Binding NombreTrabajador}" Width="210"/>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding FechaPrestamo, StringFormat=d}" Width="100"/>
                            <DataGridTextColumn Header="Monto" Binding="{Binding MontoTotal, StringFormat={}{0:N2}}" Width="100"/>
                            <DataGridTextColumn Header="Cuotas" Binding="{Binding NumeroCuotas}" Width="80"/>
                            <DataGridTextColumn Header="Monto cuota" Binding="{Binding MontoCuota, StringFormat={}{0:N2}}" Width="100"/>
                            <DataGridTextColumn Header="Saldo" Binding="{Binding SaldoPendiente, StringFormat={}{0:N2}}" Width="100"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="110"/>
                            <DataGridTextColumn Header="Observación" Binding="{Binding Observacion}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <ComboBox Width="260"
                                      Style="{StaticResource CampoCombo}"
                                      ItemsSource="{Binding Trabajadores}"
                                      DisplayMemberPath="NombreTrabajador"
                                      SelectedValuePath="IdTrabajadorOperativo"
                                      SelectedValue="{Binding IdTrabajadorFiltroCuotas}"/>
                            <Button Content="Filtrar"
                                    Style="{StaticResource BotonAccion}"
                                    Command="{Binding FiltrarCuotasCommand}"
                                    Margin="10,0,8,0"/>
                            <Button Content="Aplicar al periodo"
                                    Style="{StaticResource BotonAccion}"
                                    Command="{Binding AplicarCuotaCommand}"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Cuotas}"
                                  SelectedItem="{Binding CuotaSeleccionada}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Trabajador" Binding="{Binding NombreTrabajador}" Width="190"/>
                                <DataGridTextColumn Header="Origen" Binding="{Binding TipoOrigen}" Width="100"/>
                                <DataGridTextColumn Header="Concepto" Binding="{Binding NombreConcepto}" Width="160"/>
                                <DataGridTextColumn Header="Cuota" Binding="{Binding NumeroCuota}" Width="70"/>
                                <DataGridTextColumn Header="Total" Binding="{Binding TotalCuotas}" Width="70"/>
                                <DataGridTextColumn Header="Monto" Binding="{Binding MontoCuota, StringFormat={}{0:N2}}" Width="90"/>
                                <DataGridTextColumn Header="Fecha" Binding="{Binding FechaProgramada, StringFormat=d}" Width="100"/>
                                <DataGridTextColumn Header="Periodo" Binding="{Binding CodigoPeriodoAplicado}" Width="110"/>
                                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="110"/>
                                <DataGridTextColumn Header="Observación" Binding="{Binding Observacion}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Lotes de pago">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CajaSeccion}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="2.2*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Medio" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding MediosPago}"
                                          SelectedItem="{Binding MedioPagoLote}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Estado" Style="{StaticResource LabelCampo}"/>
                                <ComboBox Style="{StaticResource CampoCombo}"
                                          ItemsSource="{Binding EstadosLote}"
                                          SelectedItem="{Binding EstadoLote}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Text="Observación" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding ObservacionLote, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <Button Content="Generar lote"
                                        Style="{StaticResource BotonAccion}"
                                        Command="{Binding GenerarLoteCommand}"/>
                                <Button Content="Actualizar estado"
                                        Style="{StaticResource BotonAccion}"
                                        Command="{Binding CambiarEstadoLoteCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Lotes}"
                              SelectedItem="{Binding LoteSeleccionado}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Periodo" Binding="{Binding CodigoPeriodo}" Width="120"/>
                            <DataGridTextColumn Header="Medio" Binding="{Binding MedioPago}" Width="120"/>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding FechaGeneracion, StringFormat=g}" Width="145"/>
                            <DataGridTextColumn Header="Usuario" Binding="{Binding UsuarioGenerador}" Width="120"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="110"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalLote, StringFormat={}{0:N2}}" Width="110"/>
                            <DataGridTextColumn Header="Observación" Binding="{Binding Observacion}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding LoteDetalles}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Trabajador" Binding="{Binding NombreTrabajador}" Width="230"/>
                            <DataGridTextColumn Header="Monto" Binding="{Binding MontoPago, StringFormat={}{0:N2}}" Width="110"/>
                            <DataGridTextColumn Header="Medio" Binding="{Binding MedioPago}" Width="120"/>
                            <DataGridTextColumn Header="Cuenta" Binding="{Binding NumeroCuenta}" Width="170"/>
                            <DataGridTextColumn Header="Teléfono" Binding="{Binding TelefonoPago}" Width="120"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Reportes">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0"
                                 Columns="5"
                                 Margin="0,0,0,12">
                        <Border Style="{StaticResource CajaSeccion}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Ingresos" Foreground="#64748B"/>
                                <TextBlock Text="{Binding TotalIngresosPeriodo, StringFormat={}{0:N2}}" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CajaSeccion}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Descuentos" Foreground="#64748B"/>
                                <TextBlock Text="{Binding TotalDescuentosPeriodo, StringFormat={}{0:N2}}" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CajaSeccion}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Neto" Foreground="#64748B"/>
                                <TextBlock Text="{Binding NetoPeriodo, StringFormat={}{0:N2}}" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CajaSeccion}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Pagado" Foreground="#64748B"/>
                                <TextBlock Text="{Binding TotalPagadoPeriodo, StringFormat={}{0:N2}}" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CajaSeccion}">
                            <StackPanel>
                                <TextBlock Text="Saldo" Foreground="#64748B"/>
                                <TextBlock Text="{Binding SaldoPendientePeriodo, StringFormat={}{0:N2}}" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <Button Content="Boletas seleccionadas"
                                Style="{StaticResource BotonAccion}"
                                Command="{Binding DescargarBoletasSeleccionadasCommand}"
                                CommandParameter="{Binding SelectedItems, ElementName=ResumenesGrid}"/>
                        <Button Content="Todas las boletas"
                                Style="{StaticResource BotonAccion}"
                                Command="{Binding DescargarTodasBoletasCommand}"/>
                    </StackPanel>

                    <DataGrid x:Name="ResumenesGrid"
                              Grid.Row="2"
                              ItemsSource="{Binding Resumenes}"
                              SelectedItem="{Binding ResumenSeleccionado}"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Trabajador" Binding="{Binding NombreTrabajador}" Width="230"/>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding TipoTrabajador}" Width="140"/>
                            <DataGridTextColumn Header="Medio" Binding="{Binding MedioPagoPreferido}" Width="110"/>
                            <DataGridTextColumn Header="Saldo anterior" Binding="{Binding SaldoAnterior, StringFormat={}{0:N2}}" Width="120"/>
                            <DataGridTextColumn Header="Ingresos" Binding="{Binding TotalIngresos, StringFormat={}{0:N2}}" Width="110"/>
                            <DataGridTextColumn Header="Descuentos" Binding="{Binding TotalDescuentos, StringFormat={}{0:N2}}" Width="115"/>
                            <DataGridTextColumn Header="Neto" Binding="{Binding NetoCalculado, StringFormat={}{0:N2}}" Width="100"/>
                            <DataGridTextColumn Header="Pagado" Binding="{Binding TotalPagado, StringFormat={}{0:N2}}" Width="100"/>
                            <DataGridTextColumn Header="Saldo" Binding="{Binding SaldoPendiente, StringFormat={}{0:N2}}" Width="100"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding EstadoPeriodo}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Configuración">
                <TabControl Margin="0,12,0,0">
                    <TabItem Header="Trabajadores">
                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource CajaSeccion}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.6*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Empleado" Style="{StaticResource LabelCampo}"/>
                                        <ComboBox Style="{StaticResource CampoCombo}"
                                                  ItemsSource="{Binding Empleados}"
                                                  DisplayMemberPath="NombreCompleto"
                                                  SelectedValuePath="IdEmpleado"
                                                  SelectedValue="{Binding IdEmpleadoTrabajador}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                        <TextBlock Text="Tipo" Style="{StaticResource LabelCampo}"/>
                                        <ComboBox Style="{StaticResource CampoCombo}"
                                                  ItemsSource="{Binding TiposTrabajador}"
                                                  SelectedItem="{Binding TipoTrabajador}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                        <TextBlock Text="Medio" Style="{StaticResource LabelCampo}"/>
                                        <ComboBox Style="{StaticResource CampoCombo}"
                                                  ItemsSource="{Binding MediosPago}"
                                                  SelectedItem="{Binding MedioPagoTrabajador}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                        <TextBlock Text="Cuenta" Style="{StaticResource LabelCampo}"/>
                                        <TextBox Style="{StaticResource CampoTexto}"
                                                 Text="{Binding NumeroCuentaTrabajador, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4" Margin="0,0,10,0">
                                        <TextBlock Text="Teléfono" Style="{StaticResource LabelCampo}"/>
                                        <TextBox Style="{StaticResource CampoTexto}"
                                                 Text="{Binding TelefonoPagoTrabajador, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="5" Margin="0,0,10,0">
                                        <TextBlock Text="Observación" Style="{StaticResource LabelCampo}"/>
                                        <TextBox Style="{StaticResource CampoTexto}"
                                                 Text="{Binding ObservacionTrabajador, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="6"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Bottom">
                                        <CheckBox Content="Activo"
                                                  IsChecked="{Binding EstadoTrabajador}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,12,0"/>
                                        <Button Content="Guardar"
                                                Style="{StaticResource BotonAccion}"
                                                Command="{Binding GuardarTrabajadorCommand}"/>
                                        <Button Content="Eliminar"
                                                Style="{StaticResource BotonAccion}"
                                                Command="{Binding EliminarTrabajadorCommand}"/>
                                        <Button Content="Limpiar"
                                                Style="{StaticResource BotonAccion}"
                                                Command="{Binding LimpiarTrabajadorCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding Trabajadores}"
                                      SelectedItem="{Binding TrabajadorSeleccionado}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Trabajador" Binding="{Binding NombreTrabajador}" Width="230"/>
                                    <DataGridTextColumn Header="Documento" Binding="{Binding Documento}" Width="110"/>
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding TipoTrabajador}" Width="145"/>
                                    <DataGridTextColumn Header="Medio" Binding="{Binding MedioPagoPreferido}" Width="110"/>
                                    <DataGridTextColumn Header="Cuenta" Binding="{Binding NumeroCuenta}" Width="160"/>
                                    <DataGridTextColumn Header="Teléfono" Binding="{Binding TelefonoPago}" Width="120"/>
                                    <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Estado}" Width="80"/>
                                    <DataGridTextColumn Header="Observación" Binding="{Binding Observacion}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Conceptos">
                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource CajaSeccion}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1.1*"/>
                                        <ColumnDefinition Width="1.1*"/>
                                        <ColumnDefinition Width="1.1*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Código" Style="{StaticResource LabelCampo}"/>
                                        <TextBox Style="{StaticResource CampoTexto}"
                                                 Text="{Binding CodigoConcepto, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                        <TextBlock Text="Nombre" Style="{StaticResource LabelCampo}"/>
                                        <TextBox Style="{StaticResource CampoTexto}"
                                                 Text="{Binding NombreConcepto, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                        <TextBlock Text="Tipo" Style="{StaticResource LabelCampo}"/>
                                        <ComboBox Style="{StaticResource CampoCombo}"
                                                  ItemsSource="{Binding TiposMovimiento}"
                                                  SelectedItem="{Binding TipoMovimientoConcepto}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                        <TextBlock Text="Categoría" Style="{StaticResource LabelCampo}"/>
                                        <ComboBox Style="{StaticResource CampoCombo}"
                                                  ItemsSource="{Binding CategoriasMovimiento}"
                                                  SelectedItem="{Binding CategoriaMovimientoConcepto}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4" Margin="0,0,10,0">
                                        <TextBlock Text="Cálculo" Style="{StaticResource LabelCampo}"/>
                                        <ComboBox Style="{StaticResource CampoCombo}"
                                                  ItemsSource="{Binding TiposCalculo}"
                                                  SelectedItem="{Binding TipoCalculoConcepto}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="5"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Bottom">
                                        <CheckBox Content="Descuento"
                                                  IsChecked="{Binding EsDescuentoConcepto}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,12,0"/>
                                        <CheckBox Content="Activo"
                                                  IsChecked="{Binding EstadoConcepto}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,12,0"/>
                                        <Button Content="Guardar"
                                                Style="{StaticResource BotonAccion}"
                                                Command="{Binding GuardarConceptoCommand}"/>
                                        <Button Content="Eliminar"
                                                Style="{StaticResource BotonAccion}"
                                                Command="{Binding EliminarConceptoCommand}"/>
                                        <Button Content="Limpiar"
                                                Style="{StaticResource BotonAccion}"
                                                Command="{Binding LimpiarConceptoCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding Conceptos}"
                                      SelectedItem="{Binding ConceptoSeleccionado}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Código" Binding="{Binding CodigoConcepto}" Width="110"/>
                                    <DataGridTextColumn Header="Concepto" Binding="{Binding NombreConcepto}" Width="220"/>
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding TipoMovimiento}" Width="110"/>
                                    <DataGridTextColumn Header="Categoría" Binding="{Binding CategoriaMovimiento}" Width="130"/>
                                    <DataGridTextColumn Header="Cálculo" Binding="{Binding TipoCalculo}" Width="150"/>
                                    <DataGridCheckBoxColumn Header="Descuento" Binding="{Binding EsDescuento}" Width="90"/>
                                    <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Estado}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Áreas y operaciones">
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.4*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="0,0,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource CajaSeccion}">
                                    <StackPanel>
                                        <TextBlock Text="Área" Style="{StaticResource LabelCampo}"/>
                                        <TextBox Style="{StaticResource CampoTexto}"
                                                 Text="{Binding NombreArea, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Text="Descripción" Style="{StaticResource LabelCampo}" Margin="0,10,0,4"/>
                                        <TextBox Style="{StaticResource CampoTexto}"
                                                 Text="{Binding DescripcionArea, UpdateSourceTrigger=PropertyChanged}"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <CheckBox Content="Activo"
                                                      IsChecked="{Binding EstadoArea}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                                            <Button Content="Guardar"
                                                    Style="{StaticResource BotonAccion}"
                                                    Command="{Binding GuardarAreaCommand}"/>
                                            <Button Content="Eliminar"
                                                    Style="{StaticResource BotonAccion}"
                                                    Command="{Binding EliminarAreaCommand}"/>
                                            <Button Content="Limpiar"
                                                    Style="{StaticResource BotonAccion}"
                                                    Command="{Binding LimpiarAreaCommand}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding Areas}"
                                          SelectedItem="{Binding AreaSeleccionada}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Área" Binding="{Binding NombreArea}" Width="160"/>
                                        <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                                        <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Estado}" Width="70"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource CajaSeccion}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1.4*"/>
                                            <ColumnDefinition Width="1.1*"/>
                                            <ColumnDefinition Width="1.1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="Código" Style="{StaticResource LabelCampo}"/>
                                            <TextBox Style="{StaticResource CampoTexto}"
                                                     Text="{Binding CodigoOperacion, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                            <TextBlock Text="Operación" Style="{StaticResource LabelCampo}"/>
                                            <TextBox Style="{StaticResource CampoTexto}"
                                                     Text="{Binding NombreOperacion, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                            <TextBlock Text="Área" Style="{StaticResource LabelCampo}"/>
                                            <ComboBox Style="{StaticResource CampoCombo}"
                                                      ItemsSource="{Binding Areas}"
                                                      DisplayMemberPath="NombreArea"
                                                      SelectedValuePath="IdAreaOperativa"
                                                      SelectedValue="{Binding IdAreaOperacion}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                            <TextBlock Text="Tipo" Style="{StaticResource LabelCampo}"/>
                                            <ComboBox Style="{StaticResource CampoCombo}"
                                                      ItemsSource="{Binding TiposOperacion}"
                                                      SelectedItem="{Binding TipoOperacion}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4" Margin="0,0,10,0">
                                            <TextBlock Text="Tarifa" Style="{StaticResource LabelCampo}"/>
                                            <TextBox Style="{StaticResource CampoTexto}"
                                                     Text="{Binding TarifaOperacion, UpdateSourceTrigger=LostFocus}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="5"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Bottom">
                                            <CheckBox Content="Activo"
                                                      IsChecked="{Binding EstadoOperacion}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                                            <Button Content="Guardar"
                                                    Style="{StaticResource BotonAccion}"
                                                    Command="{Binding GuardarOperacionCommand}"/>
                                            <Button Content="Eliminar"
                                                    Style="{StaticResource BotonAccion}"
                                                    Command="{Binding EliminarOperacionCommand}"/>
                                            <Button Content="Limpiar"
                                                    Style="{StaticResource BotonAccion}"
                                                    Command="{Binding LimpiarOperacionCommand}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding Operaciones}"
                                          SelectedItem="{Binding OperacionSeleccionada}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Código" Binding="{Binding CodigoOperacion}" Width="95"/>
                                        <DataGridTextColumn Header="Operación" Binding="{Binding NombreOperacion}" Width="190"/>
                                        <DataGridTextColumn Header="Área" Binding="{Binding NombreArea}" Width="120"/>
                                        <DataGridTextColumn Header="Tipo" Binding="{Binding TipoOperacion}" Width="120"/>
                                        <DataGridTextColumn Header="Unidad" Binding="{Binding UnidadMedida}" Width="80"/>
                                        <DataGridTextColumn Header="Tarifa" Binding="{Binding TarifaBase, StringFormat={}{0:N2}}" Width="90"/>
                                        <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Estado}" Width="70"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>
        </TabControl>
        </Grid>
    </ScrollViewer>
</UserControl>
