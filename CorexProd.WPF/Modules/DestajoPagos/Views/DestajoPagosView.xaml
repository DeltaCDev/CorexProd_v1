<UserControl x:Class="CorexProd.WPF.Modules.DestajoPagos.Views.DestajoPagosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vistas="clr-namespace:CorexProd.WPF.Modules.DestajoPagos.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="White">

    <UserControl.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>
        <Style x:Key="BotonAccion" TargetType="Button">
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>
        <Style x:Key="CajaSeccion" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="18" MinWidth="1120">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CajaSeccion}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding EstadoPeriodo}"
                                   Foreground="#2563EB" FontWeight="SemiBold"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="20,0,20,0">
                        <TextBlock Text="Periodo" Style="{StaticResource LabelCampo}"/>
                        <ComboBox Style="{StaticResource CampoCombo}"
                                  ItemsSource="{Binding Periodos}"
                                  SelectedItem="{Binding PeriodoSeleccionado}"
                                  DisplayMemberPath="CodigoPeriodo"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="Actualizar"
                            Style="{StaticResource BotonAccion}"
                            Command="{Binding RefrescarCommand}"
                            VerticalAlignment="Bottom"/>
                </Grid>
            </Border>

            <ContentControl x:Name="ModuleContent" Grid.Row="1"/>
        </Grid>
    </ScrollViewer>
</UserControl>
