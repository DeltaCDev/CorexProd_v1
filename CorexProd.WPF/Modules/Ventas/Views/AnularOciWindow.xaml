<Window x:Class="CorexProd.WPF.Modules.Ventas.Views.AnularOciWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anular OCI"
        Width="460"
        Height="290"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F4F6">
    <Window.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="BotonDialogo" TargetType="Button">
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Anular orden de compra interna" FontSize="22" FontWeight="Bold" Foreground="#111827"/>
            <TextBlock x:Name="NumeroOciTextBlock" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>
        <Border Grid.Row="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="16">
            <StackPanel>
                <TextBlock Style="{StaticResource LabelCampo}">
                    <Run Text="Motivo de anulación "/>
                    <Run Text="*" Foreground="#DC2626"/>
                </TextBlock>
                <TextBox x:Name="MotivoTextBox" Height="92" MaxLength="500" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Padding="8" VerticalContentAlignment="Top"/>
                <TextBlock x:Name="ErrorTextBlock" Foreground="#DC2626" FontSize="12" Margin="0,8,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancelar" Style="{StaticResource BotonDialogo}" IsCancel="True"/>
            <Button Content="Confirmar" Style="{StaticResource BotonDialogo}" Background="#BE123C"
                    BorderBrush="#BE123C" Foreground="White" Click="Confirmar_Click"/>
        </StackPanel>
    </Grid>
</Window>
