<Window x:Class="CorexProd.WPF.Modules.Ventas.Views.GuiaInternaEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva Guía Interna" Width="1080" Height="700" WindowStartupLocation="CenterOwner"
        MinWidth="940" MinHeight="600" Background="#F8FAFC">
    <Window.Resources>
        <Style x:Key="Etiqueta" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/><Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="Campo" TargetType="Control">
            <Setter Property="Height" Value="34"/><Setter Property="Margin" Value="0,0,14,0"/>
        </Style>
        <Style x:Key="SoloLectura" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="Boton" TargetType="Button">
            <Setter Property="Height" Value="38"/><Setter Property="MinWidth" Value="120"/><Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="8,0,0,0"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="430"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Nueva Guía Interna" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Salida de productos vinculada a una orden de compra interna" Foreground="#64748B" Margin="0,5,0,0"/>
            </StackPanel>
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                <StackPanel Margin="0,0,12,0"><TextBlock Text="EMITIDO POR" Style="{StaticResource Etiqueta}"/><TextBlock x:Name="EmisorText" Style="{StaticResource SoloLectura}"/></StackPanel>
                <StackPanel Grid.Column="1"><TextBlock Text="AUTORIZADO POR" Style="{StaticResource Etiqueta}"/><ComboBox x:Name="AutorizadorCombo" Style="{StaticResource Campo}" DisplayMemberPath="NombreEmpleado"/></StackPanel>
            </Grid>
        </Grid>
        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,18,0,12">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="ORIGEN" Style="{StaticResource Etiqueta}"/><TextBlock Text="OCI" Style="{StaticResource SoloLectura}"/></StackPanel>
                <StackPanel Grid.Column="1"><TextBlock Text="NÚMERO OCI" Style="{StaticResource Etiqueta}"/><TextBlock Text="{Binding NumeroOci}" Style="{StaticResource SoloLectura}"/></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="ALMACÉN" Style="{StaticResource Etiqueta}"/><ComboBox x:Name="AlmacenCombo" Style="{StaticResource Campo}" DisplayMemberPath="NombreAlmacen" SelectionChanged="AlmacenCombo_SelectionChanged"/></StackPanel>
                <StackPanel Grid.Column="3"><TextBlock Text="FECHA DE EMISIÓN" Style="{StaticResource Etiqueta}"/><DatePicker SelectedDate="{Binding FechaEmision}" Style="{StaticResource Campo}"/></StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="2" Background="#F0FDFA" BorderBrush="#99F6E4" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="EMPRESA EMISORA" Style="{StaticResource Etiqueta}"/><TextBlock Text="{Binding EmpresaEmisora}" Style="{StaticResource SoloLectura}"/></StackPanel>
                <StackPanel Grid.Column="1"><TextBlock Text="RUC EMISOR" Style="{StaticResource Etiqueta}"/><TextBlock Text="{Binding RucEmisor}" Style="{StaticResource SoloLectura}"/></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="EMPRESA DESTINO" Style="{StaticResource Etiqueta}"/><TextBlock Text="{Binding EmpresaDestino}" Style="{StaticResource SoloLectura}"/></StackPanel>
                <StackPanel Grid.Column="3"><TextBlock Text="RUC DESTINO" Style="{StaticResource Etiqueta}"/><TextBlock Text="{Binding RucDestino}" Style="{StaticResource SoloLectura}"/></StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="3" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10">
            <DataGrid x:Name="DetallesGrid" ItemsSource="{Binding Detalles}" AutoGenerateColumns="False" CanUserAddRows="False"
                      GridLinesVisibility="Horizontal" RowHeight="44" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Producto" Binding="{Binding NombreProducto}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Unidad" Binding="{Binding NombreUnidad}" Width="80" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Requerido" Binding="{Binding CantidadRequerida, StringFormat=N2}" Width="82" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Pendiente" Binding="{Binding CantidadPendiente, StringFormat=N2}" Width="82" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Stock" Binding="{Binding StockActual, StringFormat=N2}" Width="75" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="A despachar" Width="100">
                        <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBox Text="{Binding CantidadDespachar, UpdateSourceTrigger=PropertyChanged}" Padding="6,3" HorizontalContentAlignment="Right"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Estado" Binding="{Binding EstadoDespacho}" Width="85" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="Observación" Width="180">
                        <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBox Text="{Binding Observacion, UpdateSourceTrigger=PropertyChanged}" Padding="6,3"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <Grid Grid.Row="4" Margin="0,14,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="360"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel><TextBlock Text="OBSERVACIÓN GENERAL" Style="{StaticResource Etiqueta}"/><TextBox Text="{Binding Observacion, UpdateSourceTrigger=PropertyChanged}" Height="38" Padding="8"/></StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Content="Volver" Style="{StaticResource Boton}" Click="Volver_Click" Background="White" BorderBrush="#CBD5E1"/>
                <Button Content="Emitir guía" Style="{StaticResource Boton}" Click="Emitir_Click" Background="#0F766E" BorderBrush="#0F766E" Foreground="White"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
