<Window x:Class="CorexProd.WPF.Modules.Ventas.Views.GuiaInternaPreviaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vista previa de Guía Interna" Width="1280" Height="700"
        WindowStartupLocation="CenterOwner" MinWidth="1100" MinHeight="600" Background="#F1F5F9">
    <Window.Resources>
        <Style x:Key="Dato" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/><Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style x:Key="Etiqueta" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/><Setter Property="Foreground" Value="#64748B"/>
        </Style>
        <Style x:Key="Boton" TargetType="Button">
            <Setter Property="Height" Value="38"/><Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="18,0"/><Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Productos listos para despacho" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Comprueba cantidades y disponibilidad antes de preparar la Guía Interna."
                           Margin="0,5,0,0" Foreground="#64748B"/>
            </StackPanel>
            <Border Grid.Column="1" Background="#CCFBF1" CornerRadius="16" Padding="14,7" VerticalAlignment="Center">
                <TextBlock Text="VISTA PREVIA" Foreground="#0F766E" FontWeight="Bold" FontSize="11"/>
            </Border>
        </Grid>
        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10"
                Padding="18" Margin="0,18,0,14">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="OCI" Style="{StaticResource Etiqueta}"/><TextBlock Text="{Binding NumeroOci}" Style="{StaticResource Dato}"/></StackPanel>
                <StackPanel Grid.Column="1"><TextBlock Text="Orden de compra" Style="{StaticResource Etiqueta}"/><TextBlock Text="{Binding OrdenCompraCliente}" Style="{StaticResource Dato}"/></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="Cliente" Style="{StaticResource Etiqueta}"/><TextBlock Text="{Binding EmpresaDestino}" Style="{StaticResource Dato}" TextTrimming="CharacterEllipsis"/></StackPanel>
                <StackPanel Grid.Column="3"><TextBlock Text="Almacén de salida" Style="{StaticResource Etiqueta}"/><TextBlock Text="{Binding NombreAlmacen}" Style="{StaticResource Dato}"/></StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10">
            <DataGrid ItemsSource="{Binding Detalles}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column" RowHeight="46" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código" Binding="{Binding CodigoProducto}" Width="110"/>
                    <DataGridTextColumn Header="Nombre del producto" Binding="{Binding NombreProducto}" Width="*" MinWidth="280"/>
                    <DataGridTextColumn Header="Cantidad requerida" Binding="{Binding CantidadRequerida, StringFormat=N2}" Width="125"/>
                    <DataGridTextColumn Header="Cantidad atendida" Binding="{Binding CantidadEntregada, StringFormat=N2}" Width="125"/>
                    <DataGridTextColumn Header="Cantidad pendiente" Binding="{Binding CantidadPendiente, StringFormat=N2}" Width="125"/>
                    <DataGridTextColumn Header="Stock disponible" Binding="{Binding StockActual, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="Estado" Binding="{Binding EstadoDespacho}" Width="105"/>
                    <DataGridTemplateColumn Header="Acciones" Width="105">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Preparar" Height="30" Padding="12,0" Cursor="Hand"
                                        Background="#0F766E" BorderBrush="#0F766E" Foreground="White"
                                        Click="Preparar_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <TextBlock Text="Las cantidades se podrán ajustar en el siguiente paso." Foreground="#64748B" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Style="{StaticResource Boton}" IsCancel="True" Background="White" BorderBrush="#CBD5E1"/>
                <Button Content="Continuar" Style="{StaticResource Boton}" Click="Continuar_Click"
                        Background="#0F766E" BorderBrush="#0F766E" Foreground="White"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
