<Window x:Class="CorexProd.WPF.Modules.Ventas.Views.AnularGuiaInternaWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Anular Guía Interna" Width="440" Height="275" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F8FAFC">
 <Grid Margin="18"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel><TextBlock Text="Anular Guía Interna" FontSize="22" FontWeight="Bold"/><TextBlock x:Name="NumeroText" Foreground="#64748B" Margin="0,4,0,0"/></StackPanel><Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,14,0,14"><StackPanel><TextBlock Text="Motivo de anulación *" FontWeight="SemiBold"/><TextBox x:Name="MotivoText" Height="80" Margin="0,7,0,0" TextWrapping="Wrap" AcceptsReturn="True" Padding="8"/><TextBlock x:Name="ErrorText" Foreground="#DC2626" Margin="0,5,0,0"/></StackPanel></Border><StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Cancelar" Width="100" Height="34" IsCancel="True"/><Button Content="Confirmar" Width="100" Height="34" Margin="8,0,0,0" Background="#DC2626" Foreground="White" Click="Confirmar_Click"/></StackPanel></Grid>
