<UserControl x:Class="CorexProd.WPF.Modules.Ventas.Views.OrdenesCompraInternaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="Boton" TargetType="Button">
            <Setter Property="Height" Value="36"/><Setter Property="MinWidth" Value="94"/><Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#F8FAFC"/><Setter Property="BorderBrush" Value="#CBD5E1"/><Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="BotonExportar" TargetType="Button" BasedOn="{StaticResource Boton}">
            <Setter Property="Background" Value="#16A34A"/><Setter Property="BorderBrush" Value="#16A34A"/><Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BotonAccion" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="Padding" Value="9,0"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionBorder" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="ActionBorder" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionBorder" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ActionBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BotonGuiaAccion" TargetType="Button" BasedOn="{StaticResource BotonAccion}">
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Background" Value="#0F766E"/>
            <Setter Property="BorderBrush" Value="#0F766E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionBorder" Property="Background" Value="#0D9488"/>
                                <Setter TargetName="ActionBorder" Property="BorderBrush" Value="#0D9488"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionBorder" Property="Background" Value="#115E59"/>
                                <Setter TargetName="ActionBorder" Property="BorderBrush" Value="#115E59"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ActionBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IconoAccion" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Etiqueta" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#475569"/><Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="Campo" TargetType="Control">
            <Setter Property="Height" Value="34"/><Setter Property="MinWidth" Value="145"/>
        </Style>
        <Style x:Key="Celda" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8,0"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="EstadoBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/><Setter Property="Padding" Value="10,4"/><Setter Property="Background" Value="#DBEAFE"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Estado}" Value="En proceso">
                    <Setter Property="Background" Value="#FEF3C7"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="Parcial">
                    <Setter Property="Background" Value="#FFEDD5"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="Entregado">
                    <Setter Property="Background" Value="#DCFCE7"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="Anulado">
                    <Setter Property="Background" Value="#FEE2E2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="EstadoBadgeTexto" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1D4ED8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Estado}" Value="En proceso">
                    <Setter Property="Foreground" Value="#92400E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="Parcial">
                    <Setter Property="Foreground" Value="#C2410C"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="Entregado">
                    <Setter Property="Foreground" Value="#166534"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="Anulado">
                    <Setter Property="Foreground" Value="#B91C1C"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="IconoInfoAnulacion" TargetType="TextBlock">
            <Setter Property="Text" Value="ⓘ"/>
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#BE123C"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Help"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="ToolTip" Value="{Binding DetalleAnulacion}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Estado}" Value="Anulado">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CeldaOci" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FilaOci" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0FDFA"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20" MaxWidth="1400" HorizontalAlignment="Center">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="18" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Gestiona las OCI generadas desde proformas" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource Boton}" Command="{Binding ActualizarCommand}">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/><TextBlock Text="Actualizar"/></StackPanel>
                    </Button>
                </StackPanel>
                <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,18,0,0">
                    <StackPanel Margin="0,0,12,0"><TextBlock Text="Buscar" Style="{StaticResource Etiqueta}"/><TextBox Style="{StaticResource Campo}" Width="250" Padding="8,0" VerticalContentAlignment="Center" Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    <StackPanel Margin="0,0,12,0"><TextBlock Text="Estado" Style="{StaticResource Etiqueta}"/><ComboBox Style="{StaticResource Campo}" ItemsSource="{Binding Estados}" SelectedItem="{Binding EstadoFiltro}"/></StackPanel>
                    <StackPanel Margin="0,0,12,0"><TextBlock Text="Fecha desde" Style="{StaticResource Etiqueta}"/><DatePicker Style="{StaticResource Campo}" SelectedDate="{Binding FechaDesde}"/></StackPanel>
                    <StackPanel Margin="0,0,12,0"><TextBlock Text="Fecha hasta" Style="{StaticResource Etiqueta}"/><DatePicker Style="{StaticResource Campo}" SelectedDate="{Binding FechaHasta}"/></StackPanel>
                    <Button Style="{StaticResource Boton}" Command="{Binding LimpiarCommand}" VerticalAlignment="Bottom" Margin="0,0,16,0" Content="Quitar filtros"/>
                    <StackPanel VerticalAlignment="Bottom" Margin="0,0,18,3"><TextBlock Text="{Binding Resumen}" FontWeight="SemiBold" Foreground="#475569"/><TextBlock Text="{Binding TotalVisible, StringFormat=Total visible: S/ {0:N2}}" Foreground="#0F766E" FontWeight="SemiBold"/></StackPanel>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Ordenes}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      RowHeight="46" MaxHeight="590" GridLinesVisibility="Horizontal"
                      CellStyle="{StaticResource CeldaOci}" RowStyle="{StaticResource FilaOci}">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Acciones" Width="260"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button Style="{StaticResource BotonAccion}" Width="30" Padding="0" ToolTip="Ver detalle"
                                    Command="{Binding DataContext.VerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                <TextBlock Text="&#xE890;" Style="{StaticResource IconoAccion}" Foreground="#111827"/>
                            </Button>
                            <Button Style="{StaticResource BotonAccion}" ToolTip="Orden de trabajo"
                                     Command="{Binding DataContext.GenerarOtCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏭" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="OT" VerticalAlignment="Center" Foreground="#7E22CE"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource BotonGuiaAccion}" ToolTip="Guía Interna"
                                     Command="{Binding DataContext.GenerarGuiaSalidaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚚" FontFamily="Segoe UI Emoji" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Guía Interna" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource BotonAccion}" Width="30" Padding="0" Margin="0" Foreground="#DC2626" BorderBrush="#FCA5A5" ToolTip="Anular"
                                    Command="{Binding DataContext.AnularCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                <TextBlock Text="&#xE711;" Style="{StaticResource IconoAccion}"/>
                            </Button>
                        </StackPanel>
                    </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                    <DataGridTextColumn Header="OCI" Binding="{Binding NumeroOci}" Width="80" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTextColumn Header="Orden de compra" Binding="{Binding OrdenCompraCliente}" Width="120" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTextColumn Header="Proforma" Binding="{Binding NumeroProforma}" Width="80" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTemplateColumn Header="Estado" Width="100"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Style="{StaticResource EstadoBadge}" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Estado}" Style="{StaticResource EstadoBadgeTexto}"/>
                            </Border>
                            <TextBlock Style="{StaticResource IconoInfoAnulacion}"/>
                        </StackPanel>
                    </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                    <DataGridTextColumn Header="Cliente" Binding="{Binding NombreCliente}" Width="210" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTextColumn Header="Fecha emisión" Binding="{Binding FechaEmision, StringFormat=dd/MM/yyyy}" Width="105" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=S/ {0:N2}}" Width="105" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTextColumn Header="Descuento" Binding="{Binding Descuento, StringFormat=S/ {0:N2}}" Width="90" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTextColumn Header="IGV" Binding="{Binding Igv, StringFormat=S/ {0:N2}}" Width="80" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=S/ {0:N2}}" Width="105" ElementStyle="{StaticResource Celda}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
