<UserControl x:Class="CorexProd.WPF.Modules.Ventas.Views.OrdenesCompraInternaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="Boton" TargetType="Button">
            <Setter Property="Height" Value="36"/><Setter Property="MinWidth" Value="94"/><Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#F8FAFC"/><Setter Property="BorderBrush" Value="#CBD5E1"/><Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="BotonExportar" TargetType="Button" BasedOn="{StaticResource Boton}">
            <Setter Property="Background" Value="#16A34A"/><Setter Property="BorderBrush" Value="#16A34A"/><Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="BotonAccion" TargetType="Button">
            <Setter Property="Height" Value="30"/><Setter Property="Padding" Value="9,0"/><Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Background" Value="#FFFFFF"/><Setter Property="BorderBrush" Value="#CBD5E1"/><Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#475569"/><Setter Property="FontSize" Value="12"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="Etiqueta" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#475569"/><Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="Campo" TargetType="Control">
            <Setter Property="Height" Value="34"/><Setter Property="MinWidth" Value="145"/>
        </Style>
        <Style x:Key="Celda" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="8,0"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="EstadoBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/><Setter Property="Padding" Value="10,4"/><Setter Property="Background" Value="#DCFCE7"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20" MaxWidth="1400" HorizontalAlignment="Center">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="18" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Órdenes de Compra Interna" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Gestiona las OCI generadas desde proformas" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource BotonExportar}" Command="{Binding ExportarCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/><TextBlock Text="Exportar"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource Boton}" Command="{Binding ActualizarCommand}">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/><TextBlock Text="Actualizar"/></StackPanel>
                    </Button>
                </StackPanel>
                <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,18,0,0">
                    <StackPanel Margin="0,0,12,0"><TextBlock Text="Buscar" Style="{StaticResource Etiqueta}"/><TextBox Style="{StaticResource Campo}" Width="250" Padding="8,0" VerticalContentAlignment="Center" Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    <StackPanel Margin="0,0,12,0"><TextBlock Text="Estado" Style="{StaticResource Etiqueta}"/><ComboBox Style="{StaticResource Campo}" ItemsSource="{Binding Estados}" SelectedItem="{Binding EstadoFiltro}"/></StackPanel>
                    <StackPanel Margin="0,0,12,0"><TextBlock Text="Fecha desde" Style="{StaticResource Etiqueta}"/><DatePicker Style="{StaticResource Campo}" SelectedDate="{Binding FechaDesde}"/></StackPanel>
                    <StackPanel Margin="0,0,12,0"><TextBlock Text="Fecha hasta" Style="{StaticResource Etiqueta}"/><DatePicker Style="{StaticResource Campo}" SelectedDate="{Binding FechaHasta}"/></StackPanel>
                    <Button Style="{StaticResource Boton}" Command="{Binding LimpiarCommand}" VerticalAlignment="Bottom" Margin="0,0,16,0" Content="Quitar filtros"/>
                    <StackPanel VerticalAlignment="Bottom" Margin="0,0,18,3"><TextBlock Text="{Binding Resumen}" FontWeight="SemiBold" Foreground="#475569"/><TextBlock Text="{Binding TotalVisible, StringFormat=Total visible: S/ {0:N2}}" Foreground="#0F766E" FontWeight="SemiBold"/></StackPanel>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Ordenes}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" RowHeight="46" MaxHeight="590" GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Acciones" Width="330"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Style="{StaticResource BotonAccion}" Width="34" Padding="0" ToolTip="Vista"
                                    Command="{Binding DataContext.VerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                <TextBlock Text="&#xE890;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                            </Button>
                            <Button Style="{StaticResource BotonAccion}" ToolTip="Orden de trabajo">
                                <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" Foreground="#A21CAF" Margin="0,0,5,0"/><TextBlock Text="OT"/></StackPanel>
                            </Button>
                            <Button Style="{StaticResource BotonAccion}" ToolTip="Guía de salida">
                                <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE7C8;" FontFamily="Segoe MDL2 Assets" Foreground="#2563EB" Margin="0,0,5,0"/><TextBlock Text="Guía de salida"/></StackPanel>
                            </Button>
                            <Button Style="{StaticResource BotonAccion}" Margin="0" Foreground="#DC2626" BorderBrush="#FCA5A5" ToolTip="Anular">
                                <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" Margin="0,0,5,0"/><TextBlock Text="Anular"/></StackPanel>
                            </Button>
                        </StackPanel>
                    </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                    <DataGridTextColumn Header="OCI" Binding="{Binding NumeroOci}" Width="105" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTextColumn Header="Orden de compra" Binding="{Binding OrdenCompraCliente}" Width="120" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTextColumn Header="Proforma" Binding="{Binding NumeroProforma}" Width="100" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTemplateColumn Header="Estado" Width="103"><DataGridTemplateColumn.CellTemplate><DataTemplate><Border Style="{StaticResource EstadoBadge}" HorizontalAlignment="Center"><TextBlock Text="{Binding Estado}" Foreground="#166534" FontWeight="SemiBold"/></Border></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                    <DataGridTextColumn Header="Cliente" Binding="{Binding NombreCliente}" Width="210" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTextColumn Header="Fecha emisión" Binding="{Binding FechaEmision, StringFormat=dd/MM/yyyy}" Width="105" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=S/ {0:N2}}" Width="105" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTextColumn Header="Descuento" Binding="{Binding Descuento, StringFormat=S/ {0:N2}}" Width="90" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTextColumn Header="IGV" Binding="{Binding Igv, StringFormat=S/ {0:N2}}" Width="80" ElementStyle="{StaticResource Celda}"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=S/ {0:N2}}" Width="105" ElementStyle="{StaticResource Celda}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
