<Window x:Class="CorexProd.WPF.Modules.Ventas.Views.GuiaInternaManualWindow" x:Name="VentanaGuia"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva Guía Interna Manual" Width="1120" Height="760" MinWidth="940" MinHeight="640"
        WindowStartupLocation="CenterOwner" Background="#F8FAFC">
    <Window.Resources>
        <Style x:Key="Etiqueta" TargetType="TextBlock"><Setter Property="Foreground" Value="#475569"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="12"/><Setter Property="Margin" Value="0,0,0,5"/></Style>
        <Style x:Key="Campo" TargetType="Control"><Setter Property="Height" Value="34"/><Setter Property="Margin" Value="0,0,14,0"/></Style>
        <Style x:Key="Boton" TargetType="Button"><Setter Property="Height" Value="38"/><Setter Property="MinWidth" Value="110"/><Setter Property="Padding" Value="16,0"/><Setter Property="Margin" Value="8,0,0,0"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
        <Style x:Key="ProductoBusquedaItem" TargetType="ListBoxItem"><Setter Property="Padding" Value="8,6"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Cursor" Value="Hand"/></Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="Nueva Guía Interna Manual" FontSize="25" FontWeight="Bold" Foreground="#0F172A"/><TextBlock Text="Salida extraordinaria para regularización de stock. Agregue únicamente los productos que se retirarán." Foreground="#64748B" Margin="0,4,0,0"/></StackPanel>
        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,16,0,12">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="Almacén" Style="{StaticResource Etiqueta}"/><ComboBox x:Name="AlmacenCombo" Style="{StaticResource Campo}" DisplayMemberPath="NombreAlmacen" SelectionChanged="Almacen_SelectionChanged"/></StackPanel>
                <StackPanel Grid.Column="1"><TextBlock Text="Fecha de emisión" Style="{StaticResource Etiqueta}"/><DatePicker Style="{StaticResource Campo}" SelectedDate="{Binding FechaEmision}"/></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="Emitido por" Style="{StaticResource Etiqueta}"/><TextBox x:Name="EmisorText" Style="{StaticResource Campo}" IsReadOnly="True"/></StackPanel>
                <StackPanel Grid.Column="3"><TextBlock Text="Autorizado por" Style="{StaticResource Etiqueta}"/><ComboBox x:Name="AutorizadorCombo" Style="{StaticResource Campo}" DisplayMemberPath="NombreEmpleado"/></StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="2" Background="#FFF7ED" BorderBrush="#FDBA74" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Style="{StaticResource Etiqueta}"><Run Text="Motivo de salida o destino "/><Run Text="*" Foreground="#DC2626"/></TextBlock><ComboBox x:Name="MotivoCombo" Height="34" SelectionChanged="Motivo_SelectionChanged"/></StackPanel>
                <StackPanel Grid.Column="1" Margin="14,0,0,0"><TextBlock Text="Cliente (opcional)" Style="{StaticResource Etiqueta}"/>
                    <Grid><TextBox x:Name="ClienteBusquedaTextBox" Height="34" Padding="8,0,32,0" VerticalContentAlignment="Center" TextChanged="ClienteBusqueda_TextChanged"/>
                        <Button Content="×" Width="28" Height="28" HorizontalAlignment="Right" Margin="0,3,3,3" ToolTip="Quitar cliente" Click="LimpiarCliente_Click"/>
                        <Popup x:Name="ClientePopup" Placement="Bottom" PlacementTarget="{Binding ElementName=ClienteBusquedaTextBox}" StaysOpen="False" AllowsTransparency="True" Width="360">
                            <Border Background="White" BorderBrush="#9CA3AF" BorderThickness="1" MaxHeight="220"><ListBox x:Name="ClientesListBox" DisplayMemberPath="ClienteBusqueda" ItemContainerStyle="{StaticResource ProductoBusquedaItem}" PreviewMouseLeftButtonUp="ClienteBusquedaListBox_PreviewMouseLeftButtonUp"/></Border>
                        </Popup>
                    </Grid>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="14,0,0,0"><TextBlock Text="Observación" Style="{StaticResource Etiqueta}"/><TextBox Text="{Binding Observacion,UpdateSourceTrigger=PropertyChanged}" MaxLength="500" Height="58" TextWrapping="Wrap" AcceptsReturn="True" Padding="8"/></StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="3" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12">
            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Productos a retirar" FontSize="16" FontWeight="Bold" Foreground="#374151" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Width="38" Height="30" ToolTip="Agregar producto" Click="AgregarProducto_Click"><TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"/></Button>
                    <Button DockPanel.Dock="Right" Content="Carga masiva" Width="118" Height="30" Margin="0,0,8,0" Click="CargaMasiva_Click"/>
                </DockPanel>
                <DataGrid x:Name="DetallesGrid" Grid.Row="1" ItemsSource="{Binding ElementName=VentanaGuia, Path=DetallesEdicion}" AutoGenerateColumns="False" CanUserAddRows="False" RowHeight="42" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código" Binding="{Binding CodigoProducto}" Width="100" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="Producto" Width="*"><DataGridTemplateColumn.CellTemplate><DataTemplate>
                            <Grid MinWidth="320"><TextBox Height="28" Padding="8,0" VerticalContentAlignment="Center" Text="{Binding TextoBusquedaProducto,UpdateSourceTrigger=PropertyChanged}"/>
                                <Popup IsOpen="{Binding ProductoDropdownAbierto,Mode=TwoWay}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" Width="520"><Border Background="White" BorderBrush="#9CA3AF" BorderThickness="1" MaxHeight="220"><ListBox ItemsSource="{Binding ProductosFiltrados}" DisplayMemberPath="ProductoBusqueda" ItemContainerStyle="{StaticResource ProductoBusquedaItem}" PreviewMouseLeftButtonUp="ProductoBusquedaListBox_PreviewMouseLeftButtonUp"/></Border></Popup>
                            </Grid>
                        </DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                        <DataGridTextColumn Header="Unidad" Binding="{Binding NombreUnidad}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Stock" Binding="{Binding StockActual,StringFormat=N2}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Cantidad a retirar" Binding="{Binding CantidadDespachar,UpdateSourceTrigger=PropertyChanged}" Width="125"/>
                        <DataGridTextColumn Header="Observación" Binding="{Binding Observacion,UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                        <DataGridTemplateColumn Header="" Width="75"><DataGridTemplateColumn.CellTemplate><DataTemplate><Button Content="Quitar" Height="28" Click="QuitarProducto_Click"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
        <Grid Grid.Row="4" Margin="0,14,0,0"><TextBlock Text="Puede agregar productos uno por uno o pegarlos mediante carga masiva." Foreground="#64748B" VerticalAlignment="Center"/><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Cancelar" Style="{StaticResource Boton}" IsCancel="True"/><Button Content="Emitir guía" Style="{StaticResource Boton}" Click="Emitir_Click" Background="#0F766E" BorderBrush="#0F766E" Foreground="White"/></StackPanel></Grid>
    </Grid>
</Window>
