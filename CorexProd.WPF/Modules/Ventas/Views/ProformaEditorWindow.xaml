<Window x:Class="CorexProd.WPF.Modules.Ventas.Views.ProformaEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Titulo}"
        Width="1160"
        Height="760"
        WindowStartupLocation="CenterOwner"
        Background="#F3F4F6">

    <Window.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Foreground" Value="#374151"/>
        </Style>

        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Titulo}"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#F97316"
                   Margin="0,0,0,14"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="White"
                        CornerRadius="8"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Padding="14"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Datos Generales"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#374151"
                                   Margin="0,0,0,14"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.15*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,14,14">
                                <TextBlock Text="Fecha Emisión" Style="{StaticResource LabelCampo}"/>
                                <DatePicker SelectedDate="{Binding FechaEmision}" Height="30"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,14,14">
                                <TextBlock Text="Fecha Vencimiento" Style="{StaticResource LabelCampo}"/>
                                <DatePicker SelectedDate="{Binding FechaVencimiento}" Height="30"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14">
                                <TextBlock Text="ID / Serie de Proforma" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         IsReadOnly="True"
                                         Text="{Binding SerieNumero}"
                                         ToolTip="Se genera automaticamente con los parametros de proforma"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,14,14">
                                <TextBlock Text="Cliente" Style="{StaticResource LabelCampo}"/>
                                <DockPanel LastChildFill="True">
                                    <Button DockPanel.Dock="Right"
                                            Content="Nuevo Cliente"
                                            Width="110"
                                            Height="30"
                                            Margin="8,0,0,0"
                                            Command="{Binding MostrarClienteRapidoCommand}"/>
                                    <ComboBox Style="{StaticResource CampoCombo}"
                                              ItemsSource="{Binding Clientes}"
                                              DisplayMemberPath="NombreRazonSocial"
                                              SelectedItem="{Binding ClienteSeleccionado}"/>
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,14">
                                <TextBlock Text="Orden de Compra Cliente" Style="{StaticResource LabelCampo}"/>
                                <TextBox Style="{StaticResource CampoTexto}"
                                         Text="{Binding OrdenCompraCliente, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <Border Grid.Row="2"
                                    Grid.ColumnSpan="3"
                                    Visibility="{Binding ClienteRapidoVisibility}"
                                    Background="#F8FAFC"
                                    BorderBrush="#CBD5E1"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12"
                                    Margin="0,0,0,4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.8*"/>
                                        <ColumnDefinition Width="1.1*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.4*"/>
                                        <ColumnDefinition Width="1.4*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,12">
                                        <TextBlock Text="Documento" Style="{StaticResource LabelCampo}"/>
                                        <ComboBox Style="{StaticResource CampoCombo}"
                                                  SelectedValuePath="Content"
                                                  SelectedValue="{Binding NuevoClienteTipoDocumento}">
                                            <ComboBoxItem Content="DNI"/>
                                            <ComboBoxItem Content="RUC"/>
                                            <ComboBoxItem Content="S/N"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,12">
                                        <TextBlock Text="Nro Documento" Style="{StaticResource LabelCampo}"/>
                                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding NuevoClienteNumeroDocumento, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,10,12">
                                        <TextBlock Text="Nombre / Razón Social" Style="{StaticResource LabelCampo}"/>
                                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding NuevoClienteNombre, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,10,12">
                                        <TextBlock Text="Teléfono" Style="{StaticResource LabelCampo}"/>
                                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding NuevoClienteTelefono, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,10,12">
                                        <TextBlock Text="Correo" Style="{StaticResource LabelCampo}"/>
                                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding NuevoClienteCorreo, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,0,10,0">
                                        <TextBlock Text="Dirección" Style="{StaticResource LabelCampo}"/>
                                        <TextBox Style="{StaticResource CampoTexto}" Text="{Binding NuevoClienteDireccion, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                        <Button Content="Guardar Cliente"
                                                Width="118"
                                                Height="30"
                                                Margin="0,0,8,0"
                                                Command="{Binding GuardarClienteRapidoCommand}"/>
                                        <Button Content="Cerrar"
                                                Width="80"
                                                Height="30"
                                                Command="{Binding CancelarClienteRapidoCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White"
                        CornerRadius="8"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Padding="14"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="Productos y/o Servicios"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#374151"
                                       VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right"
                                    Content="Agregar Producto"
                                    Width="132"
                                    Height="30"
                                    HorizontalAlignment="Right"
                                    Command="{Binding AgregarProductoCommand}"/>
                        </DockPanel>

                        <DataGrid ItemsSource="{Binding Detalles}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  RowHeight="42"
                                  MinHeight="155"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Producto" Width="600">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding Productos}"
                                                      DisplayMemberPath="NombreProducto"
                                                      SelectedItem="{Binding ProductoSeleccionado, UpdateSourceTrigger=PropertyChanged}"
                                                      IsTextSearchEnabled="True"
                                                      MinWidth="360"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Cant." Binding="{Binding Cantidad, UpdateSourceTrigger=PropertyChanged}" Width="65"/>
                                <DataGridTextColumn Header="P. Unitario" Binding="{Binding PrecioUnitario, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="85"/>
                                <DataGridTextColumn Header="Dscto." Binding="{Binding Descuento, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="65"/>
                                <DataGridTextColumn Header="Importe" Binding="{Binding Importe, StringFormat=S/ {0:N2}}" IsReadOnly="True" Width="75"/>
                                <DataGridTextColumn Header="Observación" Binding="{Binding Observacion, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                <DataGridTemplateColumn Header="" Width="82">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Quitar"
                                                    Height="28" 
                                                    Command="{Binding DataContext.QuitarProductoCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="White"
                            CornerRadius="8"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Observaciones"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#374151"
                                       Margin="0,0,0,12"/>
                            <TextBox Text="{Binding Observacion, UpdateSourceTrigger=PropertyChanged}"
                                     Height="95"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="White"
                            CornerRadius="8"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Resumen" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Subtotal:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Subtotal, StringFormat=S/ {0:N2}}" TextAlignment="Right" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Descuento:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Descuento, StringFormat=S/ {0:N2}}" TextAlignment="Right" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="IGV:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Igv, StringFormat=S/ {0:N2}}" TextAlignment="Right" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Total:" FontWeight="Bold" Foreground="#1D4ED8"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Total, StringFormat=S/ {0:N2}}" TextAlignment="Right" FontWeight="Bold" Foreground="#1D4ED8"/>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Cancelar"
                    Width="110"
                    Height="34"
                    Margin="0,0,10,0"
                    Command="{Binding CancelarCommand}"/>
            <Button Content="Guardar"
                    Width="110"
                    Height="34"
                    Command="{Binding GuardarCommand}"/>
        </StackPanel>
    </Grid>
</Window>
