<UserControl x:Class="CorexProd.WPF.Modules.Ventas.Views.ProformasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CorexProd.WPF.Modules.Ventas.ViewModels">

    <UserControl.DataContext>
        <vm:ProformasViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="EstadoTexto" TargetType="TextBlock">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#155E75"/>
            <Setter Property="Background" Value="#BAE6FD"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Estado}" Value="Anulado">
                    <Setter Property="Foreground" Value="#9A3412"/>
                    <Setter Property="Background" Value="#FED7AA"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="Registrado">
                    <Setter Property="Foreground" Value="#166534"/>
                    <Setter Property="Background" Value="#BBF7D0"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BotonAccionProforma" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="BotonIconoProforma" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="18"
                Margin="0,0,0,14">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Proformas"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#111827"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Listado de proformas registradas"
                               FontSize="14"
                               Foreground="#6B7280"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Nuevo"
                            Width="110"
                            Height="32"
                            Margin="0,0,10,0"
                            Command="{Binding NuevoCommand}"/>
                    <Button Content="Refrescar"
                            Width="110"
                            Height="32"
                            Command="{Binding RefrescarCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="0">
            <DataGrid ItemsSource="{Binding Proformas}"
                      SelectedItem="{Binding ProformaSeleccionada}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      RowHeight="44"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdProforma}" Width="40"/>
                    <DataGridTemplateColumn Header="Acciones" Width="224">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource BotonIconoProforma}"
                                            ToolTip="Editar"
                                            Margin="0,0,6,0"
                                            Command="{Binding DataContext.EditarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xE70F;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="#2563EB"/>
                                    </Button>
                                    <Button Style="{StaticResource BotonIconoProforma}"
                                            ToolTip="Copiar"
                                            Margin="0,0,6,0"
                                            Command="{Binding DataContext.CopiarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xE8C8;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="#4F46E5"/>
                                    </Button>
                                    <Button Style="{StaticResource BotonIconoProforma}"
                                            ToolTip="Anular"
                                            Margin="0,0,6,0"
                                            Command="{Binding DataContext.AnularCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xE711;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="#DC2626"/>
                                    </Button>
                                    <Button Content="Generar OCI"
                                            Style="{StaticResource BotonAccionProforma}"
                                            Background="#059669"
                                            Width="100"
                                            Command="{Binding DataContext.GenerarOciCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Proforma" Binding="{Binding SerieNumero}" Width="100"/>
                    <DataGridTextColumn Header="Orden de Compra" Binding="{Binding OrdenCompraCliente}" Width="120"/>
                    <DataGridTemplateColumn Header="Estado" Width="115">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Estado}"
                                           Style="{StaticResource EstadoTexto}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Cliente" Binding="{Binding NombreCliente}" Width="260"/>
                    <DataGridTextColumn Header="Fecha Emisión" Binding="{Binding FechaEmision, StringFormat=dd/MM/yyyy}" Width="115"/>
                    <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=S/ {0:N2}}" Width="95"/>
                    <DataGridTextColumn Header="Descuento" Binding="{Binding Descuento, StringFormat=S/ {0:N2}}" Width="95"/>
                    <DataGridTextColumn Header="IGV" Binding="{Binding Igv, StringFormat=S/ {0:N2}}" Width="80"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=S/ {0:N2}}" Width="95"/>

                    
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
