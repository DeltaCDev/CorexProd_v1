<UserControl x:Class="CorexProd.WPF.Modules.Ventas.Views.ProformasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CorexProd.WPF.Modules.Ventas.ViewModels">

    <UserControl.DataContext>
        <vm:ProformasViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="LabelFiltro" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="CampoFiltro" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="260"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="ComboFiltro" TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="BotonBaseProforma" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BotonPrimarioProforma" TargetType="Button" BasedOn="{StaticResource BotonBaseProforma}">
            <Setter Property="MinWidth" Value="122"/>
            <Setter Property="Background" Value="#0F766E"/>
            <Setter Property="BorderBrush" Value="#0F766E"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="BotonSecundarioProforma" TargetType="Button" BasedOn="{StaticResource BotonBaseProforma}">
            <Setter Property="MinWidth" Value="116"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Foreground" Value="#334155"/>
        </Style>

        <Style x:Key="BotonOciProforma" TargetType="Button" BasedOn="{StaticResource BotonBaseProforma}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#0F766E"/>
            <Setter Property="BorderBrush" Value="#0F766E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="BotonIconoProforma" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0F2FE"/>
                                <Setter Property="BorderBrush" Value="#BAE6FD"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CCFBF1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconoAccion" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#0F766E"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CeldaTexto" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="CeldaTextoCentrada" TargetType="TextBlock" BasedOn="{StaticResource CeldaTexto}">
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CeldaTextoDerecha" TargetType="TextBlock" BasedOn="{StaticResource CeldaTexto}">
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>

        <Style x:Key="EstadoBadge" TargetType="Border">
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Background" Value="#DCFCE7"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Estado}" Value="Anulado">
                    <Setter Property="Background" Value="#FFE4E6"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EstadoBadgeTexto" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#166534"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Estado}" Value="Anulado">
                    <Setter Property="Foreground" Value="#BE123C"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="ColumnHeaderHeight" Value="38"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="Background" Value="#E2E8F0"/>
                        <Setter Property="Foreground" Value="#0F172A"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderBrush" Value="#CBD5E1"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridCell}">
                        <Setter Property="Foreground" Value="#0F172A"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridRow}">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#0F172A"/>
                        <Setter Property="MinHeight" Value="48"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0FDFA"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20"
              MaxWidth="1360"
              HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    Padding="18"
                    Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12"
                                      ShadowDepth="1"
                                      Opacity="0.10"
                                      Color="#0F172A"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,16,14">
                        <TextBlock Text="Listado registrado"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Consulta, filtra y gestiona documentos de venta"
                                   FontSize="13"
                                   Foreground="#64748B"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <Button Style="{StaticResource BotonPrimarioProforma}"
                                Margin="0,0,8,0"
                                Command="{Binding NuevoCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Nuevo"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource BotonSecundarioProforma}"
                                Command="{Binding RefrescarCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Actualizar"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <WrapPanel Grid.Row="1"
                               Grid.Column="0"
                               Grid.ColumnSpan="2">
                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Text="Buscar" Style="{StaticResource LabelFiltro}"/>
                            <TextBox Style="{StaticResource CampoFiltro}"
                                     Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Text="Estado" Style="{StaticResource LabelFiltro}"/>
                            <ComboBox Style="{StaticResource ComboFiltro}"
                                      ItemsSource="{Binding EstadosFiltro}"
                                      SelectedItem="{Binding EstadoFiltro, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <TextBlock Text="{Binding ResumenRegistros}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#475569"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,0,8"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    Padding="0"
                    VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12"
                                      ShadowDepth="1"
                                      Opacity="0.08"
                                      Color="#0F172A"/>
                </Border.Effect>

                <DataGrid ItemsSource="{Binding Proformas}"
                          x:Name="ProformasGrid"
                          SelectedItem="{Binding ProformaSeleccionada}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          RowHeight="48"
                          MaxHeight="560"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding IdProforma}"
                                            Width="44"
                                            ElementStyle="{StaticResource CeldaTextoCentrada}"/>

                        <DataGridTemplateColumn Header="Acciones"
                                                Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <Button Style="{StaticResource BotonIconoProforma}"
                                                ToolTip="Ver"
                                                Margin="0,0,4,0"
                                                Command="{Binding DataContext.VerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="&#xE890;" Style="{StaticResource IconoAccion}"/>
                                        </Button>
                                        <Button Style="{StaticResource BotonIconoProforma}"
                                                ToolTip="Editar"
                                                Margin="0,0,8,0"
                                                Command="{Binding DataContext.EditarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="&#xE70F;" Style="{StaticResource IconoAccion}"/>
                                        </Button>
                                        <Button Content="Generar OCI"
                                                Style="{StaticResource BotonOciProforma}"
                                                Margin="0,0,8,0"
                                                Command="{Binding DataContext.GenerarOciCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                        <Menu Background="Transparent"
                                              BorderThickness="0">
                                            <MenuItem ToolTip="Mas acciones">
                                                <MenuItem.Header>
                                                    <TextBlock Text="&#xE712;"
                                                               Width="30"
                                                               Height="30"
                                                               TextAlignment="Center"
                                                               Style="{StaticResource IconoAccion}"/>
                                                </MenuItem.Header>
                                                <MenuItem Header="Copiar"
                                                          Command="{Binding DataContext.CopiarCommand, Source={x:Reference ProformasGrid}}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Anular"
                                                          Command="{Binding DataContext.AnularCommand, Source={x:Reference ProformasGrid}}"
                                                          CommandParameter="{Binding}"/>
                                            </MenuItem>
                                        </Menu>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Proforma"
                                            Binding="{Binding SerieNumero}"
                                            Width="88"
                                            ElementStyle="{StaticResource CeldaTextoCentrada}"/>
                        <DataGridTextColumn Header="OC Cliente"
                                            Binding="{Binding OrdenCompraCliente}"
                                            Width="106"
                                            ElementStyle="{StaticResource CeldaTextoCentrada}"/>

                        <DataGridTemplateColumn Header="Estado" Width="112">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource EstadoBadge}">
                                        <TextBlock Text="{Binding Estado}"
                                                   Style="{StaticResource EstadoBadgeTexto}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Cliente"
                                                Width="2*"
                                                MinWidth="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NombreCliente}"
                                               ToolTip="{Binding NombreCliente}"
                                               Style="{StaticResource CeldaTexto}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Elaborado por"
                                            Binding="{Binding UsuarioGenerador}"
                                            Width="130"
                                            ElementStyle="{StaticResource CeldaTexto}"/>
                        <DataGridTextColumn Header="Fecha emision"
                                            Binding="{Binding FechaEmision, StringFormat=dd/MM/yyyy}"
                                            Width="106"
                                            ElementStyle="{StaticResource CeldaTextoCentrada}"/>
                        <DataGridTextColumn Header="Subtotal"
                                            Binding="{Binding Subtotal, StringFormat=S/ {0:N2}}"
                                            Width="82"
                                            ElementStyle="{StaticResource CeldaTextoDerecha}"/>
                        <DataGridTextColumn Header="Descuento"
                                            Binding="{Binding Descuento, StringFormat=S/ {0:N2}}"
                                            Width="82"
                                            ElementStyle="{StaticResource CeldaTextoDerecha}"/>
                        <DataGridTextColumn Header="IGV"
                                            Binding="{Binding Igv, StringFormat=S/ {0:N2}}"
                                            Width="70"
                                            ElementStyle="{StaticResource CeldaTextoDerecha}"/>
                        <DataGridTextColumn Header="Total"
                                            Binding="{Binding Total, StringFormat=S/ {0:N2}}"
                                            Width="86"
                                            ElementStyle="{StaticResource CeldaTextoDerecha}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
