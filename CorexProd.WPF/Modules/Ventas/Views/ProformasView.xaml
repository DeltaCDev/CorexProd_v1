<UserControl x:Class="CorexProd.WPF.Modules.Ventas.Views.ProformasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CorexProd.WPF.Modules.Ventas.ViewModels">

    <UserControl.DataContext>
        <vm:ProformasViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="EstadoTexto" TargetType="TextBlock">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#155E75"/>
            <Setter Property="Background" Value="#BAE6FD"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Estado}" Value="Anulado">
                    <Setter Property="Foreground" Value="#9A3412"/>
                    <Setter Property="Background" Value="#FED7AA"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="Registrado">
                    <Setter Property="Foreground" Value="#166534"/>
                    <Setter Property="Background" Value="#BBF7D0"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="18"
                Margin="0,0,0,14">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Proformas"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#111827"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Listado de proformas registradas"
                               FontSize="14"
                               Foreground="#6B7280"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Nuevo"
                            Width="110"
                            Height="32"
                            Margin="0,0,10,0"
                            Command="{Binding NuevoCommand}"/>
                    <Button Content="Refrescar"
                            Width="110"
                            Height="32"
                            Command="{Binding RefrescarCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="0">
            <DataGrid ItemsSource="{Binding Proformas}"
                      SelectedItem="{Binding ProformaSeleccionada}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      RowHeight="44"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdProforma}" Width="55"/>
                    <DataGridTextColumn Header="Proforma" Binding="{Binding SerieNumero}" Width="150"/>
                    <DataGridTextColumn Header="Orden de Compra" Binding="{Binding OrdenCompraCliente}" Width="160"/>
                    <DataGridTemplateColumn Header="Estado" Width="115">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Estado}"
                                           Style="{StaticResource EstadoTexto}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Cliente" Binding="{Binding NombreCliente}" Width="260"/>
                    <DataGridTextColumn Header="Fecha Emisión" Binding="{Binding FechaEmision, StringFormat=dd/MM/yyyy}" Width="115"/>
                    <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=S/ {0:N2}}" Width="95"/>
                    <DataGridTextColumn Header="Descuento" Binding="{Binding Descuento, StringFormat=S/ {0:N2}}" Width="95"/>
                    <DataGridTextColumn Header="IGV" Binding="{Binding Igv, StringFormat=S/ {0:N2}}" Width="80"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=S/ {0:N2}}" Width="95"/>

                    <DataGridTemplateColumn Header="Acciones" Width="330">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Editar"
                                            Height="28"
                                            Width="62"
                                            Margin="0,0,6,0"
                                            Command="{Binding DataContext.EditarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Copiar"
                                            Height="28"
                                            Width="62"
                                            Margin="0,0,6,0"
                                            Command="{Binding DataContext.CopiarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Anular"
                                            Height="28"
                                            Width="62"
                                            Margin="0,0,6,0"
                                            Command="{Binding DataContext.AnularCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Generar OCI"
                                            Height="28"
                                            Width="92"
                                            Command="{Binding DataContext.GenerarOciCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
