<Window x:Class="CorexProd.WPF.Modules.Ventas.Views.GuiaInternaDocumentoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Guía Interna de Salida" Width="1050" Height="760" MinWidth="850" MinHeight="600"
        WindowStartupLocation="CenterOwner" Background="#E2E8F0">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Background="#0F172A" Padding="18,12">
            <Grid>
                <TextBlock Text="Vista previa - Guía Interna de Salida" Foreground="White" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Imprimir" Width="105" Height="34" Margin="0,0,8,0" Click="Imprimir_Click"/>
                    <Button Content="Descargar PDF" Width="130" Height="34" Margin="0,0,8,0" Click="Descargar_Click"/>
                    <Button Content="Cerrar" Width="90" Height="34" IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Border>
        <FlowDocumentScrollViewer x:Name="Visor" Grid.Row="1" Margin="18" VerticalScrollBarVisibility="Auto"
                                  IsToolBarVisible="False" Background="White"/>
    </Grid>
</Window>
