<UserControl x:Class="CorexProd.WPF.Modules.Productos.Views.CategoriasProductosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="18"
                Margin="0,0,0,14">

            <StackPanel>
                <TextBlock Text="Gestión de Categorías de Productos"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <TextBlock Margin="0,0,0,18"
                           FontSize="14">
                    <Run Text="Complete la información de la categoría. Los campos marcados con "/>
                    <Run Text="*" Foreground="Red" FontWeight="Bold"/>
                    <Run Text=" son obligatorios." Foreground="Red"/>
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Nombre Categoría "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>

                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding NombreCategoria, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,20,0">
                        <TextBlock Text="Descripción"
                                   Style="{StaticResource LabelCampo}"/>

                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <CheckBox Grid.Column="2"
                              Content="Activo"
                              IsChecked="{Binding Estado}"
                              FontSize="14"
                              VerticalAlignment="Bottom"
                              Margin="0,0,25,5"/>

                    <Button Grid.Column="3"
                            Content="Guardar"
                            Width="110"
                            Height="32"
                            Margin="0,0,10,0"
                            VerticalAlignment="Bottom"
                            Command="{Binding GuardarCommand}"/>

                    <Button Grid.Column="4"
                            Content="Limpiar"
                            Width="110"
                            Height="32"
                            VerticalAlignment="Bottom"
                            Command="{Binding LimpiarCommand}"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="0">

            <DataGrid ItemsSource="{Binding Categorias}"
                      SelectedItem="{Binding CategoriaSeleccionada}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      RowHeight="44"
                      GridLinesVisibility="Horizontal">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding IdCategoriaProducto}"
                                        Width="80"/>

                    <DataGridTextColumn Header="Categoría"
                                        Binding="{Binding NombreCategoria}"
                                        Width="220"/>

                    <DataGridTextColumn Header="Descripción"
                                        Binding="{Binding Descripcion}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Fecha Registro"
                                        Binding="{Binding FechaRegistro, StringFormat=dd/MM/yyyy HH:mm}"
                                        Width="170"/>

                    <DataGridCheckBoxColumn Header="Activo"
                                            Binding="{Binding Estado}"
                                            Width="90"/>

                    <DataGridTemplateColumn Header="Acciones"
                                            Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Eliminar"
                                        Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding IdCategoriaProducto}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>