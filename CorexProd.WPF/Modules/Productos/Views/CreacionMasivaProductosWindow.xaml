<Window x:Class="CorexProd.WPF.Modules.Productos.Views.CreacionMasivaProductosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Creacion masiva de productos"
        Width="980"
        Height="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="160"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Creacion masiva" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="Formato: CODIGO;NOMBRE;CATEGORIA;UNIDAD_MEDIDA_ID;STOCK_MINIMO  |  Opcional: CODIGO;NOMBRE;SUPERCATEGORIA;CATEGORIA;UNIDAD_MEDIDA_ID;STOCK_MINIMO"
                       Foreground="#475569"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <TextBox Grid.Row="1"
                 Text="{Binding TextoCarga, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="13"
                 Padding="10"/>

        <DockPanel Grid.Row="2" Margin="0,12,0,10">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Procesar" Width="105" Height="32" Margin="0,0,8,0" Command="{Binding ProcesarCommand}"/>
                <Button Content="Crear productos" Width="130" Height="32" Margin="0,0,8,0" Command="{Binding CrearProductosCommand}"/>
                <Button Content="Limpiar" Width="90" Height="32" Margin="0,0,8,0" Command="{Binding LimpiarCommand}"/>
                <Button Content="Cancelar" Width="90" Height="32" Command="{Binding CancelarCommand}"/>
            </StackPanel>
            <TextBlock Text="{Binding Resumen}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#334155"/>
        </DockPanel>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Filas}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  RowHeight="36"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Linea" Binding="{Binding NumeroLinea}" Width="60"/>
                <DataGridTextColumn Header="Codigo" Binding="{Binding Codigo}" Width="120"/>
                <DataGridTextColumn Header="Nombre del producto" Binding="{Binding NombreProducto}" Width="*"/>
                <DataGridTextColumn Header="Supercategoría" Binding="{Binding NombreSuperCategoria}" Width="150"/>
                <DataGridTextColumn Header="Categoria encontrada" Binding="{Binding NombreCategoria}" Width="150"/>
                <DataGridTextColumn Header="Unidad encontrada" Binding="{Binding NombreUnidad}" Width="140"/>
                <DataGridTextColumn Header="Stock minimo" Binding="{Binding StockMinimo, StringFormat=N2}" Width="105"/>
                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="90"/>
                <DataGridTextColumn Header="Validacion" Binding="{Binding Validacion}" Width="260"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="4"
                   Text="{Binding DetalleErrores}"
                   Margin="0,10,0,0"
                   Foreground="#B91C1C"
                   TextWrapping="Wrap"
                   MaxHeight="68"/>
    </Grid>
</Window>
