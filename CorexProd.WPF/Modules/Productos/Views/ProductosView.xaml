<UserControl x:Class="CorexProd.WPF.Modules.Productos.Views.ProductosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="18"
                Margin="0,0,0,14">

            <StackPanel>
                <TextBlock Text="Gestión de Productos"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <TextBlock Margin="0,0,0,18"
                           FontSize="14">
                    <Run Text="Complete la información del producto. Los campos marcados con "/>
                    <Run Text="*" Foreground="Red" FontWeight="Bold"/>
                    <Run Text=" son obligatorios." Foreground="Red"/>
                </TextBlock>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.6*"/>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Código "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>

                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding Codigo, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Producto "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>

                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding NombreProducto, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Categoría "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>

                        <ComboBox Style="{StaticResource CampoCombo}"
                                  ItemsSource="{Binding Categorias}"
                                  DisplayMemberPath="NombreCategoria"
                                  SelectedValuePath="IdCategoriaProducto"
                                  SelectedValue="{Binding IdCategoriaProducto}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,20,14">
                        <TextBlock Style="{StaticResource LabelCampo}">
                            <Run Text="Unidad "/>
                            <Run Text="*" Foreground="Red"/>
                        </TextBlock>

                        <ComboBox Style="{StaticResource CampoCombo}"
                                  ItemsSource="{Binding UnidadesMedida}"
                                  DisplayMemberPath="NombreUnidad"
                                  SelectedValuePath="IdUnidadMedida"
                                  SelectedValue="{Binding IdUnidadMedida}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,20,14">
                        <TextBlock Text="Stock Mínimo"
                                   Style="{StaticResource LabelCampo}"/>

                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding StockMinimo, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <CheckBox Grid.Row="0"
                              Grid.Column="5"
                              Content="Activo"
                              IsChecked="{Binding Estado}"
                              FontSize="14"
                              VerticalAlignment="Bottom"
                              Margin="0,0,0,19"/>

                    <StackPanel Grid.Row="0"
                                Grid.Column="4"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,-45">
                        <Button Content="Guardar"
                                Width="110"
                                Height="32"
                                Margin="0,0,10,0"
                                Command="{Binding GuardarCommand}"/>

                        <Button Content="Limpiar"
                                Width="110"
                                Height="32"
                                Command="{Binding LimpiarCommand}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="0"
                Margin="0,35,0,0">

            <DataGrid ItemsSource="{Binding Productos}"
                      SelectedItem="{Binding ProductoSeleccionado}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      RowHeight="44"
                      GridLinesVisibility="Horizontal">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdProducto}" Width="60"/>
                    <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="110"/>
                    <DataGridTextColumn Header="Producto" Binding="{Binding NombreProducto}" Width="190"/>
                    <DataGridTextColumn Header="Categoría" Binding="{Binding NombreCategoria}" Width="160"/>
                    <DataGridTextColumn Header="Unidad" Binding="{Binding NombreUnidad}" Width="140"/>
                    <DataGridTextColumn Header="Stock Mín." Binding="{Binding StockMinimo}" Width="100"/>
                    <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Estado}" Width="80"/>

                    <DataGridTemplateColumn Header="Ficha Técnica" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Ver PDF"
                                        Height="28"
                                        Command="{Binding DataContext.VerFichaTecnicaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding Codigo}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Acciones" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Eliminar"
                                        HorizontalAlignment="Left"
                                        Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding IdProducto}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>