<Window x:Class="CorexProd.WPF.Modules.Reportes.Views.OciDespachadaDetalleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle de OCI despachada"
        Width="1050"
        Height="620"
        MinWidth="900"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Detalle de OCI despachada"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>
            <TextBlock x:Name="TxtSubtitulo"
                       Foreground="#64748B"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="#EFF6FF"
                BorderBrush="#DBEAFE"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="OCI" FontWeight="SemiBold" Foreground="#475569"/>
                    <TextBlock x:Name="TxtOci" FontWeight="Bold" Foreground="#0F172A" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Cliente" FontWeight="SemiBold" Foreground="#475569"/>
                    <TextBlock x:Name="TxtCliente" FontWeight="Bold" Foreground="#0F172A" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Totales" FontWeight="SemiBold" Foreground="#475569"/>
                    <TextBlock x:Name="TxtTotales" FontWeight="Bold" Foreground="#0F172A" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10">
            <DataGrid x:Name="GrdDetalle"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      RowHeight="38"
                      GridLinesVisibility="Horizontal"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#F8FAFC">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código" Binding="{Binding [Codigo]}" Width="110"/>
                    <DataGridTextColumn Header="Producto" Binding="{Binding [Descripcion]}" Width="*"/>
                    <DataGridTextColumn Header="Cant. solicitada" Binding="{Binding [Cantidad solicitada], StringFormat=N2}" Width="130"/>
                    <DataGridTextColumn Header="Cant. producida" Binding="{Binding [Cantidad producida], StringFormat=N2}" Width="130"/>
                    <DataGridTextColumn Header="Cant. despachada" Binding="{Binding [Cantidad despachada], StringFormat=N2}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Button Grid.Row="3"
                Content="Cerrar"
                Width="120"
                Height="36"
                Margin="0,16,0,0"
                HorizontalAlignment="Center"
                Click="Cerrar_Click"/>
    </Grid>
</Window>
