<UserControl x:Class="CorexProd.WPF.Modules.Reportes.Views.KardexProductosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CorexProd.WPF.Modules.Reportes.ViewModels">

    <UserControl.DataContext>
        <vm:KardexProductosViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="CampoFecha" TargetType="DatePicker">
            <Setter Property="Height" Value="32"/>
        </Style>

        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CeldaNumeroVerde" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#10B981"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="CeldaNumeroRojo" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="CeldaNumero" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F8FAFC" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,14">
            <TextBlock Text="Kardex de productos"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>
            <TextBlock Text="Movimiento general y trazabilidad por producto terminado."
                       Foreground="#64748B"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <TabControl Grid.Row="1" Background="Transparent">
            <TabItem Header="Kardex General">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.3*"/>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="1.25*"/>
                                <ColumnDefinition Width=".7*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                <TextBlock Text="Movimiento" Style="{StaticResource Label}"/>
                                <ComboBox ItemsSource="{Binding TiposMovimiento}"
                                          SelectedItem="{Binding TipoMovimientoSeleccionado}"
                                          DisplayMemberPath="Nombre"
                                          Style="{StaticResource CampoCombo}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,14,0">
                                <TextBlock Text="Almacén" Style="{StaticResource Label}"/>
                                <ComboBox ItemsSource="{Binding Almacenes}"
                                          SelectedItem="{Binding AlmacenSeleccionado}"
                                          DisplayMemberPath="NombreAlmacen"
                                          Style="{StaticResource CampoCombo}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,14,0">
                                <StackPanel Width="145" Margin="0,0,10,0">
                                    <TextBlock Text="Desde" Style="{StaticResource Label}"/>
                                    <DatePicker SelectedDate="{Binding FechaDesde}" Style="{StaticResource CampoFecha}"/>
                                </StackPanel>
                                <StackPanel Width="145">
                                    <TextBlock Text="Hasta" Style="{StaticResource Label}"/>
                                    <DatePicker SelectedDate="{Binding FechaHasta}" Style="{StaticResource CampoFecha}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,14,0">
                                <TextBlock Text="Registros" Style="{StaticResource Label}"/>
                                <ComboBox ItemsSource="{Binding Limites}"
                                          SelectedItem="{Binding LimiteSeleccionado}"
                                          Style="{StaticResource CampoCombo}"/>
                            </StackPanel>

                            <Button Grid.Column="4"
                                    Content="Buscar"
                                    Width="110"
                                    Height="36"
                                    Margin="0,19,0,0"
                                    Background="#0EA5E9"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    BorderThickness="0"
                                    Command="{Binding BuscarGeneralCommand}"/>

                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="5"
                                       Text="{Binding TotalRegistrosGeneral, StringFormat=Movimientos encontrados: {0}}"
                                       Foreground="#0F766E"
                                       FontWeight="SemiBold"
                                       Margin="0,12,0,0"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <DataGrid ItemsSource="{Binding MovimientosGeneral}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  RowHeight="42"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Fecha" Binding="{Binding FechaMovimiento, StringFormat=dd/MM/yyyy HH:mm}" Width="125"/>
                                <DataGridTextColumn Header="Movimiento" Binding="{Binding TipoMovimientoTexto}" Width="140"/>
                                <DataGridTextColumn Header="Producto" Binding="{Binding Producto}" Width="2.4*"/>
                                <DataGridTextColumn Header="Almacén" Binding="{Binding Almacen}" Width="1.1*"/>
                                <DataGridTextColumn Header="UM" Binding="{Binding UnidadMedida}" Width="70"/>
                                <DataGridTextColumn Header="Entrada" Binding="{Binding Entrada, StringFormat=N2}" Width="90" ElementStyle="{StaticResource CeldaNumeroVerde}"/>
                                <DataGridTextColumn Header="Salida" Binding="{Binding Salida, StringFormat=N2}" Width="90" ElementStyle="{StaticResource CeldaNumeroRojo}"/>
                                <DataGridTextColumn Header="Stock" Binding="{Binding Stock, StringFormat=N2}" Width="90" ElementStyle="{StaticResource CeldaNumero}"/>
                                <DataGridTextColumn Header="Usuario" Binding="{Binding Usuario}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Kardex por producto">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="1.05*"/>
                                <ColumnDefinition Width=".95*"/>
                                <ColumnDefinition Width=".65*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,16,10">
                                <TextBlock Text="Desde" Style="{StaticResource Label}"/>
                                <DatePicker SelectedDate="{Binding FechaDesde}" Style="{StaticResource CampoFecha}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Hasta" Style="{StaticResource Label}"/>
                                <DatePicker SelectedDate="{Binding FechaHasta}" Style="{StaticResource CampoFecha}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,16,10">
                                <TextBlock Text="Almacén - Movimiento" Style="{StaticResource Label}"/>
                                <ComboBox ItemsSource="{Binding Almacenes}"
                                          SelectedItem="{Binding AlmacenSeleccionado}"
                                          DisplayMemberPath="NombreAlmacen"
                                          Style="{StaticResource CampoCombo}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,16,10">
                                <TextBlock Text="Tipos de Movimiento" Style="{StaticResource Label}"/>
                                <ComboBox ItemsSource="{Binding TiposMovimiento}"
                                          SelectedItem="{Binding TipoMovimientoSeleccionado}"
                                          DisplayMemberPath="Nombre"
                                          Style="{StaticResource CampoCombo}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,16,10">
                                <TextBlock Text="Registros" Style="{StaticResource Label}"/>
                                <ComboBox ItemsSource="{Binding Limites}"
                                          SelectedItem="{Binding LimiteSeleccionado}"
                                          Style="{StaticResource CampoCombo}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,16,0">
                                <TextBlock Text="Producto" Style="{StaticResource Label}"/>
                                <Grid>
                                    <TextBox x:Name="ProductoBusquedaText"
                                             Text="{Binding ProductoTexto, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource CampoTexto}"/>
                                    <Popup IsOpen="{Binding ProductosDropDownAbierto, Mode=TwoWay}"
                                           PlacementTarget="{Binding ElementName=ProductoBusquedaText}"
                                           Placement="Bottom"
                                           StaysOpen="False"
                                           AllowsTransparency="True">
                                        <Border Width="{Binding ActualWidth, ElementName=ProductoBusquedaText}"
                                                MaxHeight="230"
                                                Background="White"
                                                BorderBrush="#CBD5E1"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <ListBox ItemsSource="{Binding ProductosFiltrados}"
                                                     SelectedItem="{Binding ProductoSeleccionado, Mode=TwoWay}"
                                                     DisplayMemberPath="ProductoBusqueda"
                                                     BorderThickness="0"
                                                     MaxHeight="220"/>
                                        </Border>
                                    </Popup>
                                </Grid>
                                <TextBlock Text="Escriba mínimo 3 caracteres para abrir la búsqueda."
                                           Foreground="#94A3B8"
                                           FontSize="11"
                                           Margin="2,4,0,0"/>
                            </StackPanel>

                            <Button Grid.Column="4"
                                    Grid.Row="0"
                                    HorizontalAlignment="Right"
                                    Content="Consultar"
                                    Width="120"
                                    Height="36"
                                    Margin="0,19,0,0"
                                    Background="#2563EB"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    BorderThickness="0"
                                    Command="{Binding BuscarProductoCommand}"/>

                            <Button Grid.Column="4"
                                    Grid.Row="1"
                                    HorizontalAlignment="Right"
                                    Content="Limpiar filtros"
                                    Width="120"
                                    Height="32"
                                    Margin="0,19,0,0"
                                    Background="#F8FAFC"
                                    BorderBrush="#CBD5E1"
                                    Foreground="#334155"
                                    FontWeight="SemiBold"
                                    Command="{Binding LimpiarCommand}"/>

                        </Grid>
                    </Border>

                    <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
                        <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Entradas" Foreground="#64748B" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding TotalEntradasProducto, StringFormat=N2}" Foreground="#10B981" FontSize="24" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Salidas" Foreground="#64748B" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding TotalSalidasProducto, StringFormat=N2}" Foreground="#EF4444" FontSize="24" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Devoluciones" Foreground="#64748B" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding TotalDevolucionesProducto, StringFormat=N2}" Foreground="#F59E0B" FontSize="24" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Stock final" Foreground="#64748B" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding StockFinalProducto, StringFormat=N2}" Foreground="#0F172A" FontSize="24" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                        <DataGrid ItemsSource="{Binding MovimientosProducto}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  RowHeight="44"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Fecha" Binding="{Binding FechaMovimiento, StringFormat=dd/MM/yyyy HH:mm}" Width="125"/>
                                <DataGridTextColumn Header="Motivo" Binding="{Binding TipoMovimientoTexto}" Width="150"/>
                                <DataGridTextColumn Header="Almacén" Binding="{Binding Almacen}" Width="1.2*"/>
                                <DataGridTextColumn Header="UM" Binding="{Binding UnidadMedida}" Width="70"/>
                                <DataGridTextColumn Header="Entrada" Binding="{Binding Entrada, StringFormat=N2}" Width="90" ElementStyle="{StaticResource CeldaNumeroVerde}"/>
                                <DataGridTextColumn Header="Salida" Binding="{Binding Salida, StringFormat=N2}" Width="90" ElementStyle="{StaticResource CeldaNumeroRojo}"/>
                                <DataGridTextColumn Header="Devolución" Binding="{Binding Devolucion, StringFormat=N2}" Width="100" ElementStyle="{StaticResource CeldaNumero}"/>
                                <DataGridTextColumn Header="Stock" Binding="{Binding Stock, StringFormat=N2}" Width="90" ElementStyle="{StaticResource CeldaNumero}"/>
                                <DataGridTextColumn Header="Observación" Binding="{Binding Observacion}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
