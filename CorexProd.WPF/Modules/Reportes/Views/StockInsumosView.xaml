<UserControl x:Class="CorexProd.WPF.Modules.Reportes.Views.StockInsumosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="LabelCampo" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="CampoTexto" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style x:Key="CampoCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="18"
                Margin="0,0,0,14">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,16">
                    <TextBlock Text="Consulta de codigo, insumo, categoria y cantidad disponible."
                               Foreground="#6B7280"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Row="0"
                        Grid.Column="1"
                        Background="#EFF6FF"
                        BorderBrush="#BFDBFE"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,8"
                        Margin="0,0,10,16">
                    <StackPanel>
                        <TextBlock Text="Insumos"
                                   Foreground="#1D4ED8"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding TotalInsumos}"
                                   Foreground="#1E3A8A"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="2"
                        Background="#ECFDF5"
                        BorderBrush="#A7F3D0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,8"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Cantidad total"
                                   Foreground="#047857"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding CantidadTotal, StringFormat=N2}"
                                   Foreground="#065F46"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1" Grid.ColumnSpan="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Buscar por codigo o nombre"
                                   Style="{StaticResource LabelCampo}"/>
                        <TextBox Style="{StaticResource CampoTexto}"
                                 Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock Text="Categoria"
                                   Style="{StaticResource LabelCampo}"/>
                        <ComboBox Style="{StaticResource CampoCombo}"
                                  ItemsSource="{Binding Categorias}"
                                  DisplayMemberPath="NombreCategoria"
                                  SelectedValuePath="IdCategoriaInsumo"
                                  SelectedValue="{Binding IdCategoriaSeleccionada}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Bottom">
                        <Button Content="Buscar"
                                Width="95"
                                Height="32"
                                Margin="0,0,8,0"
                                Command="{Binding BuscarCommand}"/>
                        <Button Content="Limpiar"
                                Width="95"
                                Height="32"
                                Margin="0,0,8,0"
                                Command="{Binding LimpiarCommand}"/>
                        <Button Content="Actualizar"
                                Width="95"
                                Height="32"
                                Command="{Binding ActualizarCommand}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <DataGrid ItemsSource="{Binding StockInsumos}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      RowHeight="42"
                      GridLinesVisibility="Horizontal">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="CODIGO"
                                        Binding="{Binding Codigo}"
                                        Width="120"/>
                    <DataGridTextColumn Header="NOMBRE DE INSUMO"
                                        Binding="{Binding NombreInsumo}"
                                        Width="*"/>
                    <DataGridTextColumn Header="CATEGORIA"
                                        Binding="{Binding NombreCategoria}"
                                        Width="160"/>
                    <DataGridTextColumn Header="UNIDAD"
                                        Binding="{Binding Abreviatura}"
                                        Width="90"/>
                    <DataGridTextColumn Header="STOCK MIN."
                                        Binding="{Binding StockMinimo, StringFormat=N2}"
                                        Width="110"/>
                    <DataGridTextColumn Header="CANTIDAD"
                                        Binding="{Binding Cantidad, StringFormat=N2}"
                                        Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
