<Window x:Class="CorexProd.WPF.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CorexProd - Login"
        Height="420"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F3F4F6">

    <Grid>
        <Border Width="330"
                Padding="25"
                Background="White"
                CornerRadius="12"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel>

                <TextBlock Text="CorexProd"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>

                <TextBlock Text="Inicio de sesión"
                           FontSize="15"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock Text="Usuario"/>
                <TextBox Text="{Binding Usuario}"
                         Height="35"
                         Margin="0,5,0,15"/>

                <TextBlock Text="Contraseña"/>
                <PasswordBox x:Name="TxtClave"
                             Height="35"
                             Margin="0,5,0,20"/>

                <Button Content="Ingresar"
                        Height="38"
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=TxtClave}"
                        Background="#2563EB"
                        Foreground="White"
                        FontWeight="Bold"/>

                <TextBlock Text="{Binding Mensaje}"
                           Foreground="Red"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>