<UserControl x:Class="CorexProd.WPF.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             Loaded="HomeView_Loaded"
             PreviewKeyDown="HomeView_PreviewKeyDown">
    <UserControl.Resources>
        <Style x:Key="NavigationButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1E293B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#334155"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E2E8F0"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ModuleCardTemplate">
            <Border Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="7"
                    Padding="20"
                    Margin="0,0,14,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="34"
                            Height="34"
                            CornerRadius="6"
                            Background="{Binding IconBackground}"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding Icon}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Foreground="{Binding Accent}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A"/>
                        <TextBlock Text="{Binding Description}"
                                   FontSize="12"
                                   LineHeight="18"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,0,1"
                Padding="26,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding CurrentPage.Title}"
                               FontSize="25"
                               FontWeight="Bold"
                               Foreground="#0F172A"/>
                    <TextBlock Text="{Binding CurrentPage.Subtitle}"
                               FontSize="13"
                               Foreground="#64748B"
                               Margin="0,5,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#FFF7ED"
                        BorderBrush="#FED7AA"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="14,9"
                        Margin="18,0,0,0"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="SISTEMA ERP"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="#C2410C"/>
                        <TextBlock Text="CorexProd"
                                   FontSize="12"
                                   Foreground="#7C2D12"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="26,20,12,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="{Binding CurrentPage.HighlightBackground}"
                    BorderBrush="{Binding CurrentPage.HighlightBorder}"
                    BorderThickness="1"
                    CornerRadius="7"
                    Padding="18,14"
                    Margin="0,0,14,16">
                <TextBlock Text="{Binding CurrentPage.Introduction}"
                           FontSize="13"
                           LineHeight="19"
                           Foreground="#334155"
                           TextWrapping="Wrap"/>
            </Border>

            <ItemsControl Grid.Row="1"
                          ItemsSource="{Binding CurrentPage.Modules}"
                          ItemTemplate="{StaticResource ModuleCardTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Grid>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="0,1,0,0"
                Padding="26,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="&#xE72B;"
                        Style="{StaticResource NavigationButtonStyle}"
                        HorizontalAlignment="Left"
                        ToolTip="Página anterior"
                        IsEnabled="{Binding CanGoPrevious}"
                        Click="PreviousPage_Click"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PageIndicator}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#334155"
                               HorizontalAlignment="Center"/>
                    <Border Width="150"
                            Height="3"
                            Background="#E2E8F0"
                            CornerRadius="2"
                            Margin="0,7,0,0">
                        <Border Width="{Binding ProgressWidth}"
                                Background="#2563EB"
                                CornerRadius="2"
                                HorizontalAlignment="Left"/>
                    </Border>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="&#xE72A;"
                        Style="{StaticResource NavigationButtonStyle}"
                        HorizontalAlignment="Right"
                        ToolTip="Página siguiente"
                        IsEnabled="{Binding CanGoNext}"
                        Click="NextPage_Click"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
