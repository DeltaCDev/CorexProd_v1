<UserControl x:Class="CorexProd.WPF.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="ModuloTitulo" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="ModuloTexto" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>

        <Style x:Key="IconoModulo" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SeccionTitulo" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="25" MaxWidth="1380" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#F8FAFC"
                    CornerRadius="8"
                    Padding="24"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,24,0">
                        <TextBlock Text="Bienvenido a CorexProd"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"/>
                        <TextBlock Text="Sistema ERP para ventas, almacen, productos, produccion, destajo, reportes y seguridad."
                                   FontSize="14"
                                   Foreground="#475569"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#FFF7ED"
                            BorderBrush="#FED7AA"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Panel operativo"
                                       FontWeight="SemiBold"
                                       Foreground="#C2410C"
                                       FontSize="13"/>
                            <TextBlock Text="Resumen de módulos activos"
                                       Foreground="#7C2D12"
                                       FontSize="12"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="1"
                         Columns="4"
                         Margin="0,0,0,16">
                <Border Background="#EFF6FF" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;" Style="{StaticResource IconoModulo}" Foreground="#1D4ED8"/>
                            <TextBlock Text="Ventas" Style="{StaticResource ModuloTitulo}"/>
                        </StackPanel>
                        <TextBlock Text="Proformas con editor, detalle, anulacion, PDF y flujo de documentos comerciales."
                                   Style="{StaticResource ModuloTexto}"/>
                    </StackPanel>
                </Border>

                <Border Background="#F0FDF4" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7B8;" Style="{StaticResource IconoModulo}" Foreground="#15803D"/>
                            <TextBlock Text="Almacen" Style="{StaticResource ModuloTitulo}"/>
                        </StackPanel>
                        <TextBlock Text="Unidades, categorias de insumos, insumos e ingresos manuales de stock con abastecimiento."
                                   Style="{StaticResource ModuloTexto}"/>
                    </StackPanel>
                </Border>

                <Border Background="#FEFCE8" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;" Style="{StaticResource IconoModulo}" Foreground="#A16207"/>
                            <TextBlock Text="Produccion" Style="{StaticResource ModuloTitulo}"/>
                        </StackPanel>
                        <TextBlock Text="Ficha tecnica de produccion con versiones, cabecera por producto y consumo de insumos."
                                   Style="{StaticResource ModuloTexto}"/>
                    </StackPanel>
                </Border>

                <Border Background="#FFF1F2" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D2;" Style="{StaticResource IconoModulo}" Foreground="#BE123C"/>
                            <TextBlock Text="Seguridad" Style="{StaticResource ModuloTitulo}"/>
                        </StackPanel>
                        <TextBlock Text="Usuarios, roles, permisos por menu, empleados, cargos, empresa, parametros y cambio de clave."
                                   Style="{StaticResource ModuloTexto}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*"/>
                    <ColumnDefinition Width="0.85*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="8"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        Padding="24"
                        Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock Text="Contenido disponible" Style="{StaticResource SeccionTitulo}"/>

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,22,16">
                                <TextBlock Text="Ventas" Style="{StaticResource ModuloTitulo}"/>
                                <TextBlock Text="Proformas, clientes, productos en detalle, importes, anulaciones y exportacion PDF."
                                           Style="{StaticResource ModuloTexto}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="Productos" Style="{StaticResource ModuloTitulo}"/>
                                <TextBlock Text="Categorias de productos, productos terminados, unidades, stock minimo y ficha tecnica PDF."
                                           Style="{StaticResource ModuloTexto}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,22,16">
                                <TextBlock Text="Almacen" Style="{StaticResource ModuloTitulo}"/>
                                <TextBlock Text="Unidades de medida, categorias de insumos, insumos, proveedores e ingresos manuales de stock."
                                           Style="{StaticResource ModuloTexto}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="Destajo y Pagos" Style="{StaticResource ModuloTitulo}"/>
                                <TextBlock Text="Panel de destajo, periodos, movimientos operativos, prestamos, cuotas, lotes y reportes."
                                           Style="{StaticResource ModuloTexto}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,22,0">
                                <TextBlock Text="Reportes" Style="{StaticResource ModuloTitulo}"/>
                                <TextBlock Text="Stock de productos terminados, stock de insumos y base preparada para kardex."
                                           Style="{StaticResource ModuloTexto}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Seguridad" Style="{StaticResource ModuloTitulo}"/>
                                <TextBlock Text="Roles, permisos de menu, usuarios, empleados, empresa, cargos, parametros y sesion."
                                           Style="{StaticResource ModuloTexto}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="8"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        Padding="24">
                    <StackPanel>
                        <TextBlock Text="Flujo de trabajo" Style="{StaticResource SeccionTitulo}"/>

                        <TextBlock Text="1. Configure seguridad: empresa, cargos, empleados, usuarios, roles y permisos."
                                   Style="{StaticResource ModuloTexto}"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="2. Registre maestros: unidades, categorias, insumos, productos, clientes y proveedores."
                                   Style="{StaticResource ModuloTexto}"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="3. Defina fichas tecnicas para productos y consumo de insumos."
                                   Style="{StaticResource ModuloTexto}"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="4. Use ingresos manuales para abastecer stock y proformas para la gestion comercial."
                                   Style="{StaticResource ModuloTexto}"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="5. Consulte stock, reportes y control de destajo segun permisos del usuario."
                                   Style="{StaticResource ModuloTexto}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="Estado del sistema" Style="{StaticResource SeccionTitulo}"/>
                    <TextBlock Text="CorexProd ya cuenta con módulos operativos para mantener maestros, controlar accesos, registrar documentos comerciales, administrar stock, definir fichas técnicas y consultar reportes."
                               FontSize="14"
                               Foreground="#475569"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="La navegación lateral muestra únicamente las opciones permitidas para el rol del usuario conectado."
                               FontSize="14"
                               Foreground="#475569"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
