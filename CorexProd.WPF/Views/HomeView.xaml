<UserControl x:Class="CorexProd.WPF.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- BIENVENIDA -->
        <Border Background="#F8FAFC"
                CornerRadius="12"
                Padding="25"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <StackPanel>
                <TextBlock Text="Bienvenido a CorexProd"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#111827"/>

                <TextBlock Text="Sistema ERP de producción, ventas, almacén, inventario y seguridad."
                           FontSize="15"
                           Foreground="#64748B"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- TARJETAS -->
        <UniformGrid Grid.Row="1"
                     Columns="4"
                     Margin="0,20,0,20">

            <Border Background="#EFF6FF"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Seguridad"
                               FontSize="14"
                               Foreground="#1D4ED8"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Usuarios, roles y permisos"
                               FontSize="13"
                               Foreground="#475569"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#F0FDF4"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Almacén"
                               FontSize="14"
                               Foreground="#15803D"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Insumos, unidades y stock"
                               FontSize="13"
                               Foreground="#475569"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#FEFCE8"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Producción"
                               FontSize="14"
                               Foreground="#A16207"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Órdenes y seguimiento"
                               FontSize="13"
                               Foreground="#475569"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#FFF1F2"
                    CornerRadius="12"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Reportes"
                               FontSize="14"
                               Foreground="#BE123C"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Stock, kardex y análisis"
                               FontSize="13"
                               Foreground="#475569"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- PANEL INFORMATIVO -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="25"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <StackPanel>
                <TextBlock Text="Estado del sistema"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#111827"
                           Margin="0,0,0,15"/>

                <TextBlock Text="CorexProd se encuentra listo para continuar con la implementación de módulos operativos."
                           FontSize="14"
                           Foreground="#475569"/>

                <TextBlock Text="Módulos completados: Roles, Cargos, Empleados, Usuarios, Login, Menú por permisos y Cambio de clave."
                           FontSize="14"
                           Foreground="#475569"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>